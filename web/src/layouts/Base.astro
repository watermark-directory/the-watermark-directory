---
import Header from "../components/Header.astro";
import Icon from "../components/Icon.astro";
import Logo from "../components/Logo.astro";
import RumScript from "../components/RumScript.astro";
import SEO from "../components/SEO.astro";
import SectionToc from "../components/SectionToc.astro";
import { footerGroups, type SectionId, type TocEntry } from "../lib/nav";
import { SITE_NAME, SITE_DESCRIPTION, withBase } from "../lib/site";
import "../styles/site.css";

interface BaseProps {
  title: string;
  description?: string;
  section?: SectionId;
  /** Kill-switch for the rail (rarely needed — it only shows with a `toc`). */
  rail?: boolean;
  /** Page-local table of contents — anchors on THIS page. The rail is a TOC for
   *  the page you're on, never section navigation; it shows only when non-empty. */
  toc?: TocEntry[];
  /** Rail heading override (defaults to "On this page"; the record screen uses
   *  "On this record"). */
  tocTitle?: string;
  /** og:type — defaults to "website"; docs essays pass "article". */
  ogType?: "website" | "article";
  /** Keep this route out of search indexes (internal galleries, previews, leftovers). */
  noindex?: boolean;
  /** Sequential navigation — emitted as <link rel="prev/next"> for crawlers and Bing. */
  prevHref?: string;
  nextHref?: string;
}

// `.astro` pages pass these props directly; `.mdx` pages using `layout:` pass
// them nested under `frontmatter`. Accept both.
const raw = Astro.props as BaseProps & { frontmatter?: BaseProps };
const {
  title,
  description = SITE_DESCRIPTION,
  section = "home",
  rail = true,
  toc = [],
  tocTitle,
  ogType = "website",
  noindex = false,
  prevHref,
  nextHref,
} = raw.frontmatter ?? raw;
const showRail = rail !== false && toc.length > 0;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />
    <link
      rel="preload"
      href="https://fonts.googleapis.com/css2?family=Archivo:wght@400;500;600;700;800;900&family=IBM+Plex+Mono:wght@400;500;600&display=swap"
      as="style"
    />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Archivo:wght@400;500;600;700;800;900&family=IBM+Plex+Mono:wght@400;500;600&display=swap"
      rel="stylesheet"
    />
    <link rel="icon" type="image/svg+xml" href={withBase("/favicon.svg")} />
    <link rel="icon" type="image/png" sizes="32x32" href={withBase("/favicon-32.png")} />
    <link rel="icon" type="image/png" sizes="16x16" href={withBase("/favicon-16.png")} />
    <link rel="apple-touch-icon" sizes="180x180" href={withBase("/apple-touch-icon.png")} />
    <meta name="theme-color" content="#16201a" />
    <link rel="mcp" href="/.well-known/mcp.json" type="application/json" />
    {prevHref && <link rel="prev" href={prevHref} />}
    {nextHref && <link rel="next" href={nextHref} />}
    <title>{title === SITE_NAME ? title : `${title} · ${SITE_NAME}`}</title>
    <SEO title={title} description={description} type={ogType} noindex={noindex} />
  </head>
  <body>
    <a class="skip-link" href="#main">Skip to content</a>
    <input
      type="checkbox"
      id="bosc-nav-toggle"
      class="nav-toggle"
      aria-label="Open the section menu"
      aria-controls="bosc-sections"
    />
    <Header active={section} />
    <div class:list={["layout", { "no-rail": !showRail }]}>
      {showRail && <SectionToc items={toc} title={tocTitle} />}
      <main id="main" class="content" tabindex="-1">
        <slot />
      </main>
    </div>
    <footer class="site-footer">
      <div class="footer-main">
        <p class="footer-contract">
          <strong>Pre-launch — this site isn't public yet.</strong> Every figure
          carries a source; inference is labeled; redactions are shown, not hidden.
          Nothing here is a verdict.
        </p>
        <div class="footer-actions">
          <span class="footer-pill"><span class="dot" aria-hidden="true"></span>provenance-first</span>
          <a class="btn btn--icon" href={withBase("/submit")}><Icon name="correction" size={15} /> Submit a tip or correction</a>
        </div>
      </div>
      <div class="footer-nav">
        <div class="footer-brand-col">
          <a class="footer-brand" href={withBase("/")}><Logo size={18} class="footer-mark" /><span class="footer-wordmark">Watermark<span class="brand-dot">.</span></span></a>
          <span class="footer-manifesto">static · no trackers · every page reads with JS off</span>
        </div>
        <nav aria-label="Footer site navigation" class="footer-cols">
          {footerGroups().map((group) => (
            <div class="footer-col">
              <span class="footer-col-heading">{group.heading}</span>
              {group.links.map((link) => <a href={withBase(link.href)}>{link.label}</a>)}
            </div>
          ))}
        </nav>
      </div>
    </footer>
    <script>
      import "../scripts/search.ts";
      import "../scripts/toc.ts";
    </script>
    <RumScript />
  </body>
</html>
