---
/**
 * The per-site "needs" board (#781) — the locked sections from the readiness model (#787),
 * rendered as an open ask for sources.
 *
 * This IS a thin peer's leads/needs list. Lima's leads board reads the curated corpus-audit
 * (`leads.ts`); a peer has no per-site leads feed yet, so its honest "what we're seeking" is the
 * set of sections still waiting on a source. Each card routes to the submissions seam, so a
 * visitor can engage and contribute without the whole story being in place (the #781 thesis).
 * Shared by the partial-site landing (`PartialSiteHome`) and the peer leads page so the board has
 * one source of truth.
 */
import { SECTION_META, lockedSections } from "../lib/readiness";
import { withSite } from "../lib/site";

interface Props {
  slug: string;
}
const { slug } = Astro.props as Props;

const needs = lockedSections(slug).map((s) => ({
  label: SECTION_META[s].label,
  holds: SECTION_META[s].holds,
}));
---

{
  needs.length > 0 ? (
    <div class="needs-cards">
      {needs.map((c) => (
        <a class="needs-card" href={withSite("/submit")}>
          <div class="needs-card-top">
            <span class="needs-card-label">{c.label}</span>
            <span class="needs-card-lock" aria-hidden="true">
              <svg viewBox="0 0 24 24" width="13" height="13" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round">
                <rect x="5" y="11" width="14" height="9" rx="1" />
                <path d="M8 11 V7.5 A4 4 0 0 1 16 7.5 V11" />
              </svg>
            </span>
          </div>
          <span class="needs-card-desc">{c.holds}</span>
          <span class="needs-card-go">Have a source? Submit it →</span>
        </a>
      ))}
    </div>
  ) : null
}

<style>
  .needs-cards { display: grid; grid-template-columns: repeat(auto-fill, minmax(248px, 1fr)); gap: 14px; }
  .needs-card {
    display: flex; flex-direction: column; border: 1px solid var(--bosc-rule); background: #efece2;
    padding: 16px 18px; text-decoration: none; color: inherit;
  }
  .needs-card:hover { border-color: var(--bosc-forest); }
  .needs-card-top { display: flex; align-items: center; justify-content: space-between; gap: 10px; }
  .needs-card-label { font-size: 1rem; font-weight: 700; color: var(--bosc-ink); }
  .needs-card-lock { color: var(--bosc-faint); display: inline-flex; }
  .needs-card-desc { font-size: 0.82rem; color: var(--bosc-muted); line-height: 1.5; margin-top: 6px; flex: 1 1 auto; }
  .needs-card-go { font-size: 0.78rem; font-weight: 700; color: var(--bosc-ink); margin-top: 12px; }
</style>
