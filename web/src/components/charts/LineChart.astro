---
/**
 * Line + area chart (#306) — a cumulative time series, the last point labeled.
 * SSR SVG, no JS. Forest line over a faint forest fill.
 */
import type { TagKind } from "~/lib/teardown";
import { buildLine, type LinePoint, type RefLineInput } from "~/lib/charts";
import EvidenceTag from "../EvidenceTag.astro";

interface Props {
  data: LinePoint[];
  kicker?: string;
  title: string;
  max?: number;
  /** Label drawn at the final point (e.g. "340.2 ac"). */
  endLabel?: string;
  /** Dashed horizontal threshold lines (draw / limit / level) — see `RefLineInput`. */
  refs?: RefLineInput[];
  evidence?: TagKind;
  source?: string;
  caption?: string;
}
const {
  data,
  kicker = "Line · time series",
  title,
  max,
  endLabel,
  refs,
  evidence,
  source,
  caption,
} = Astro.props;
const c = buildLine(data, { ...(max != null ? { max } : {}), ...(refs ? { refs } : {}) });
---

<figure class="chart-card">
  <figcaption class="chart-head">
    <span class="chart-kicker">{kicker}</span>
    <span class="chart-title">{title}</span>
  </figcaption>
  <svg viewBox={`0 0 ${c.width} ${c.height}`} class="chart-svg" role="img" aria-label={title}>
    {
      c.grid.map((g) => (
        <Fragment>
          <line x1={c.plot.left} y1={g.y} x2={c.plot.right} y2={g.y} stroke="var(--data-grid)" stroke-width="1" />
          <text x={c.plot.left - 6} y={g.y + 3} text-anchor="end" class="chart-axis">{g.value}</text>
        </Fragment>
      ))
    }
    <line x1={c.plot.left} y1={c.baselineY} x2={c.plot.right} y2={c.baselineY} stroke="var(--data-axis)" stroke-width="1" />
    <path d={c.area} fill="var(--data-1)" fill-opacity="0.10" />
    {
      c.refLines.map((r) => (
        <Fragment>
          <line x1={c.plot.left} y1={r.y} x2={c.plot.right} y2={r.y} stroke={r.color} stroke-width="1.5" stroke-dasharray={r.dash} />
          <text x={c.plot.right} y={r.y - 4} text-anchor="end" class="chart-ref-label" style={`fill:${r.color}`}>{r.label}</text>
        </Fragment>
      ))
    }
    <path d={c.line} fill="none" stroke="var(--data-1)" stroke-width="2.2" stroke-linejoin="round" stroke-linecap="round" />
    {
      c.dots.map((d) => (
        <Fragment>
          <circle cx={d.x} cy={d.y} r="3" fill="var(--surface-card)" stroke="var(--data-1)" stroke-width="2" />
          <text x={d.x} y={c.plot.labelY} text-anchor="middle" class="chart-axis chart-axis--x">{d.label}</text>
        </Fragment>
      ))
    }
    <circle cx={c.last.x} cy={c.last.y} r="4.5" fill="var(--data-1)" stroke="var(--surface-card)" stroke-width="2" />
    {endLabel && <text x={c.last.x - 6} y={c.last.y + 4} text-anchor="end" class="chart-val is-peak">{endLabel}</text>}
  </svg>
  {
    (evidence || source || caption) && (
      <figcaption class="chart-foot">
        {evidence && <EvidenceTag kind={evidence} title={source} />}
        {caption && <span class="chart-caption">{caption}</span>}
        {source && !caption && <span class="chart-caption">{source}</span>}
      </figcaption>
    )
  }
</figure>
