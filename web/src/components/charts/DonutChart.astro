---
/**
 * Donut chart (#306) — composition, the total in the center, a labeled legend beside it.
 * SSR SVG, no JS. Forest tints for the slices.
 */
import type { TagKind } from "~/lib/teardown";
import { buildDonut, type DonutSlice } from "~/lib/charts";
import EvidenceTag from "../EvidenceTag.astro";

interface Props {
  slices: DonutSlice[];
  kicker?: string;
  title: string;
  /** The label under the center total (e.g. "records"). */
  centerLabel?: string;
  evidence?: TagKind;
  source?: string;
}
const { slices, kicker = "Donut · composition", title, centerLabel, evidence, source } = Astro.props;
const c = buildDonut(slices);
---

<figure class="chart-card">
  <figcaption class="chart-head">
    <span class="chart-kicker">{kicker}</span>
    <span class="chart-title">{title}</span>
  </figcaption>
  <div class="chart-donut">
    <svg viewBox="0 0 200 200" class="chart-donut-svg" role="img" aria-label={title}>
      {c.segments.map((s) => <path d={s.d} fill={s.fill} stroke="var(--surface-card)" stroke-width="2" />)}
      <text x="100" y="96" text-anchor="middle" class="chart-donut-total">{c.total}</text>
      {centerLabel && <text x="100" y="116" text-anchor="middle" class="chart-axis">{centerLabel}</text>}
    </svg>
    <ul class="chart-donut-legend">
      {
        c.segments.map((s) => (
          <li class="chart-legend-item">
            <span class="chart-swatch" style={`background:${s.fill}`} />
            {s.label}
            <span class="chart-donut-val">{s.value}</span>
          </li>
        ))
      }
    </ul>
  </div>
  {
    (evidence || source) && (
      <figcaption class="chart-foot">
        {evidence && <EvidenceTag kind={evidence} title={source} />}
        {source && <span class="chart-caption">{source}</span>}
      </figcaption>
    )
  }
</figure>
