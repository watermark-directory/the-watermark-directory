---
/**
 * Record Teardown — the guided walk's signature teaching component (design
 * handoff: "The Record Teardown"). One data-driven component, three teaching
 * shapes selected by `layout`:
 *   - split     source ↔ extraction across the gutter (default)
 *   - scroll    vertical scrollytelling (also the small-screen reflow)
 *   - annotated numbered pins keyed to a margin rail (redaction-heavy records)
 * The five parts: ① source ② what we read ③ what it reveals ④ how to check
 * ⑤ where it connects. Styling lives in styles/site.css (`.td-*`), an extension
 * of the existing token vocabulary. SSR-only — no JS, fully readable with JS off.
 */
import EvidenceTag from "./EvidenceTag.astro";
import RedactionReveal from "./RedactionReveal.astro";
import TeardownSourceCard from "./TeardownSourceCard.astro";
import type { TeardownLayout, TeardownRecord } from "../lib/teardown";
import { resolveTeardown } from "../lib/teardownResolve";

interface Props {
  record: TeardownRecord;
  layout?: TeardownLayout;
  /** Emit `beat-*` ids on the five beats so the record-screen rail can scroll-spy
   *  them (#195). Set on the DEFAULT (split) instance only — the screen renders all
   *  three layouts, so ids on more than one would collide. */
  anchors?: boolean;
}
const { record, layout = "split", anchors = false } = Astro.props;
// Resolve curated content against the live bundle: load-bearing figures + the
// source viewer bind to the record's real extraction, deep verify/concept links,
// present-checked, with graceful fallback to the curated value/links.
const { teardown: r, verifyResolved, sourceFields, sourceDoc } = resolveTeardown(record);
const pins = r.pins ?? [];
---

<div class="teardown" data-layout={layout}>
  <!-- ===== header strip ===== -->
  <div class="td-head">
    <div class="td-head-bar" aria-hidden="true"></div>
    <div class="td-head-main">
      <div class="td-eyebrow">Record Teardown</div>
      <p class="td-title">{r.title}</p>
      <div class="td-doc">{r.docName}</div>
      {verifyResolved && (
        <a class="td-live" href={r.check.verifyHref} title="This record is in the published content bundle — the same row the library renders.">● in the published bundle</a>
      )}
    </div>
    <div class="td-kind">{r.source.kind}</div>
  </div>

  {/* ============================ LAYOUT A · SPLIT ============================ */}
  {layout === "split" && (
    <div class="td-body">
      <div class="td-split">
        {/* ① source */}
        <div class="td-pane td-pane--source" id={anchors ? "beat-source" : undefined}>
          <div class="td-part">① The source</div>
          <TeardownSourceCard source={r.source} fields={sourceFields} sourceDoc={sourceDoc} size="md" />
        </div>
        {/* ② what we read */}
        <div class="td-pane td-pane--read" id={anchors ? "beat-read" : undefined}>
          <div class="td-part is-forest">② What we read from it</div>
          <div class="td-rows">
            {r.extraction.map((row) => (
              <div class="td-row">
                <div class="td-row-label">{row.label}</div>
                <div class:list={["td-row-value", row.warn && "is-warn", row.live && "is-live"]}>
                  {row.live && <span class="td-live-dot" aria-hidden="true" title="Read live from the published record"></span>}{row.value}
                </div>
              </div>
            ))}
          </div>
          <div class="td-note">● figures read live from the published record · ~ markers preserved as approximate</div>
        </div>
      </div>

      {/* ③ reveals + ④ check */}
      <div class="td-rc">
        <div class="td-reveal" id={anchors ? "beat-reveal" : undefined}>
          <div class="td-part">③ What it reveals</div>
          <p class="td-reveal-text">{r.reveal.lead}<mark class="td-key">{r.reveal.key}</mark>{r.reveal.tail}</p>
        </div>
        <div class="td-check" id={anchors ? "beat-check" : undefined}>
          <div class="td-part is-green">④ How to check it</div>
          <EvidenceTag kind={r.check.tag}> {r.check.sub}</EvidenceTag>
          <div class="td-link-row">
            {r.check.verifyHref
              ? <a class="td-link td-link--verify" href={r.check.verifyHref}><span aria-hidden="true">↗</span>{r.check.verify}</a>
              : <span class="td-link td-link--verify"><span aria-hidden="true">↗</span>{r.check.verify}</span>}
            {r.check.methodHref
              ? <a class="td-link td-link--method" href={r.check.methodHref}><span aria-hidden="true">›</span>{r.check.method}</a>
              : <span class="td-link td-link--method"><span aria-hidden="true">›</span>{r.check.method}</span>}
          </div>
        </div>
      </div>

      {r.redaction && <RedactionReveal redaction={r.redaction} />}

      {/* ⑤ connects */}
      <div class="td-connects" id={anchors ? "beat-connect" : undefined}>
        <div class="td-part">⑤ Where it connects</div>
        <div class="td-chips">
          {r.connect.map((c) => (
            c.href
              ? <a class="td-chip" href={c.href}><span class="td-chip-kind">{c.kind}</span>{c.label}</a>
              : <span class="td-chip"><span class="td-chip-kind">{c.kind}</span>{c.label}</span>
          ))}
        </div>
      </div>
    </div>
  )}

  {/* ========================= LAYOUT B · SCROLL ============================= */}
  {layout === "scroll" && (
    <div class="td-scroll">
      <div class="td-part">① The source</div>
      <TeardownSourceCard source={r.source} fields={sourceFields} sourceDoc={sourceDoc} size="sm" />

      <div class="td-block td-block--read">
        <div class="td-part is-forest">② What we read from it</div>
        <div class="td-readcards">
          {r.extraction.map((row) => (
            <div class="td-readcard">
              <div class="td-readcard-label">{row.label}</div>
              <div class:list={["td-readcard-value", row.warn && "is-warn", row.live && "is-live"]}>
                {row.live && <span class="td-live-dot" aria-hidden="true" title="Read live from the published record"></span>}{row.value}
              </div>
            </div>
          ))}
        </div>
      </div>

      <div class="td-block td-block--reveal">
        <div class="td-part is-amber">③ What it reveals</div>
        <p class="td-reveal-text td-reveal-text--lg">{r.reveal.lead}<mark class="td-key">{r.reveal.key}</mark>{r.reveal.tail}</p>
      </div>

      <div class="td-block td-block--check">
        <div class="td-part is-green">④ How to check it</div>
        <div class="td-check-inline">
          <EvidenceTag kind={r.check.tag}> {r.check.sub}</EvidenceTag>
          {r.check.verifyHref
            ? <a class="td-link td-link--verify" href={r.check.verifyHref}><span aria-hidden="true">↗</span>{r.check.verify}</a>
            : <span class="td-link td-link--verify"><span aria-hidden="true">↗</span>{r.check.verify}</span>}
          {r.check.methodHref
            ? <a class="td-link td-link--method" href={r.check.methodHref}><span aria-hidden="true">›</span>{r.check.method}</a>
            : <span class="td-link td-link--method"><span aria-hidden="true">›</span>{r.check.method}</span>}
        </div>
      </div>

      {r.redaction && <RedactionReveal redaction={r.redaction} />}

      <div class="td-connects">
        <div class="td-part">⑤ Where it connects</div>
        <div class="td-chips">
          {r.connect.map((c) => (
            c.href
              ? <a class="td-chip" href={c.href}><span class="td-chip-kind">{c.kind}</span>{c.label}</a>
              : <span class="td-chip"><span class="td-chip-kind">{c.kind}</span>{c.label}</span>
          ))}
        </div>
      </div>
    </div>
  )}

  {/* ======================= LAYOUT C · ANNOTATED =========================== */}
  {layout === "annotated" && (
    <div class="td-body">
      <div class="td-annot-grid">
        {/* artifact + pins */}
        <div>
          <div class="td-part">① The source <span class="td-part-flag">· annotated</span></div>
          <TeardownSourceCard
            source={r.source}
            fields={sourceFields}
            sourceDoc={sourceDoc}
            size="lg"
            redactionLabel={r.redactionLabel}
            pins={pins}
          />
        </div>
        {/* margin rail keyed to pins */}
        <div>
          <div class="td-part is-forest">② What we read</div>
          <div class="td-rail">
            {pins.map((p) => (
              <div class="td-rail-item">
                <div class:list={["td-rail-num", p.danger && "is-danger"]}>{p.n}</div>
                <div>
                  <div class="td-rail-label">{p.label}</div>
                  <div class:list={["td-rail-value", p.danger && "is-danger"]}>{p.value}</div>
                </div>
              </div>
            ))}
          </div>
        </div>
      </div>

      {/* footer band: reveal + connect / check */}
      <div class="td-annot-foot">
        <div>
          <div class="td-part">③ What it reveals</div>
          <p class="td-reveal-text">{r.reveal.lead}<mark class="td-key">{r.reveal.key}</mark>{r.reveal.tail}</p>
          <div class="td-chips td-chips--mt">
            {r.connect.map((c) => (
              c.href
                ? <a class="td-chip td-chip--onpanel" href={c.href}><span class="td-chip-kind">{c.kind}</span>{c.label}</a>
                : <span class="td-chip td-chip--onpanel"><span class="td-chip-kind">{c.kind}</span>{c.label}</span>
            ))}
          </div>
        </div>
        <div class="td-annot-check">
          <div class="td-part is-green">④ How to check it</div>
          <EvidenceTag kind={r.check.tag}> {r.check.sub}</EvidenceTag>
          <div class="td-link-row">
            {r.check.verifyHref
              ? <a class="td-link td-link--verify" href={r.check.verifyHref}><span aria-hidden="true">↗</span>{r.check.verify}</a>
              : <span class="td-link td-link--verify"><span aria-hidden="true">↗</span>{r.check.verify}</span>}
            {r.check.methodHref
              ? <a class="td-link td-link--method" href={r.check.methodHref}><span aria-hidden="true">›</span>{r.check.method}</a>
              : <span class="td-link td-link--method"><span aria-hidden="true">›</span>{r.check.method}</span>}
          </div>
        </div>
      </div>

      {r.redaction && <RedactionReveal redaction={r.redaction} />}
    </div>
  )}
</div>
