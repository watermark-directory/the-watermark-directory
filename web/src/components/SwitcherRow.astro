---
/**
 * One row in the grouped network switcher (#307, design "Site Selector"). Extracted so the
 * State and Basin groupings render the same row. Carries the build-phase pill, the facility
 * lifecycle stage, the tracking issue, and (when restricted) a lock — a locked row routes to
 * its request-access page rather than the build.
 */
import {
  FACILITY_STATUS_META,
  type NetworkSite,
  SITE_STATUS_META,
  facilityStatus,
  siteBadge,
} from "../lib/sites";
import { withBase } from "../lib/site";

interface Props {
  site: NetworkSite;
  activeSlug: string | null;
}
const { site: s, activeSlug } = Astro.props;
const isActive = activeSlug !== null && s.slug === activeSlug;
const locked = Boolean(s.locked);
// Locked overrides the build-phase pill (lock is about access, not phase).
const status = locked ? { label: "Locked", cls: "is-locked" } : SITE_STATUS_META[s.status];

// The facility lifecycle stage — a separate clock from the build phase (the dot + short label).
const fac = facilityStatus(s.slug);
const facMeta = FACILITY_STATUS_META[fac];
const FAC_SHORT: Record<string, string> = {
  investigation: "Investigating",
  confirmed: "Confirmed",
  construction: "In construction",
  live: "Operational",
};
---

<a
  class:list={["switcher-row", { "is-active": isActive, "is-soon": !s.selectable, "is-locked": locked }]}
  href={withBase(s.href)}
  aria-current={isActive ? "page" : undefined}
>
  <span class:list={["switcher-badge", { "has-codename": Boolean(s.codename) }]}>{siteBadge(s)}</span>
  <span class="switcher-body">
    <span class="switcher-place">
      {s.codename && <span class="switcher-codename">{s.codename}</span>}
      {
        locked && (
          <svg class="switcher-lock" viewBox="0 0 24 24" width="12" height="12" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" aria-label="locked" role="img">
            <rect x="5" y="11" width="14" height="9" rx="1" />
            <path d="M8 11 V7.5 A4 4 0 0 1 16 7.5 V11" />
          </svg>
        )
      }
      {s.place}
    </span>
    <span class="switcher-basin">{s.basin}</span>
  </span>
  <span class="switcher-meta">
    <span class:list={["switcher-status", status.cls]}>{status.label}</span>
    <span class="switcher-submeta">
      <span class="switcher-facility" style={`color:${facMeta.color}`}>
        <svg viewBox="0 0 24 24" width="11" height="11" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <rect x="4" y="4.5" width="16" height="6.5" rx="1.4"></rect>
          <rect x="4" y="13" width="16" height="6.5" rx="1.4"></rect>
          <line x1="7" y1="7.75" x2="7.2" y2="7.75"></line>
          <line x1="7" y1="16.25" x2="7.2" y2="16.25"></line>
        </svg>
        {FAC_SHORT[fac]}
      </span>
      {s.issue && <span class="switcher-issue">#{s.issue}</span>}
    </span>
  </span>
  <span class="switcher-check" aria-hidden="true">{isActive ? "✓" : ""}</span>
</a>
