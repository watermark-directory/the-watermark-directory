---
// Tiered source-document viewer (epic #274 / D1). Dispatches on the *real* render_class
// (from the file itself, #275), fetching bytes from /api/doc/<rel> (B2). Degrades to a
// download/open affordance offline or when the bytes aren't bound — no console errors.
import { docApiUrl, viewerTier } from "../lib/docView";
import type { DocumentEntry } from "../lib/feeds";
import PdfViewer from "./islands/PdfViewer";

interface Props {
  entry: DocumentEntry;
  /** Constrain the embed height for an inline preview (e.g. the teardown card, #284). */
  compact?: boolean;
}
const { entry, compact = false } = Astro.props;
const url = docApiUrl(entry.rel);
const tier = viewerTier(entry); // unavailable (LFS pointer) → "other" (download-only)

// A byte cap keeps a runaway text file from hanging the page; the raw link is always there.
const TEXT_BYTE_CAP = 512 * 1024;

// `astro dev` doesn't mount functions/, so /api/doc returns 404 and every embed below is
// blank. Built output (preview/prod) is false here and serves bytes via the Function, so
// this notice only ever shows under `npm run dev` — turning the silent blank into a reason.
const devServerNote = import.meta.env.DEV;
---

<div class:list={["docview", compact && "docview--compact"]} data-tier={tier}>
  {
    devServerNote && (
      <p class="docview-note docview-devnote">
        <strong>Dev server:</strong> document bytes come from the <code>/api/doc</code> Pages
        Function, which <code>astro dev</code> doesn’t run — the embed below will be blank. Use{" "}
        <code>wrangler pages dev</code> to serve documents locally (see{" "}
        <code>docs/object-store.md</code>).
      </p>
    )
  }

  {
    tier === "image" && (
      <figure class="docview-figure">
        <img class="docview-img" src={url} alt={entry.name} loading="lazy" />
      </figure>
    )
  }

  {
    tier === "pdf" && (
      <div class="docview-pdf">
        <object class="docview-object" data={url} type="application/pdf">
          <p class="docview-note">Your browser can’t display this PDF inline.</p>
        </object>
        <details class="docview-pdfjs">
          <summary>Open the in-browser reader</summary>
          <PdfViewer client:visible src={url} label={entry.name} />
        </details>
      </div>
    )
  }

  {
    tier === "html" && (
      <iframe
        class="docview-frame"
        src={url}
        title={entry.name}
        sandbox=""
        referrerpolicy="no-referrer"
        loading="lazy"
      />
    )
  }

  {
    tier === "text" && (
      <div class="docview-text" data-doc-src={url} data-byte-cap={TEXT_BYTE_CAP}>
        <pre class="docview-pre">Loading…</pre>
      </div>
    )
  }

  {
    (tier === "office" || tier === "other") && (
      <p class="docview-note">
        {entry.available
          ? "No inline preview for this file type — open it in your own app."
          : "Bytes not pulled locally (Git-LFS pointer) — available on request."}
      </p>
    )
  }

  <p class="docview-actions">
    <a class="docview-link" href={url} download={entry.name}>Download</a>
    <span class="docview-dot">·</span>
    <a class="docview-link" href={url} target="_blank" rel="noopener noreferrer">Open in a new tab</a>
  </p>
</div>

<script>
  // Text tier: fetch the document and fill the <pre>, capped, with a graceful failure
  // (offline / no DOCS bound). One handler covers every DocViewer instance on the page.
  for (const node of document.querySelectorAll<HTMLElement>(".docview-text[data-doc-src]")) {
    const src = node.dataset.docSrc;
    const cap = Number(node.dataset.byteCap ?? "524288");
    const pre = node.querySelector("pre");
    if (!src || !pre) continue;
    fetch(src)
      .then(async (res) => {
        if (!res.ok) throw new Error(String(res.status));
        const text = await res.text();
        pre.textContent =
          text.length > cap ? `${text.slice(0, cap)}\n\n… (truncated — download for the rest)` : text;
      })
      .catch(() => {
        pre.textContent = "Couldn’t load this document here — use Download or Open in a new tab.";
      });
  }
</script>

<style>
  /* Dev-only (see `devServerNote`): a dashed callout so a blank embed reads as expected. */
  .docview-devnote {
    border: 1px dashed var(--bosc-rule, #ccc);
    border-radius: 6px;
    padding: 0.5rem 0.7rem;
    margin-bottom: 0.7rem;
    font-size: 0.8rem;
    line-height: 1.5;
    background: var(--td-tint, #f6f6f4);
  }
  .docview-devnote code {
    font-family: var(--bosc-mono, monospace);
  }
</style>
