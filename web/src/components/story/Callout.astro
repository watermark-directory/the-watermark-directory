---
/**
 * Story · Callout — a provided story-component (#724/#731). The boxed aside the chapters use
 * to pull a key point out of the prose ("The whole story turns on small numbers"). Reuses the
 * existing `.callout` site styles, so it's on-brand by construction (watermark-design).
 *
 * In an MDX chapter body:
 *   <Callout title="The whole story turns on small numbers">
 *     The Ottawa has a design low flow of about **0.2 cfs**…
 *   </Callout>
 *
 * `variant` maps to the existing modifiers: `takeaway` ("What you can read anywhere now"),
 * `open` (an open question / unresolved strand).
 */
interface Props {
  /** The bold lead line; omit for a title-less callout. */
  title?: string;
  variant?: "default" | "takeaway" | "open";
  /** Optional anchor id (e.g. "why") for in-page deep links. */
  id?: string;
}
const { title, variant = "default", id } = Astro.props;
const cls = ["callout", variant === "takeaway" && "walk-takeaway", variant === "open" && "callout--open"];
---

<div class:list={cls} id={id}>
  {title && <p class="callout-title">{title}</p>}
  <slot />
</div>
