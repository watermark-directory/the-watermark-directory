---
import Icon from "./Icon.astro";
import Logo from "./Logo.astro";
import SwitcherRow from "./SwitcherRow.astro";
import SwitcherRowV2 from "./SwitcherRowV2.astro";
import AuthShell from "./islands/AuthShell";
import {
  comingSoonSiteTabs,
  networkTabs,
  platformLinks,
  siteTabs,
  SUBMIT_LINK,
  navItemActive,
  navItemLinks,
  type SectionId,
} from "../lib/nav";
import { withBase } from "../lib/site";
import { currentSiteForPath, groupSites, SITE_STATUS_META, SITES, siteForPath } from "../lib/sites";

interface Props {
  active: SectionId;
}
const { active } = Astro.props;
const searchIndexUrl = withBase("/search-index.json");
const base = import.meta.env.BASE_URL || "/";

// The two-tier chrome (design "Global Chrome"). The active tier is resolved from the
// route: inside a site (`here !== null`) → SITE tabs + the site chip; at the network
// level (the directory + cross-cutting globals) → NETWORK tabs + the "All sites" chip.
// The `Watermark.` wordmark always returns to the network home (the Directory).
const here = siteForPath(Astro.url.pathname, base);
// The switcher's *current* state — and now the tab tier — react to any `/network/<slug>` route,
// including a coming-soon site (where `here`, the *built-site* resolver, is null). On a site page
// the left tabs are site-tier: Lima (built, `here`) gets its real bundle-backed `siteTabs`; a
// coming-soon peer gets a registry-only, mostly-locked bar (`comingSoonSiteTabs`) so the chrome
// matches the chip instead of dropping to the network tabs (#793).
const current = currentSiteForPath(Astro.url.pathname, base);
const tier: "network" | "site" = current ? "site" : "network";
const networkTabsList = networkTabs();
const platformList = platformLinks();
// The site-tier tab set for the current site: a coming-soon peer gets the registry-only locked bar;
// a built site (or the global-default) gets the real bundle-backed tabs. The desktop left tabs use
// it on a site page (network tabs off-network); the mobile sheet's "This site" group always does.
const siteTabsList = current && !here ? comingSoonSiteTabs(current) : siteTabs();
const leftTabs = current ? siteTabsList : networkTabsList;
const networkHome = "/";

// The site chip = the breadcrumb + the switcher trigger. Off the network → "All sites".
const chipPlace = current ? current.place : "All sites";
const chipCodename = current?.codename ?? null;
const herePhase = current ? SITE_STATUS_META[current.status] : null;

// The grouped selector (#307/#308): the same 32-site panel, pivoted by State or Basin
// (default Basin, design "Site Selector"). No-JS — radio inputs + :checked.
const stateGroups = groupSites("state");
const basinGroups = groupSites("basin");
const hereSlug = current?.slug ?? null;
const totalSites = SITES.length;
const stateCount = stateGroups.length;
const basinCount = basinGroups.length;
const lockedCount = SITES.filter((s) => s.locked).length;
const openCount = totalSites - lockedCount;

// Auth chip — only rendered when the PUBLIC_ build vars are set (kill switch mirrors submit/ask).
const cognitoDomain = import.meta.env.PUBLIC_COGNITO_DOMAIN ?? "";
const cognitoClientId = import.meta.env.PUBLIC_COGNITO_CLIENT_ID ?? "";
const authEnabled = Boolean(cognitoDomain && cognitoClientId);

// The platform globals also surfaced in the mobile sheet's "Platform" group. Submit
// rides here on phones (on desktop it's the right-cluster pill); Ask + Search follow.
const platformGlobals: { label: string; href: string; section: SectionId }[] = [
  { label: SUBMIT_LINK.label, href: SUBMIT_LINK.href, section: SUBMIT_LINK.section },
  { label: "Ask the corpus", href: "/ask", section: "ask" },
  { label: "Search", href: "/search", section: "search" },
];
---

<header class:list={["topbar", `tier-${tier}`]}>
  <!-- Brand — the wordmark, always a link home to the network. On phones it collapses to the "w." mark. -->
  <a class="brand" href={withBase(networkHome)} aria-label="Watermark — network home">
    <Logo size={22} class="brand-mark" rounded />
    <span class="brand-word">Watermark<span class="brand-dot">.</span></span>
  </a>
  <span class="brand-sep" aria-hidden="true">/</span>

  <!-- The site chip — the breadcrumb into a site and the switcher trigger (no-JS <details>). -->
  <details class="site-switcher">
    <summary class="site-chip" aria-label={current ? `Current site: ${chipPlace} — switch site` : "All sites — open the site selector"}>
      {
        tier === "network" && (
          <svg class="chip-grid" viewBox="0 0 24 24" width="13" height="13" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <rect x="3.5" y="4.5" width="17" height="6" rx="1" />
            <rect x="3.5" y="13.5" width="17" height="6" rx="1" />
          </svg>
        )
      }
      <span class="chip-place">{chipPlace}</span>
      {chipCodename && <span class="chip-codename">{chipCodename}</span>}
      <span class="chip-caret" aria-hidden="true">▾</span>
    </summary>
    <div class="switcher-menu">
      <input type="radio" name="switcher-groupby" id="gb-basin" class="gb-radio" checked />
      <input type="radio" name="switcher-groupby" id="gb-state" class="gb-radio" />
      <div class="switcher-head">
        <span class="switcher-head-l">
          <span class="switcher-title">Switch site</span>
          <span class="switcher-count"
            >{totalSites} sites · <span class="sw-scope sw-scope-basin">{basinCount} basins</span><span
              class="sw-scope sw-scope-state">{stateCount} states</span
            ></span
          >
        </span>
        <span class="switcher-groupby">
          <span class="gb-k">Group by</span>
          <label for="gb-state" class="gb-btn gb-state">State</label>
          <label for="gb-basin" class="gb-btn gb-basin">Basin</label>
        </span>
      </div>
      <div class="switcher-groups by-state">
        {
          stateGroups.map((g) => (
            <div class="switcher-group">
              <div class="switcher-grouphead">
                {g.tag && <span class="switcher-grouptag">{g.tag}</span>}
                <span class="switcher-grouplabel">{g.label}</span>
                <span class="switcher-groupcount">{g.sites.length}</span>
              </div>
              <div class="switcher-grouprows">
                {g.sites.map((s) => (
                  <SwitcherRow site={s} activeSlug={hereSlug} />
                ))}
              </div>
            </div>
          ))
        }
      </div>
      <div class="switcher-groups by-basin">
        {
          basinGroups.map((g) => (
            <>
              {g.showRegion && (
                <div class="switcher-region">
                  <span class="switcher-region-tag">{g.regionTag}</span>
                  <span class="switcher-region-label">{g.regionLabel}</span>
                  <span class="switcher-region-count">{g.regionCount} sites</span>
                </div>
              )}
              <div class="switcher-group">
                <div class="switcher-grouphead">
                  {g.tag && <span class="switcher-grouptag">{g.tag}</span>}
                  <span class="switcher-grouplabel">{g.label}</span>
                  <span class="switcher-groupcount">{g.sites.length}</span>
                </div>
                <div class="switcher-grouprows">
                  {g.sites.map((s) => (
                    <SwitcherRow site={s} activeSlug={hereSlug} />
                  ))}
                </div>
              </div>
            </>
          ))
        }
      </div>
      <div class="switcher-foot">
        <span class="switcher-foot-note">
          Each site is a section of the Watermark platform — pivoted by <span class="sw-scope sw-scope-basin"
            >basin</span
          ><span class="sw-scope sw-scope-state">state</span>. Live &amp; building sites open; queued and tracking
          sites route to their coming-soon / watch page.
        </span>
        <span class="switcher-legend" aria-hidden="true">
          <span class="leg leg-live">Live</span>
          <span class="leg leg-building">Building</span>
          <span class="leg leg-queued">Queued</span>
          <span class="leg leg-tracking">Tracking</span>
          <span class="leg leg-locked">
            <svg viewBox="0 0 24 24" width="11" height="11" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <rect x="5" y="11" width="14" height="9" rx="1"></rect>
              <path d="M8 11 V7.5 A4 4 0 0 1 16 7.5 V11"></path>
            </svg>Locked
          </span>
        </span>
      </div>
    </div>

    <!-- V2 Site Selector — controlled by localStorage('site-selector-v2'='1'). Both panels
         are rendered; CSS hides the inactive one so no redeploy is needed to flip the flag. -->
    <div class="switcher-menu switcher-menu-v2">
      <input type="radio" name="sw2-groupby" id="gb-v2-basin" class="gb-radio" checked />
      <input type="radio" name="sw2-groupby" id="gb-v2-state" class="gb-radio" />
      <div class="v2-head">
        <div class="v2-head-row1">
          <span class="v2-head-title">Switch site</span>
          <span class="v2-head-count">
            {totalSites} sites · <span class="sw-v2-scope sw-v2-scope-basin">{basinCount} basins</span><span class="sw-v2-scope sw-v2-scope-state">{stateCount} states</span>
          </span>
          <span class="v2-head-stats">
            <span class="v2-head-open">{openCount} open</span>
            {lockedCount > 0 && (
              <span class="v2-head-locked">
                <svg viewBox="0 0 24 24" width="11" height="11" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                  <rect x="5" y="11" width="14" height="9" rx="1"/>
                  <path d="M8 11 V7.5 A4 4 0 0 1 16 7.5 V11"/>
                </svg>
                {lockedCount} restricted
              </span>
            )}
          </span>
          <label class="v2-filter" for="sw-v2-filter">
            <span class="v2-filter-icon" aria-hidden="true">
              <svg viewBox="0 0 24 24" width="14" height="14" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <circle cx="11" cy="11" r="6.5"/>
                <line x1="16" y1="16" x2="21" y2="21"/>
              </svg>
            </span>
            <input type="text" id="sw-v2-filter" placeholder="Filter by place…" autocomplete="off" spellcheck="false" />
          </label>
          <span class="v2-groupby-k">Group by</span>
          <span class="v2-toggle">
            <label for="gb-v2-state" class="gb-btn gb-v2-state">State</label>
            <label for="gb-v2-basin" class="gb-btn gb-v2-basin">Basin</label>
          </span>
        </div>
        <p class="v2-blurb">
          Each <b>site</b> is one Watermark investigation. The <b>page</b> color says what opens; the <b>campus</b> line is the build on the ground — two different clocks.
        </p>
      </div>
      <div class="v2-scroll">
        <div class="v2-groups by-v2-state">
          {
            stateGroups.map((g) => (
              <div class="v2-group">
                <div class="v2-grouphead">
                  {g.tag && <span class="v2-grouptag">{g.tag}</span>}
                  <span class="v2-grouplabel">{g.label}</span>
                  <span class="v2-groupcount">{g.sites.length}</span>
                </div>
                <div class="v2-grouprows">
                  {g.sites.map((s) => (
                    <SwitcherRowV2 site={s} activeSlug={hereSlug} />
                  ))}
                </div>
              </div>
            ))
          }
        </div>
        <div class="v2-groups by-v2-basin">
          {
            basinGroups.map((g) => (
              <>
                {g.showRegion && (
                  <div class="v2-region">
                    <span class="v2-region-tag">{g.regionTag}</span>
                    <span class="v2-region-label">{g.regionLabel}</span>
                    <span class="v2-region-count">{g.regionCount} sites</span>
                  </div>
                )}
                <div class="v2-group">
                  <div class="v2-grouphead">
                    {g.tag && <span class="v2-grouptag">{g.tag}</span>}
                    <span class="v2-grouplabel">{g.label}</span>
                    <span class="v2-groupcount">{g.sites.length}</span>
                  </div>
                  <div class="v2-grouprows">
                    {g.sites.map((s) => (
                      <SwitcherRowV2 site={s} activeSlug={hereSlug} />
                    ))}
                  </div>
                </div>
              </>
            ))
          }
        </div>
      </div>
      <div class="v2-foot">
        <div class="v2-foot-col">
          <span class="v2-foot-label">The page — what opens on Watermark</span>
          <span class="v2-foot-legend">
            <span class="v2-fl-item v2-fl-open">Open · Draft<span class="v2-fl-arrow">→</span><span class="v2-fl-note">full record</span></span>
            <span class="v2-fl-item v2-fl-queued">Queued · Watching<span class="v2-fl-arrow">→</span><span class="v2-fl-note">preview page</span></span>
            <span class="v2-fl-item v2-fl-locked">
              <svg viewBox="0 0 24 24" width="11" height="11" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <rect x="5" y="11" width="14" height="9" rx="1"/>
                <path d="M8 11 V7.5 A4 4 0 0 1 16 7.5 V11"/>
              </svg>
              Restricted<span class="v2-fl-note">request access</span>
            </span>
          </span>
        </div>
        <div class="v2-foot-col">
          <span class="v2-foot-label">The campus — the build on the ground</span>
          <span class="v2-foot-legend">
            <span class="v2-fl-campus v2-fl-inv">Investigating</span>
            <span class="v2-fl-campus v2-fl-confirmed">Confirmed</span>
            <span class="v2-fl-campus v2-fl-construction">Under construction</span>
            <span class="v2-fl-campus v2-fl-operational">Operational</span>
          </span>
        </div>
      </div>
    </div>
  </details>
  {herePhase && <span class:list={["phase-pill", herePhase.cls]} title={`Site build phase: ${herePhase.label}`}>{herePhase.label}</span>}

  <!-- Left tabs — swap by tier (site vs network). About is a no-JS dropdown. -->
  <nav class="sections" id="bosc-sections" aria-label={tier === "site" ? "This site" : "Network"}>
    {
      leftTabs.map((item) => {
        const isActive = navItemActive(item, active);
        if (item.kind === "mega") {
          const m = item.mega;
          return (
            <details class:list={["nav-dd", "nav-mega", { active: isActive }]}>
              <summary class="section-tab nav-dd-summary" aria-current={isActive ? "page" : undefined}>
                {item.label}
                <span class="nav-dd-caret" aria-hidden="true">▾</span>
              </summary>
              <div class="nav-mega-menu">
                <div class="nav-mega-tiles">
                  {m.tiles.map((t) => (
                    <a class="nav-mega-tile" href={withBase(t.href)}>
                      <span class="nav-mega-tile-label">{t.label}</span>
                      <span class="nav-mega-tile-blurb">{t.blurb}</span>
                    </a>
                  ))}
                </div>
                <div class="nav-mega-cols">
                  <div class="nav-mega-spine">
                    <a class:list={["nav-mega-spine-head", { "is-locked": m.spine.locked }]} href={withBase(m.spine.href)}>
                      <span class="nav-mega-spine-title">{m.spine.title}</span>
                      {m.spine.locked ? (
                        <Icon name="locked" size={12} class="nav-mega-lock" />
                      ) : (
                        <span class="nav-mega-spine-count">{m.spine.count}</span>
                      )}
                    </a>
                    <p class="nav-mega-spine-blurb">{m.spine.blurb}</p>
                    {m.spine.items.map((it) => (
                      <a class="nav-mega-link" href={withBase(it.href)}>
                        <span class="nav-mega-num">{it.num}</span>
                        <span class="nav-mega-link-main">
                          <span class="nav-mega-link-label">{it.label}</span>
                          {it.blurb && <span class="nav-mega-link-blurb">{it.blurb}</span>}
                        </span>
                      </a>
                    ))}
                    <a class="nav-mega-toc" href={withBase(m.spine.tocHref)}>Open the table of contents →</a>
                  </div>
                  <div class="nav-mega-themes">
                    <div class="nav-mega-themes-head">Themes it crosses</div>
                    <div class="nav-mega-themes-grid">
                      {m.themes.map((th) => (
                        <div class="nav-mega-theme">
                          <a class:list={["nav-mega-theme-title", { "is-locked": th.locked }]} href={withBase(th.href)}>
                            {th.title}
                            {th.locked && <Icon name="locked" size={11} class="nav-mega-lock" />}
                          </a>
                          {th.items.map((it) => (
                            <a class:list={["nav-mega-tlink", { "is-locked": it.locked }]} href={withBase(it.href)}>
                              {it.label}
                              {it.locked && <Icon name="locked" size={10} class="nav-mega-lock" />}
                            </a>
                          ))}
                        </div>
                      ))}
                    </div>
                  </div>
                </div>
              </div>
            </details>
          );
        }
        if (item.kind === "dropdown") {
          return (
            <details class:list={["nav-dd", { active: isActive }]}>
              <summary class="section-tab nav-dd-summary" aria-current={isActive ? "page" : undefined}>
                {item.label}
                <span class="nav-dd-caret" aria-hidden="true">▾</span>
              </summary>
              <div class="nav-dd-menu">
                {item.children.map((child) =>
                  "divider" in child ? (
                    <hr class="nav-dd-hr" />
                  ) : (
                    <a class="nav-dd-item" href={withBase(child.href)}>
                      <span class="nav-dd-item-label">{child.label}</span>
                      {child.blurb && <span class="nav-dd-item-blurb">{child.blurb}</span>}
                    </a>
                  ),
                )}
              </div>
            </details>
          );
        }
        if (item.locked) {
          // A coming-soon site's not-yet-built section (#793): a non-navigable marker, not a link
          // (the page doesn't exist) — the watch page itself lists what will land there.
          return (
            <span class="section-tab is-locked" aria-disabled="true" title={`${item.label} — coming soon`}>
              {item.label}
              <Icon name="locked" size={11} class="section-tab-lock" />
            </span>
          );
        }
        return (
          <a
            class:list={["section-tab", { active: isActive }]}
            href={withBase(item.href)}
            aria-current={isActive ? "page" : undefined}
          >
            {item.label}
          </a>
        );
      })
    }
  </nav>

  <!-- Mobile sheet (#400): This site / Network / Platform, toggled by the burger checkbox. -->
  <nav class="nav-sheet" id="bosc-nav-sheet" aria-label="Site menu">
    <div class="sheet-group">
      <div class="sheet-grouphead">This site · {current ? current.place : "Lima"}</div>
      {
        siteTabsList.map((item) =>
          item.kind === "link" ? (
            <a
              class:list={["sheet-link", { active: navItemActive(item, active) }]}
              href={withBase(item.href)}
              aria-current={navItemActive(item, active) ? "page" : undefined}
            >
              {item.label}
            </a>
          ) : item.kind === "mega" ? (
            navItemLinks(item).map((l) => (
              <a class="sheet-link" href={withBase(l.href)}>
                {l.label}
              </a>
            ))
          ) : (
            <>
              <div class="sheet-sublabel">{item.label}</div>
              {item.children.map((child) =>
                "divider" in child ? null : (
                  <a class="sheet-link sheet-link--sub" href={withBase(child.href)}>
                    {child.label}
                  </a>
                ),
              )}
            </>
          ),
        )
      }
    </div>
    <div class="sheet-group">
      <div class="sheet-grouphead">Network</div>
      {
        networkTabsList.map((item) =>
          item.kind === "link" ? (
            <a
              class:list={["sheet-link", { active: navItemActive(item, active) }]}
              href={withBase(item.href)}
              aria-current={navItemActive(item, active) ? "page" : undefined}
            >
              {item.label}
            </a>
          ) : item.kind === "dropdown" ? (
            <>
              <div class="sheet-sublabel">{item.label}</div>
              {item.children.map((child) =>
                "divider" in child ? null : (
                  <a class="sheet-link sheet-link--sub" href={withBase(child.href)}>
                    {child.label}
                  </a>
                ),
              )}
            </>
          ) : null,
        )
      }
    </div>
    <div class="sheet-group">
      <div class="sheet-grouphead">Platform</div>
      <div class="sheet-platform">
        {
          platformList.map((item) => (
            <a
              class:list={["sheet-plink", { active: active === item.section }]}
              href={withBase(item.href)}
              aria-current={active === item.section ? "page" : undefined}
            >
              {item.label}
            </a>
          ))
        }
        {
          platformGlobals.map((g) => (
            <a
              class:list={["sheet-plink", { active: active === g.section }]}
              href={withBase(g.href)}
              aria-current={active === g.section ? "page" : undefined}
            >
              {g.label === "Ask the corpus" ? "Ask" : g.label}
            </a>
          ))
        }
      </div>
    </div>
  </nav>

  <!-- Platform cluster (right) — Docs · Wiki · | · Submit · Ask · Search. Constant across tiers. -->
  <div class="topbar-right">
    <span class="platform-links">
      {
        platformList.map((item) => (
          <a
            class:list={["platform-link", { active: active === item.section }]}
            href={withBase(item.href)}
            aria-current={active === item.section ? "page" : undefined}
          >
            {item.label}
          </a>
        ))
      }
    </span>
    <span class="topbar-div" aria-hidden="true"></span>
    <a
      class:list={["topbar-submit", { active: active === SUBMIT_LINK.section }]}
      href={withBase(SUBMIT_LINK.href)}
      aria-current={active === SUBMIT_LINK.section ? "page" : undefined}
    >
      <svg viewBox="0 0 24 24" width="14" height="14" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        <line x1="12" y1="5" x2="12" y2="19"></line>
        <line x1="5" y1="12" x2="19" y2="12"></line>
      </svg>
      <span class="topbar-submit-label">Submit</span>
    </a>
    <a
      class:list={["topbar-ask", { active: active === "ask" }]}
      href={withBase("/ask")}
      aria-current={active === "ask" ? "page" : undefined}
    >
      <Icon name="ask" size={15} /> <span class="topbar-ask-label">Ask</span>
    </a>
    {
      authEnabled && (
        <AuthShell
          cognitoDomain={cognitoDomain}
          clientId={cognitoClientId}
          loginHref={withBase("/account/login")}
          logoutHref={withBase("/account/logout")}
          client:idle
        />
      )
    }
    <div class="search">
      <Icon name="search" size={15} class="search-icon" />
      <input
        type="search"
        id="bosc-search"
        placeholder="Search…"
        autocomplete="off"
        aria-label="Search the corpus"
        spellcheck="false"
        data-index={searchIndexUrl}
        data-base={base}
      />
      <kbd class="search-kbd" aria-hidden="true">⌘K</kbd>
      <div id="bosc-search-results" class="search-results" hidden></div>
    </div>
    <label for="bosc-nav-toggle" class="nav-burger" aria-label="Toggle navigation"><Icon name="menu" size={22} /></label>
  </div>
</header>

<script is:inline>
  // Runtime flag: localStorage.setItem('site-selector-v2','1') + reload to enable v2.
  // localStorage.removeItem('site-selector-v2') + reload to revert.
  (function () {
    if (localStorage.getItem("site-selector-v2") === "1") {
      document.documentElement.setAttribute("data-ssv2", "");
    }
  })();

  // V2 place filter — filters .switcher-row-v2 elements by place name.
  var filterInput = document.getElementById("sw-v2-filter");
  if (filterInput) {
    filterInput.addEventListener("input", function () {
      var q = filterInput.value.toLowerCase().trim();
      document.querySelectorAll(".switcher-row-v2").forEach(function (row) {
        var place = row.querySelector(".v2-placename");
        var text = place ? place.textContent.toLowerCase() : "";
        row.hidden = q !== "" && !text.includes(q);
      });
    });
  }
</script>
