---
import { selectableSitePaths } from "../../../../lib/sites";
export const getStaticPaths = selectableSitePaths;
/**
 * End-use & workloads — the interactive companion to the full report
 * (docs/end-use-and-workloads.md, #251). Reuses the walk's island-over-SSR pattern:
 * the taxonomy explorer (EndUseExplorer) lets the reader see that "data center"
 * names four businesses that answer "who can use it" differently — and that the
 * Lima record leaves the answer [open]. Pays off into the full cited essay.
 */
import ReportShell from "../../../../layouts/ReportShell.astro";
import EndUseExplorer from "../../../../components/islands/EndUseExplorer.tsx";
import { buildEndUse } from "../../../../lib/endUse";

const endUse = buildEndUse();
const limaLabel = (s: string): string => (s === "ruled-out" ? "ruled out" : "[open]");
---

<ReportShell
  title="End use & workloads"
  description="The customer is known (Google); the use is not. Explore the four things called 'data center' — and the open question of who can use the Lima campus."
  eyebrow="Extension narrative · #233 · the workloads it will run"
  h1="What the facility is for"
  fullReportHref="/docs/end-use-and-workloads"
>
  <Fragment slot="lead">
      <p class="section-lead">
        The customer question is settled — the developer is <strong>Google</strong>
        (<code>[verified]</code>). This works one layer downstream: not <em>who builds it</em>,
        but <em>what it is for, and who can use it</em>. The industry told an Ohio committee,
        in its own words, that “data center” names four very different businesses — and they
        answer the public's two plain questions, <em>who benefits</em> and <em>who can use it</em>,
        in completely different ways.
      </p>
  </Fragment>

    <section class="walk-interactive" aria-label="The four things called a data center">
      <h2 class="walk-explore-h">Pick a type — read who can use it</h2>
      <div class="eu-surface">
        <EndUseExplorer client:only="react" data={endUse} site={Astro.locals.site} />
        <noscript>
          <div class="dil-noscript">
            The explorer needs JavaScript — the same content is in the full table below.
          </div>
        </noscript>
      </div>

      {/*
        The plain-text fallback. Open by default so no-JS readers (who get no explorer)
        have the content immediately; the inline script below collapses it when JS is
        present, so it doesn't sit beside the explorer looking like a second control.
      */}
      <details open class="eu-fallback" id="eu-fallback">
        <summary class="eu-fallback-summary">The full table — every type, in plain text</summary>
        <table class="dtable eu-table">
          <caption>
            The four businesses called “data center,” and what the Lima record establishes about each.
            The developer is Google (<code>[verified]</code>); which model the campus is stays
            <code>[open]</code>.
          </caption>
          <thead>
            <tr>
              <th scope="col">Type</th>
              <th scope="col">Who owns the compute</th>
              <th scope="col">Who can use it</th>
              <th scope="col">Lima</th>
            </tr>
          </thead>
          <tbody>
            {
              endUse.types.map((t) => (
                <tr>
                  <td>
                    <strong>{t.label}</strong>
                    <span class="eu-td-tag">{t.tagline}</span>
                  </td>
                  <td>{t.ownsCompute}</td>
                  <td>{t.whoCanUse}</td>
                  <td>{limaLabel(t.limaStatus)}</td>
                </tr>
              ))
            }
          </tbody>
        </table>
      </details>
      <script is:inline>
        document.getElementById("eu-fallback")?.removeAttribute("open");
      </script>
    </section>

    <div class="callout callout--open">
      <p class="callout-title">Where this lands</p>
      <p>
        Confirming the customer did not resolve the use. The record establishes the taxonomy and
        the federal-enclave structure above it — but not <strong>which one the Lima campus is</strong>,
        and not <strong>who can use it</strong>. Two of its silences are pointed: Google's own
        legislative testimony omits Lima, and the records request for County ⇄ DoD / GDLS
        communications returned “no records.” An absence is not a finding — it is the continued
        absence of an answer.
      </p>
    </div>

    <Fragment slot="full-report">
      the hyperscale-vs-colocation split, the “cannot say” abatement opacity, the FedRAMP /
      DoD impact-level ladder, and why the answer changes the public-benefit math
    </Fragment>
</ReportShell>
