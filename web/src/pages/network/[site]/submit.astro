---
import Base from "../../../layouts/Base.astro";
import SubmitForm from "../../../components/SubmitForm.astro";
import { selectableSitePaths } from "../../../lib/sites";

// One `network/[site]/…` route per selectable site (#724/#734); Lima alone today.
export const getStaticPaths = selectableSitePaths;

// The site-tier submission route. The per-record "✎ Suggest a correction" deep-links
// from inside Lima (records, people, places, the walk) target this so the correction
// flow keeps Lima's chrome; `?ref_kind=…` query params surface the record being
// corrected (submitRef.ts). The form body itself is shared with the network-tier
// /submit route via <SubmitForm>. `section="home"` keeps the site-tier "The site" tab.
---

<Base title="Submit a tip or correction" section="home">
  <SubmitForm />
</Base>
