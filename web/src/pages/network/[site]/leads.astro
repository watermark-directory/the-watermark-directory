---
/**
 * Open leads (design "Site Leads") — every gap we're chasing on a site, in the open. Sits in the
 * "The site" dropdown. The board reads the site's own `leads` bundle feed (#796), where every lead
 * traces to a real committed source (the corpus-completeness audit / a working hypothesis); the
 * comp's fabricated contributor avatars + "updated 2h ago" timestamps are deliberately dropped.
 *
 * A site with no `leads` feed (a thinner peer with no curated leads yet) falls back to the
 * readiness-derived needs board (<SiteNeeds>, #781) — its honest "what we're seeking", never
 * another site's leads.
 *
 * No-JS: filtering is radio inputs + `:checked` sibling CSS (the same pattern as the site
 * switcher); pagination is omitted. Reads with JS off.
 */
import Base from "../../../layouts/Base.astro";
import Icon from "../../../components/Icon.astro";
import SiteNeeds from "../../../components/SiteNeeds.astro";
import { hasFeed, loadFeed } from "../../../lib/bundle";
import {
  KIND_META,
  LEAD_FILTERS,
  LEAD_LIFECYCLE,
  type Lead,
  RECENTLY_CLOSED,
  STATUS_META,
  leadCount,
  leadStats,
} from "../../../lib/leads";
import { isReferenceSite, lockedSections } from "../../../lib/readiness";
import { withSite } from "../../../lib/site";
import { activeSite, selectableSitePaths, siteForSlug, siteState } from "../../../lib/sites";

// One `network/[site]/…` route per selectable site (#724/#734); Lima alone today.
export const getStaticPaths = selectableSitePaths;

// The active site (route prop) drives the dateline + title — not a hardcoded "Lima" (#741).
const { slug } = Astro.props as { slug: string };
const site = siteForSlug(slug) ?? activeSite();
const dateline = `${site.place}, ${siteState(slug)}`;

// The board is feed-driven (#796): a site renders its own `leads`; a site with none falls back to
// the readiness needs board (<SiteNeeds>, #781). Recently-closed is the reference build's curated
// presentation rail (no per-site closed-leads feed yet), so it's reference-only.
const hasLeads = hasFeed("leads");
const leads = hasLeads ? loadFeed<Lead[]>("leads") : [];
const closedCount = isReferenceSite(slug) ? RECENTLY_CLOSED.length : 0;
const needsCount = lockedSections(slug).length;

const stats = leadStats(leads, closedCount);
const submitHref = withSite("/submit");
const recordHref = withSite("/site/");
const ghIssue = (n: number): string => `https://github.com/goedelsoup/bosc/issues/${n}`;
---

<Base
  title={`Open leads — ${site.place}`}
  section="leads"
  rail={false}
  description={`Every gap we're chasing on the ${site.place} site, in the open — each lead unverified until a source corroborates it.`}
>
  {!hasLeads ? (
    <div class="leads">
      <header class="leads-head">
        <a class="leads-back" href={withSite()}>← Back to the site</a>
        <div class="leads-head-row">
          <div class="leads-head-main">
            <div class="leads-kicker">Open investigation · {dateline}</div>
            <h1>Open leads</h1>
            <p class="leads-lead">
              This is an early build of the {site.place} record — there's no curated leads board
              yet. What it needs most are the <strong>sources behind the sections still locked</strong>
              below. We don't fill them with another site's record; bring a document and it opens
              that section.
            </p>
          </div>
          <a class="leads-submit" href={submitHref}>
            <svg viewBox="0 0 24 24" width="14" height="14" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><line x1="12" y1="5" x2="12" y2="19"></line><line x1="5" y1="12" x2="19" y2="12"></line></svg>
            Submit a lead
          </a>
        </div>
      </header>

      <div class="leads-layout">
        <div class="leads-main">
          <div class="leads-count">
            <span class="leads-count-l">{needsCount} {needsCount === 1 ? "section needs" : "sections need"} sources</span>
            <span class="leads-count-rule" aria-hidden="true"></span>
          </div>
          <SiteNeeds slug={slug} />
          <p class="leads-listfoot">
            As each section is sourced it opens into <a href={recordHref}>the record →</a>
          </p>
        </div>

        <aside class="leads-rail" aria-label="How leads work">
          <div class="leads-cta">
            <div class="leads-cta-kicker">Build the record</div>
            <div class="leads-cta-h">Know something we don't?</div>
            <p class="leads-cta-p">
              A document, a name, a correction. We log every submission as a lead — not a verdict — and review
              before the record changes.
            </p>
            <a class="leads-cta-btn" href={submitHref}>Submit a lead →</a>
          </div>

          <div class="leads-lifecycle">
            <div class="leads-rail-kicker">How a lead closes</div>
            <ol class="leads-lc-list">
              {LEAD_LIFECYCLE.map((p) => (
                <li class="leads-lc-step">
                  <span class="leads-lc-num">{p.num}</span>
                  <span class="leads-lc-main">
                    <span class="leads-lc-title">{p.title}</span>
                    <span class="leads-lc-desc">{p.desc}</span>
                  </span>
                </li>
              ))}
            </ol>
          </div>
        </aside>
      </div>
    </div>
  ) : (
  <div class="leads">
    <header class="leads-head">
      <a class="leads-back" href={withSite()}>← Back to the site</a>
      <div class="leads-head-row">
        <div class="leads-head-main">
          <div class="leads-kicker">Open investigation · {dateline}</div>
          <h1>Open leads</h1>
          <p class="leads-lead">
            Every gap we're chasing on this site, in the open. Each lead is <strong>unverified inference</strong>
            until a source corroborates it — and every one traces to the
            <a href={withSite("/docs/dossier")}>corpus-completeness audit</a> or a working hypothesis.
            Pick one up, answer it, or bring the document that closes it.
          </p>
        </div>
        <a class="leads-submit" href={submitHref}>
          <svg viewBox="0 0 24 24" width="14" height="14" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><line x1="12" y1="5" x2="12" y2="19"></line><line x1="5" y1="12" x2="19" y2="12"></line></svg>
          Submit a lead
        </a>
      </div>
    </header>

    <div class="leads-stats">
      {
        stats.map((s) => (
          <div class="leads-stat">
            <div class:list={["leads-stat-n", `is-${s.mod}`]}>{s.n}</div>
            <div class="leads-stat-l">{s.label}</div>
          </div>
        ))
      }
    </div>

    <div class="leads-layout">
      <div class="leads-main">
        {/* No-JS filter state — radios precede the toolbar + list so `:checked ~` reaches them. */}
        {LEAD_FILTERS.map((f, i) => (
          <input type="radio" name="lead-filter" id={`lf-${f.key}`} class="leads-filter-radio" checked={i === 0} />
        ))}

        <div class="leads-toolbar" role="tablist" aria-label="Filter leads by kind">
          {
            LEAD_FILTERS.map((f) => (
              <label class:list={["leads-filter", `lf-${f.key}`]} for={`lf-${f.key}`}>
                {f.label}
                <span class="leads-filter-n">{leadCount(leads, f.key)}</span>
              </label>
            ))
          }
        </div>

        <div class="leads-count">
          <span class="leads-count-l">{leads.length} open leads · unverified</span>
          <span class="leads-count-rule" aria-hidden="true"></span>
        </div>

        <div class="lead-list">
          {
            leads.map((l) => {
              const k = KIND_META[l.kind];
              const s = STATUS_META[l.status];
              return (
                <article class:list={["lead", `lead--${k.mod}`, `lead-${l.kind}`]}>
                  <div class="lead-body">
                    <div class="lead-meta">
                      <span class="lead-kind">{k.label}</span>
                      <span class:list={["lead-chip", `is-${s.mod}`]}>
                        <span class="lead-chip-dot" aria-hidden="true"></span>
                        {s.label}
                      </span>
                      <span class:list={["lead-tag", `is-${l.tag}`]}>[{l.tag}]</span>
                      <span class="lead-source">{l.source}</span>
                    </div>
                    <h2 class="lead-title">{l.title}</h2>
                    <p class="lead-detail">{l.detail}</p>
                    <div class="lead-foot">
                      {l.note && <span class="lead-note">{l.note}</span>}
                      {l.issue && (
                        <a class="lead-gh" href={ghIssue(l.issue)} rel="noopener noreferrer" title="Linked tracking issue">
                          <Icon name="repo" size={11} /> #{l.issue}
                        </a>
                      )}
                    </div>
                  </div>
                  <div class="lead-action">
                    <a class="lead-act-btn" href={submitHref}>{k.action} →</a>
                    <span class="lead-id">{l.id}</span>
                  </div>
                </article>
              );
            })
          }
        </div>

        <p class="leads-listfoot">
          Showing all {leads.length} open leads. Closed leads move into <a href={recordHref}>the record →</a>
        </p>
      </div>

      <aside class="leads-rail" aria-label="How leads work">
        <div class="leads-cta">
          <div class="leads-cta-kicker">Build the record</div>
          <div class="leads-cta-h">Know something we don't?</div>
          <p class="leads-cta-p">
            A document, a name, a correction. We log every submission as a lead — not a verdict — and review
            before the record changes.
          </p>
          <a class="leads-cta-btn" href={submitHref}>Submit a lead →</a>
        </div>

        <div class="leads-lifecycle">
          <div class="leads-rail-kicker">How a lead closes</div>
          <ol class="leads-lc-list">
            {
              LEAD_LIFECYCLE.map((p) => (
                <li class="leads-lc-step">
                  <span class="leads-lc-num">{p.num}</span>
                  <span class="leads-lc-main">
                    <span class="leads-lc-title">{p.title}</span>
                    <span class="leads-lc-desc">{p.desc}</span>
                  </span>
                </li>
              ))
            }
          </ol>
        </div>

        {isReferenceSite(slug) ? (
          <div class="leads-closed">
            <div class="leads-closed-head">
              <span class="leads-rail-kicker leads-rail-kicker--forest">Recently closed</span>
              <span class="leads-closed-tag"><span class="leads-closed-dot" aria-hidden="true"></span>sourced</span>
            </div>
            <ul class="leads-closed-list">
              {RECENTLY_CLOSED.map((c) => (
                <li class="leads-closed-item">
                  <span class="leads-closed-check" aria-hidden="true">
                    <svg viewBox="0 0 24 24" width="9" height="9" fill="none" stroke="currentColor" stroke-width="3.4" stroke-linecap="round" stroke-linejoin="round"><path d="M5 13 L10 18 L19 7"></path></svg>
                  </span>
                  <span class="leads-closed-main">
                    <span class="leads-closed-title">{c.title}</span>
                    <span class="leads-closed-meta">{c.meta}</span>
                  </span>
                </li>
              ))}
            </ul>
          </div>
        ) : null}
      </aside>
    </div>
  </div>
  )}
</Base>
