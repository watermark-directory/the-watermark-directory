---
import { selectableSitePaths } from "../../../../../lib/sites";
export const getStaticPaths = selectableSitePaths;
/**
 * How to read any record (#697) — the reader-facing home for the cross-record
 * "evidence grammar" teaching device. The design comp's `RecordScreen` carried a
 * flag-gated Cost · Air · NPDES switcher as a *comp-only* affordance (one screen,
 * many record types) with no live counterpart; this page is that counterpart, built
 * for real: the same five-beat teardown grammar shown across three genuinely
 * different record types — all bound to the live bundle, none fabricated. Resolves
 * the parity gap the right way (cf. #643 evidence-vocab; closes #697).
 *
 * The switcher is a no-JS radio + CSS pattern (mirrors `.rec-flow` on the record
 * screen): all three teardowns are SSR'd; the CSS shows the selected one. Fully
 * readable with JS off — every panel is in the DOM.
 */
import BackLink from "../../../../../components/BackLink.astro";
import EvidenceLegend from "../../../../../components/EvidenceLegend.astro";
import RecordTeardown from "../../../../../components/RecordTeardown.astro";
import Base from "../../../../../layouts/Base.astro";
import { AIR_TEARDOWN, NPDES_TEARDOWN, OPC_TEARDOWN } from "../../../../../lib/teardowns";
import { withSite } from "../../../../../lib/site";
---

<Base
  title="How to read any record"
  section="site"
  rail={false}
  description="The evidence grammar behind every record on the site — source, read, reveal, check, connect — shown across a cost estimate, an air permit, and an NPDES water screen, all read from the published record."
>
  <div class="hub">
    <BackLink href={withSite("/site/records/")} label="Records" />
    <div class="hub-head">
      <div>
        <div class="hub-eyebrow">The record · how to read it</div>
        <h1>How to read any record</h1>
        <p class="hub-lead">
          Every record on this site — a contractor's cost estimate, an air permit, a
          water-discharge screen — is read the same five ways. Learn the grammar once and
          you can check any figure on the site yourself. Nothing below is summarized for
          you: each is a real record, read from the published bundle, with its evidence
          class on every line.
        </p>
      </div>
    </div>

    <h2 class="hub-subhead" id="grammar">The five beats</h2>
    <p class="hub-lead">
      One transformation — <strong>source → structured read → meaning → verify → connect</strong> —
      applied to whatever the record happens to be:
    </p>
    <div class="td-parts-list">
      <div><b>①</b> The source — the artifact and its provenance, messiness left visible</div>
      <div><b>②</b> What we read — the structured extraction, each value's confidence shown</div>
      <div><b>③</b> What it reveals — plain meaning, with the one load-bearing number called out</div>
      <div><b>④</b> How to check it — the evidence tag and a link to verify it at the source</div>
      <div><b>⑤</b> Where it connects — doors into the rest of the library</div>
    </div>

    <h2 class="hub-subhead" id="evidence">The evidence classes</h2>
    <p class="hub-lead">
      Beat ④ hangs on one vocabulary. Every figure carries its evidence class — read it as a
      confidence signal, not decoration:
    </p>
    <EvidenceLegend />

    <h2 class="hub-subhead" id="across">One grammar, three record types</h2>
    <p class="hub-lead">
      Switch between three genuinely different records below. The artifact changes; the five
      beats don't. Each is a real extraction — the <span class="approx">●</span>
      <em>in the published bundle</em> badge marks the ones whose figures are read live from the
      same row the library renders.
    </p>

    <div class="htr-flow">
      <input class="htr-radio" type="radio" id="htr-cost" name="htr-rec" checked />
      <input class="htr-radio" type="radio" id="htr-air" name="htr-rec" />
      <input class="htr-radio" type="radio" id="htr-npdes" name="htr-rec" />
      <div class="htr-head">
        <div class="htr-seg" role="group" aria-label="Record type">
          <span class="htr-seg-lead">Record type</span>
          <label for="htr-cost">Cost estimate</label>
          <label for="htr-air">Air permit</label>
          <label for="htr-npdes">NPDES · water</label>
        </div>
      </div>
      <div class="htr-panel htr-panel--cost">
        <RecordTeardown record={OPC_TEARDOWN} layout="split" />
      </div>
      <div class="htr-panel htr-panel--air">
        <RecordTeardown record={AIR_TEARDOWN} layout="split" />
      </div>
      <div class="htr-panel htr-panel--npdes">
        <RecordTeardown record={NPDES_TEARDOWN} layout="split" />
      </div>
    </div>

    <p class="hub-lead">
      A dollar total, a redacted emissions table, a low-flow water screen — three filings, one
      reading. Open the <a href={withSite("/site/records/")}>full record library</a> to read any
      of them the same way, or each teardown's verify link to land on the exact source.
    </p>
  </div>
</Base>
