---
import { selectableSitePaths } from "../../../../../lib/sites";
export const getStaticPaths = selectableSitePaths;
import Base from "../../../../../layouts/Base.astro";
import { hasFeed, loadFeed } from "../../../../../lib/bundle";
import type { PersonItem } from "../../../../../lib/feeds";
import { withSite } from "../../../../../lib/site";

const people = hasFeed("people") ? loadFeed<PersonItem[]>("people") : [];
---

<Base title="People" section="site" rail={false}>
  <div class="hub">
    <div class="hub-head">
      <div>
        <div class="hub-eyebrow">The record · people</div>
        <h1>People</h1>
        <p class="hub-lead">
          Curated individual profiles — the people behind the entity graph.
          For sites and parcels, see <a href={withSite("/site/places/")}>Places &amp; parcels</a>.
        </p>
      </div>
      <span class="hub-count">{people.length} people</span>
    </div>

    <div class="hub-grid">
      {
        people.map((p) => (
          <a class="hub-door" href={`${withSite("/site/people/")}${p.slug}/`}>
            <div class="hub-door-top">
              <span class="hub-door-kind">Person</span>
            </div>
            <div class="hub-door-title">{p.name}</div>
            {(p.roles.length > 0 || p.affiliations.length > 0) && (
              <div class="hub-door-desc">{p.roles.slice(0, 2).join(" · ") || p.affiliations[0]}</div>
            )}
            <div class="hub-door-foot">
              <span class="hub-door-browse">Open profile</span>
              <span class="hub-door-arrow" aria-hidden="true">›</span>
            </div>
          </a>
        ))
      }
    </div>
  </div>
</Base>
