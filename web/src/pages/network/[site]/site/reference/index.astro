---
import { selectableSitePaths } from "../../../../../lib/sites";
export const getStaticPaths = selectableSitePaths;
import { getCollection } from "astro:content";
import Base from "../../../../../layouts/Base.astro";
import { refBySlug, REFERENCE } from "../../../../../lib/reference";
import { withSite } from "../../../../../lib/site";

// Only list datasets whose README is actually present in this checkout.
const present = new Set((await getCollection("reference")).map((e) => e.id));
const datasets = REFERENCE.filter((d) => present.has(d.slug) && refBySlug.has(d.slug));
---

<Base title="Reference data" section="site" rail={false}>
  <div class="hub">
    <div class="hub-head">
      <div>
        <div class="hub-eyebrow">The record · reference</div>
        <h1>Reference data</h1>
        <p class="hub-lead">
          The authoritative datasets from <strong>outside</strong> sources that the analysis
          draws on — EPA, USGS, BLS/Census, county and city GIS, GLEIF. Each is committed,
          regenerable from its source, and documented here with its provenance and known gaps.
        </p>
      </div>
      <span class="hub-count">{datasets.length} datasets</span>
    </div>
    <div class="hub-grid">
      {
        datasets.map((d) => (
          <a class="hub-door" href={`${withSite("/site/reference/")}${d.slug}`}>
            <div class="hub-door-top">
              <span class="hub-door-kind">Dataset</span>
            </div>
            <div class="hub-door-title">{d.title}</div>
            <div class="hub-door-desc">{d.blurb}</div>
            <div class="hub-door-foot">
              <span class="hub-door-browse">Open</span>
              <span class="hub-door-arrow" aria-hidden="true">›</span>
            </div>
          </a>
        ))
      }
    </div>
  </div>
</Base>
