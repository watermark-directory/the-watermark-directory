---
import { withSitePaths } from "~/lib/sites";
// One deep-linkable page per source document (epic #274 / D2) — good for citations.
// Resolves the doc from the documents feed and renders the tiered <DocViewer>.
import DocViewer from "~/components/DocViewer.astro";
import Base from "~/layouts/Base.astro";
import { hasFeed, loadFeed } from "~/lib/bundle";
import { docAccess } from "~/lib/docView";
import { type DocumentCollectionItem, type DocumentEntry, formatBytes } from "~/lib/feeds";
import { withSite } from "~/lib/site";

export function getStaticPaths() {
  return withSitePaths(() => {
    const collections = hasFeed("documents") ? loadFeed<DocumentCollectionItem[]>("documents") : [];
    return collections.flatMap((c) =>
      c.entries.map((entry) => ({
        params: { rel: entry.rel },
        props: { entry, collectionTitle: c.title, collectionSlug: c.slug },
      })),
    );
  });
}

const { entry, collectionTitle, collectionSlug } = Astro.props as {
  entry: DocumentEntry;
  collectionTitle: string;
  collectionSlug: string;
};
const access = docAccess(entry);
const accessChip = {
  published: { cls: "dchip--present", label: "● published" },
  "dev-only": { cls: "dchip--devonly", label: "dev-only" },
  absent: { cls: "dchip--lfs", label: "LFS pointer" },
}[access];
---

<Base title={entry.name} section="site">
  <article class="docpage">
    <p class="rec-crumb">
      <a href={withSite("/site/documents/")}>Documents</a>
      <span aria-hidden="true">→</span>
      <a href={`${withSite("/site/documents/")}#doc-${collectionSlug}`}>{collectionTitle}</a>
      <span aria-hidden="true">→</span>
      <span class="rec-crumb-here">{entry.name}</span>
    </p>

    <h1 class="docpage-title">{entry.name}</h1>

    <p class="docpage-meta">
      <span class="dchip dchip--type">{entry.render_class}</span>
      <span class={`dchip ${accessChip.cls}`}>{accessChip.label}</span>
      <span class="docpage-dim">{entry.media_type}</span>
      <span class="docpage-dim">{formatBytes(entry.size_bytes)}</span>
    </p>

    {
      access === "dev-only" && (
        <p class="docpage-gatenote">
          Not on the public allowlist — viewable in dev/preview; the public site serves it
          only after a redaction review (#280/#281).
        </p>
      )
    }

    <DocViewer entry={entry} />

    <p class="docpage-prov">
      Source of record: <code>data/documents/{entry.rel}</code> — immutable
      chain-of-custody evidence, served verbatim.
    </p>
  </article>
</Base>
