---
import { selectableSitePaths } from "~/lib/sites";
// Lima-only showcase: the teardown data (OPC_TEARDOWN, RDA_TEARDOWN) is Lima-specific.
export const getStaticPaths = () => selectableSitePaths().filter((p) => p.props.slug === "lima");
/**
 * Record Teardown — component preview (ported from the design handoff's
 * "Record Teardown — Showcase" board). Mounts the one component in all three
 * layouts plus the 2-up pairing, on the Tetra Tech OPC and the RDA. This is the
 * handoff surface for the guided walk's signature teaching pattern; the chapter
 * pages (Epic: guided walk) will embed `<RecordTeardown>` the same way.
 */
import Base from "~/layouts/Base.astro";
import BackLink from "~/components/BackLink.astro";
import EvidenceLegend from "~/components/EvidenceLegend.astro";
import RecordTeardown from "~/components/RecordTeardown.astro";
import { OPC_TEARDOWN, RDA_TEARDOWN } from "~/lib/teardowns";
import { withSite } from "~/lib/site";

// Literal braces would be parsed as JSX expressions inside markup, so the
// contract snippet is a plain string.
const contractSnippet = `<RecordTeardown
  record={ recordId, citation }
  layout="split | scroll | annotated"
/>`;
---

<Base title="Record Teardown — component preview" section="site" noindex>
  <div class="td-showcase">
    <BackLink href={withSite("/site/")} label="The record" />
    <div class="td-showcase-kicker">Watermark · component family</div>
    <h1>The Record Teardown</h1>
    <p class="td-showcase-lead">
      One reusable, data-driven pattern — props are <strong>a record + a citation</strong> — that makes the
      <strong>source → structured read → meaning → verify → connect</strong> transformation visible. One
      component, a selectable <code>layout</code> prop, three teaching shapes. Shown on the Tetra Tech Opinion
      of Probable Cost.
    </p>

    <!-- contract -->
    <div class="td-contract">
      <div class="td-contract-col">
        <h2>The contract</h2>
        <pre>{contractSnippet}</pre>
        <p class="td-note">
          Authoring a new teardown = pick a record, write three sentences. Same feeds as the library — the data
          never forks.
        </p>
      </div>
      <div class="td-contract-col">
        <h2>The five parts</h2>
        <div class="td-parts-list">
          <div><b>①</b> The source — artifact + provenance, messiness visible</div>
          <div><b>②</b> What we read — structured extraction, confidence shown</div>
          <div><b>③</b> What it reveals — plain meaning + load-bearing number</div>
          <div><b>④</b> How to check — evidence tag + verify link</div>
          <div><b>⑤</b> Where it connects — doors into the library</div>
        </div>
      </div>
      <div class="td-contract-col">
        <EvidenceLegend />
        <p class="td-note">[derived] → inference · [live] → verified (mapped, minimal)</p>
      </div>
    </div>

    <!-- A · split -->
    <div class="td-layout-head">
      <div class="td-badge">LAYOUT A</div>
      <div class="td-layout-name">Split-screen read <span>— default · source ↔ extraction across the gutter</span></div>
    </div>
    <RecordTeardown record={OPC_TEARDOWN} layout="split" />

    <!-- B · scroll -->
    <div class="td-layout-head">
      <div class="td-badge">LAYOUT B</div>
      <div class="td-layout-name">Vertical scrollytelling <span>— the mobile reflow · source leads, read pulls out below</span></div>
    </div>
    <RecordTeardown record={OPC_TEARDOWN} layout="scroll" />

    <!-- C · annotated -->
    <div class="td-layout-head">
      <div class="td-badge td-badge--danger">LAYOUT C</div>
      <div class="td-layout-name">Annotated artifact <span>— for redaction-heavy records · numbered pins keyed to a margin rail</span></div>
    </div>
    <RecordTeardown record={OPC_TEARDOWN} layout="annotated" />

    <!-- 2-up -->
    <div class="td-layout-head">
      <div class="td-badge td-badge--ink">2-UP</div>
      <div class="td-layout-name">Paired teardowns <span>— two anchor records, stacked with a connective beat (Ch. 1 / 3 / 4)</span></div>
    </div>
    <div class="td-twoup">
      <div class="td-twoup-row"><span class="td-twoup-tag">RECORD 1 OF 2</span><span>What the road work is priced at →</span></div>
      <RecordTeardown record={OPC_TEARDOWN} layout="split" />

      <div class="td-beat">
        <div class="td-beat-arrow" aria-hidden="true">↓</div>
        <div class="td-beat-text">
          <b>and then —</b> that $14.2M estimate becomes a “private” contribution in the deal itself, where the
          clauses decide who really pays.
        </div>
      </div>

      <div class="td-twoup-row"><span class="td-twoup-tag">RECORD 2 OF 2</span><span>… and how the contract structures it</span></div>
      <RecordTeardown record={RDA_TEARDOWN} layout="split" />
    </div>
  </div>
</Base>
