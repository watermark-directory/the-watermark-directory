---
import Base from "../layouts/Base.astro";
import SubmitForm from "../components/SubmitForm.astro";

// The network-tier submission route (the "Submit" tab + the footer + network-global
// pages link here). `section="submit"` lights the network Submit tab and keeps the
// network chrome — unlike /network/american-sugar-creek-allen-co/submit, which is the site-tier route the per-record
// correction deep-links target so a Lima correction keeps Lima chrome.
---

<Base title="Submit a tip or correction" section="submit">
  <SubmitForm />
</Base>
