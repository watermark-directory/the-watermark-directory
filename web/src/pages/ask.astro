---
import Base from "../layouts/Base.astro";
import { withSite, withStory } from "../lib/site";

// The portal goes live only when the Turnstile site key is present at build time (set in
// the host/CI env once the endpoint is bootstrapped — docs/ask-api.md). Until then,
// render a disabled placeholder that points at browsing the corpus directly, so the page
// is honest in every environment (local, CI, and the not-yet-live deploy).
const siteKey = import.meta.env.PUBLIC_TURNSTILE_SITE_KEY;
const enabled = Boolean(siteKey);
const base = import.meta.env.BASE_URL || "/";

// Pages Functions are root-relative and NOT base-prefixed (unlike static assets).
const ENDPOINT = "/api/ask";
const CONTRACT_URL =
  "https://github.com/watermark-directory/the-watermark-directory/blob/main/docs/ask-api.md";

const EXAMPLES = [
  "What do the Tetra Tech roundabout cost estimates total?",
  "Who are the parties named in the confidentiality agreement?",
  "What permits has Ohio EPA issued for the site?",
];

const faqLd = Astro.site
  ? {
      "@context": "https://schema.org",
      "@type": "FAQPage",
      mainEntity: [
        {
          "@type": "Question",
          name: "What is the Watermark Directory?",
          acceptedAnswer: {
            "@type": "Answer",
            text: "An investigative platform that decodes public-records documents about water infrastructure in Ohio and Indiana watersheds, assembling primary sources into a browsable, citable record.",
          },
        },
        {
          "@type": "Question",
          name: "What records are in the corpus?",
          acceptedAnswer: {
            "@type": "Answer",
            text: "NPDES permits, stormwater plans, engineering cost estimates, commissioner meeting minutes, and environmental agency correspondence covering the American Sugar Creek / Lima, Ohio watershed.",
          },
        },
        {
          "@type": "Question",
          name: "What do the Tetra Tech roundabout cost estimates total?",
          acceptedAnswer: {
            "@type": "Answer",
            text: "The six Tetra Tech OPC estimates for the roundabout infrastructure are documented in the corpus; ask the corpus for a current total with citations.",
          },
        },
        {
          "@type": "Question",
          name: "What permits has Ohio EPA issued for the site?",
          acceptedAnswer: {
            "@type": "Answer",
            text: "Ohio EPA-issued NPDES and air permits for the Lima data-center site are in the corpus; ask for a list with permit numbers and issue dates.",
          },
        },
      ],
    }
  : null;
---

<Base title="Ask the corpus" section="ask">
  {faqLd && <script slot="head" type="application/ld+json" is:inline set:html={JSON.stringify(faqLd)} />}
  <article class="prose">
    <div class="submit-eyebrow">Ask</div>
    <h1>Ask the corpus</h1>
    <p class="section-lead">
      Ask a question about the Watermark record and get an answer drawn <strong>only from the
      extracted corpus</strong>, with citations back to the source. If the record is
      silent, the answer says so — it never guesses. Treat answers as a <strong>guide to
      the record</strong>, not a verdict; follow the citations and verify.
    </p>

    {
      enabled ? (
        <Fragment>
          <noscript>
            <div class="callout callout-warning">
              <p class="callout-title">JavaScript is required to ask</p>
              <p>
                The question box verifies you're human and streams the answer, both of which
                need JavaScript. With it off, browse the record directly —
                <a href={withSite("/site/")}>the corpus</a>,
                <a href={withSite("/timeline")}>the timeline</a>, or
                <a href={withStory()}>the story</a>.
              </p>
            </div>
          </noscript>
          <form id="ask-form" class="form ask-card" data-endpoint={ENDPOINT} data-base={base}>
            <div class="field">
              <label for="ask-question">
                Your question
                <span class="field-hint">— one question about the record. Answers cite their sources.</span>
              </label>
              <textarea
                id="ask-question"
                name="question"
                maxlength="1000"
                required
                rows="2"
                placeholder="e.g. “How much do the roundabout estimates total?”"
              />
            </div>

            <div class="ask-examples" aria-label="Example questions">
              {EXAMPLES.map((q) => (
                <button type="button" class="ask-example" data-q={q}>
                  {q}
                </button>
              ))}
            </div>

            <div class="cf-turnstile" data-sitekey={siteKey} />

            <div class="form-foot">
              <button type="submit" class="btn">Ask</button>
              <p id="ask-status" class="form-status" role="status" aria-live="polite" />
            </div>
          </form>

          <div id="ask-answer" class="ask-answer prose" hidden />
          <div id="ask-controls" class="ask-controls" hidden>
            <button type="button" id="ask-stop" class="ask-ctl ask-ctl--stop" hidden>
              Stop generating
            </button>
            <button type="button" id="ask-copy" class="ask-ctl" hidden>Copy answer</button>
            <button type="button" id="ask-retry" class="ask-ctl" hidden>Retry</button>
          </div>
          <div id="ask-sources" class="ask-sources-wrap" />

          <p class="submit-note">
            Answers are generated by Claude from the retrieved records and may be incomplete.
            The corpus is litigation evidence — <strong>verify every claim against its
            citation</strong>. Full contract: <a href={CONTRACT_URL}>docs/ask-api.md</a>.
          </p>

          <script src="https://challenges.cloudflare.com/turnstile/v0/api.js" async defer is:inline />
          <script>import "../scripts/ask.ts";</script>
        </Fragment>
      ) : (
        <div class="callout callout-warning">
          <p class="callout-title">Ask isn't live yet</p>
          <p>
            The question endpoint isn't enabled in this build. In the meantime you can
            explore the record directly — browse <a href={withSite("/site/")}>the corpus</a>,
            walk <a href={withSite("/timeline")}>the timeline</a>, or
            <a href={withStory()}>start the story</a>. The question box will
            appear here once the endpoint is live.
          </p>
        </div>
      )
    }
  </article>
</Base>
