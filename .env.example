# Copy to .env and fill in. .env is gitignored.

# Anthropic API key used by the Claude Agent SDK / Anthropic SDK.
ANTHROPIC_API_KEY=sk-ant-...

# All BOSC settings are namespaced with the BOSC_ prefix (see bosc/config.py).

# Default model for the research agent.
BOSC_MODEL=claude-opus-4-8

# A lighter/faster model for bulk extraction work.
BOSC_EXTRACT_MODEL=claude-sonnet-4-6

# Cap on agent turns per research run.
BOSC_MAX_TURNS=20

# Logging: DEBUG | INFO | WARNING | ERROR
BOSC_LOG_LEVEL=INFO

# US Census Data API key — enables the population-over-time series in the economics
# baseline (`bosc economics`). Free instant key: https://api.census.gov/data/key_signup.html
# Without it, employment + location quotients still work (BLS QCEW is keyless).
BOSC_CENSUS_API_KEY=

# Override data locations if needed (defaults are repo-relative).
# BOSC_DATA_DIR=./data
