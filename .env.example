# Copy to .env and fill in. .env is gitignored.

# Anthropic API key used by the Claude Agent SDK / Anthropic SDK.
ANTHROPIC_API_KEY=sk-ant-...

# All BOSC settings are namespaced with the BOSC_ prefix (see bosc/config.py).

# Default model for the research agent.
BOSC_MODEL=claude-opus-4-8

# A lighter/faster model for bulk extraction work.
BOSC_EXTRACT_MODEL=claude-sonnet-4-6

# Cap on agent turns per research run.
BOSC_MAX_TURNS=20

# Logging: DEBUG | INFO | WARNING | ERROR
BOSC_LOG_LEVEL=INFO

# US Census Data API key — enables the population-over-time series in the economics
# baseline (`bosc economics`). Free instant key: https://api.census.gov/data/key_signup.html
# Without it, employment + location quotients still work (BLS QCEW is keyless).
BOSC_CENSUS_API_KEY=

# EIA API v2 key — consumer energy prices + retail sales (`bosc eia`; the demand ->
# consumer-price thread, #91/#120). Free instant key: https://www.eia.gov/opendata/register.php
# Sent only on the live request; never part of the cache key or a committed fixture.
# Offline (BOSC_ECON_OFFLINE=1) replays committed fixtures and needs no key.
BOSC_EIA_API_KEY=

# PJM Data Miner 2 subscription key — zonal day-ahead LMP (`bosc lmp` / `bosc pjm`; #121).
# Free signup: https://dataminer2.pjm.com/  (sent as the Ocp-Apim-Subscription-Key header only on
# the live request; never in the cache key or a committed fixture). Offline (BOSC_ECON_OFFLINE=1)
# replays committed fixtures and needs no key.
BOSC_PJM_API_KEY=

# --- Live-data credentials pending their connectors (tracking issue #124) -------------
# Not yet read by bosc.config — listed here so provisioning lives in one place. Add the
# matching Settings field when the connector lands.
#
# FERC Online / eLibrary (#122) — Form 1 (XBRL) financials + docket downloads
#   (ER24-2172, AD24-11-000). Access/credentials, not an API key:
#   https://www.ferc.gov/ferc-online/ferc-online/how-register

# Override data locations if needed (defaults are repo-relative).
# BOSC_DATA_DIR=./data

# OpenTelemetry / Honeycomb (#953) — backend tracing
# Create a key at https://ui.honeycomb.io/account → Team Settings → API Keys.
# WATERMARK_OTEL_ENABLED defaults to false; set to true to emit spans to Honeycomb.
WATERMARK_OTEL_ENABLED=false
WATERMARK_HONEYCOMB_API_KEY=
