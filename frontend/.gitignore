# Astro / Node build artifacts — regenerable, never committed.
node_modules/
dist/
.astro/

# Local env overrides (e.g. BOSC_BUNDLE_DIR).
.env
.env.local

# Astro's static-assets dir IS source (favicon, etc.) — re-include it; a global
# gitignore (`public`) would otherwise exclude it.
!public/
!public/**
