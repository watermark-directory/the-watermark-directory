---
/**
 * The rail — a table of contents for the page you're on (NOT section nav). It
 * lists this page's own in-page anchors; `scripts/toc.ts` highlights the one in
 * view (scroll-spy). Pages pass their `toc` to `Base`, which renders this only
 * when there are entries. The links are same-page `#anchor`s.
 */
import type { TocEntry } from "../lib/nav";

interface Props {
  items: TocEntry[];
  title?: string;
}
const { items, title = "On this page" } = Astro.props;
---

<aside class="section-toc" aria-label={title}>
  <div class="section-toc-title">{title}</div>
  <nav>
    <ul>
      {
        items.map((t, i) => (
          <li>
            <a href={`#${t.anchor}`}>
              <span class="toc-num">{String(i + 1).padStart(2, "0")}</span>
              <span class="toc-label">{t.label}</span>
            </a>
          </li>
        ))
      }
    </ul>
  </nav>
</aside>
