---
import { getSection, type SectionId } from "../lib/nav";
import { withBase } from "../lib/site";

interface Props {
  section: SectionId;
}
const { section } = Astro.props;
const data = getSection(section);
---

<aside class="section-toc" aria-label={`${data.label} — contents`}>
  <div class="section-toc-title">On this page</div>
  <nav>
    <ul>
      {
        data.toc.map((t, i) => (
          <li>
            <a href={`${withBase(data.href)}#${t.anchor}`}>
              <span class="toc-num">{String(i + 1).padStart(2, "0")}</span>
              <span class="toc-label">{t.label}</span>
            </a>
          </li>
        ))
      }
    </ul>
  </nav>
</aside>
