---
/**
 * Waterfall chart (DesignSync · hydrology chart set) — a value built or drawn down step by
 * step; reads as an equation (the classic case: intake − returned = consumed). Each step
 * floats from the running total, with a dashed connector to the next. SSR SVG, no JS. Tone
 * by kind: ink for a base total, forest for a returned/recovered delta (data), amber for an
 * addition or the net remainder (the modeled loss).
 */
import { buildWaterfall, type WaterfallStep } from "../../lib/charts";

interface Props {
  steps: WaterfallStep[];
  max?: number;
  kicker?: string;
  title: string;
  note?: string;
}
const { steps, max, kicker = "Waterfall · net", title, note } = Astro.props;
const c = buildWaterfall(steps, { max });
---

<figure class="chart-card">
  <figcaption class="chart-head">
    <span class="chart-kicker">{kicker}</span>
    <span class="chart-title">{title}</span>
  </figcaption>
  <svg viewBox={`0 0 ${c.width} ${c.height}`} class="chart-svg" role="img" aria-label={title}>
    {
      c.grid.map((g) => (
        <Fragment>
          <line x1="40" y1={g.y} x2="344" y2={g.y} stroke="var(--data-grid)" stroke-width="1" />
          <text x="36" y={g.y + 3} text-anchor="end" class="chart-axis">{g.value}</text>
        </Fragment>
      ))
    }
    <line x1="40" y1={c.baselineY} x2="344" y2={c.baselineY} stroke="var(--data-axis)" stroke-width="1" />
    {
      c.bars.map((b) =>
        b.connectorX2 != null ? (
          <line
            x1={b.x + b.w}
            y1={b.connectorY}
            x2={b.connectorX2}
            y2={b.connectorY}
            stroke="var(--ink-faint)"
            stroke-width="1"
            stroke-dasharray="3 2"
          />
        ) : null,
      )
    }
    {
      c.bars.map((b) => (
        <Fragment>
          <rect x={b.x} y={b.y} width={b.w} height={b.h} fill={b.color} />
          <text x={b.cx} y={b.y - 6} text-anchor="middle" fill={b.color} class="chart-wf-val">
            {b.label}
          </text>
          <text x={b.cx} y={c.baselineY + 14} text-anchor="middle" class="chart-axis chart-axis--x">
            {b.name}
          </text>
        </Fragment>
      ))
    }
  </svg>
  {
    note && (
      <div class="chart-bullet-note">
        <span class="chart-bullet-tick" aria-hidden="true" />
        {note}
      </div>
    )
  }
</figure>
