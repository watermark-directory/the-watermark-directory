---
/**
 * The BOSC logo mark — the "bracketed record" (design "Logo Set"): the evidence
 * brackets framing three descending bars, the public record reassembled. Square
 * caps on the brackets (reserved for the mark), round on the bars; monochrome via
 * `currentColor`, so it inherits white on the indigo chrome, indigo/ink elsewhere.
 * Mark only — the wordmark is system type set alongside it.
 */
interface Props {
  size?: number;
  class?: string;
  label?: string;
}
const { size = 26, class: cls, label } = Astro.props;
---

<svg
  class:list={["bosc-mark", cls]}
  viewBox="0 0 64 64"
  width={size}
  height={size}
  fill="none"
  stroke="currentColor"
  stroke-width="3.6"
  role={label ? "img" : undefined}
  aria-label={label}
  aria-hidden={label ? undefined : "true"}
>
  <path d="M22 13 H13 V51 H22" stroke-linecap="square" />
  <path d="M42 13 H51 V51 H42" stroke-linecap="square" />
  <line x1="22" y1="25" x2="42" y2="25" stroke-linecap="round" />
  <line x1="22" y1="32" x2="38" y2="32" stroke-linecap="round" />
  <line x1="22" y1="39" x2="34" y2="39" stroke-linecap="round" />
</svg>
