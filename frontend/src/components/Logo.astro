---
/**
 * The Watermark logo mark (rebrand — design "Watermark · Brand Lockups"): the
 * citation brackets — kept from the old "bracketed record" mark — now framing a
 * waterline (the line water leaves behind) over a single record rule. The name's
 * triple read: the mark pressed into paper to prove a document, the watershed, and
 * the high-water line. Square caps on the brackets (reserved for the mark), round on
 * the waterline + rule; monochrome via `currentColor`, so it inherits white on the
 * indigo chrome and indigo/ink elsewhere. Mark only — the wordmark is system type
 * set alongside it.
 */
interface Props {
  size?: number;
  class?: string;
  label?: string;
}
const { size = 26, class: cls, label } = Astro.props;
---

<svg
  class:list={["bosc-mark", cls]}
  viewBox="0 0 64 64"
  width={size}
  height={size}
  fill="none"
  stroke="currentColor"
  stroke-width="3.6"
  role={label ? "img" : undefined}
  aria-label={label}
  aria-hidden={label ? undefined : "true"}
>
  <path d="M23 13 H13 V51 H23" stroke-linecap="square" />
  <path d="M41 13 H51 V51 H41" stroke-linecap="square" />
  <path d="M21 29 q5.5 -6 11 0 t11 0" stroke-linecap="round" />
  <line x1="21" y1="42" x2="43" y2="42" stroke-linecap="round" />
</svg>
