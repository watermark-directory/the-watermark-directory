---
/**
 * The Watermark "w." mark (rebrand — design "Watermark · Brand Final": *no logo,
 * just the word*). The brand is the wordmark `Watermark.`; the only load-bearing
 * mark is this favicon glyph — a lowercase `w` with the green signal period,
 * knocked out of an ink tile. It reads as type, not an icon. Used where the full
 * wordmark won't fit (the mobile bar, the footer, share/avatar tiles); the bar and
 * footer render the wordmark itself. Matches public/favicon.svg + brand/favicon.svg.
 */
interface Props {
  size?: number;
  class?: string;
  label?: string;
  /** Rounded tile for app-icon contexts; square (raw favicon) by default. */
  rounded?: boolean;
}
const { size = 26, class: cls, label, rounded = false } = Astro.props;
---

<svg
  class:list={["bosc-mark", cls]}
  viewBox="0 0 64 64"
  width={size}
  height={size}
  role={label ? "img" : undefined}
  aria-label={label}
  aria-hidden={label ? undefined : "true"}
>
  <rect width="64" height="64" rx={rounded ? 13 : 0} fill="#16201a"></rect>
  <text
    x="32"
    y="47"
    text-anchor="middle"
    font-family="Archivo, system-ui, Arial, sans-serif"
    font-weight="800"
    font-size="44"
    letter-spacing="-3"><tspan fill="#f5f2ea">w</tspan><tspan fill="#3d8f63">.</tspan></text>
</svg>
