---
import Icon from "./Icon.astro";
import Logo from "./Logo.astro";
import SwitcherRow from "./SwitcherRow.astro";
import { NAV_TABS, navItemActive, type SectionId } from "../lib/nav";
import { withBase } from "../lib/site";
import { groupSites, siteForPath } from "../lib/sites";

interface Props {
  active: SectionId;
}
const { active } = Astro.props;
const searchIndexUrl = withBase("/search-index.json");
const base = import.meta.env.BASE_URL || "/";

// The Watermark network switcher (#304). The mark opens a no-JS <details> menu of sites; only
// the live reference build (Lima) is switchable — the rest route to their coming-soon page.
// The *current* site is resolved from this page's route (#316), so the lockup shows where
// you are — not a constant. `null` = the network hub / cross-cutting globals (neutral state).
const here = siteForPath(Astro.url.pathname, base);
const herePlace = here ? here.place : "network";
const hereLabel = here ? `current site: ${here.place}` : "network overview";
const statusMeta: Record<string, { label: string; cls: string }> = {
  live: { label: "Live", cls: "is-live" },
  building: { label: "Building", cls: "is-building" },
  queued: { label: "Queued", cls: "is-queued" },
};
// The site's build phase, shown as a pill beside the switcher (the left/site cluster). Only on a
// resolved site — the network hub / cross-cutting globals carry no phase.
const herePhase = here ? statusMeta[here.status] : null;
// The grouped switcher (#307): the same sites pivoted by jurisdiction (State) or basin (Watershed).
// The toggle is no-JS (radio inputs + :checked), so it works with JS off.
const stateGroups = groupSites("state");
const watershedGroups = groupSites("watershed");
const hereSlug = here?.slug ?? null;

// The mobile nav sheet (#400): on phones the section tabs reopen as a labeled
// "This site / Platform" sheet. Split NAV_TABS at the ownership divider; the platform
// group also surfaces the cross-cutting globals (Directory, About, Ask, Search) that live
// in the topbar-right / footer on desktop. Desktop chrome (.sections) is untouched.
const dividerAt = NAV_TABS.findIndex((t) => t.kind === "divider");
const siteTabs = (dividerAt === -1 ? NAV_TABS : NAV_TABS.slice(0, dividerAt)).filter((t) => t.kind !== "divider");
const platformTabs = (dividerAt === -1 ? [] : NAV_TABS.slice(dividerAt + 1)).filter((t) => t.kind !== "divider");
const platformGlobals: { label: string; href: string; section: SectionId }[] = [
  { label: "Directory", href: "/directory/", section: "directory" },
  { label: "About", href: "/about", section: "about" },
  { label: "Ask the corpus", href: "/ask", section: "ask" },
  { label: "Search", href: "/search", section: "search" },
];
---

<header class="topbar">
  <label for="bosc-nav-toggle" class="nav-burger" aria-label="Toggle navigation"><Icon name="menu" size={22} /></label>
  <details class="site-switcher">
    <summary class="brand" aria-label={`The Watermark network — ${hereLabel}`}>
      <Logo size={26} class="brand-mark" />
      <span class="brand-word"><strong>Watermark</strong> <span class="brand-tagline">· {herePlace}</span></span>
      <span class="switcher-caret" aria-hidden="true">▾</span>
    </summary>
    <div class="switcher-menu">
      <input type="radio" name="switcher-groupby" id="gb-state" class="gb-radio" checked />
      <input type="radio" name="switcher-groupby" id="gb-ws" class="gb-radio" />
      <div class="switcher-head">
        <span class="switcher-title">Switch site</span>
        <span class="switcher-groupby">
          <span class="gb-k">Group by</span>
          <label for="gb-state" class="gb-btn gb-state">State</label>
          <label for="gb-ws" class="gb-btn gb-ws">Watershed</label>
        </span>
      </div>
      <div class="switcher-groups by-state">
        {
          stateGroups.map((g) => (
            <div class="switcher-group">
              <div class="switcher-grouphead">
                {g.tag && <span class="switcher-grouptag">{g.tag}</span>}
                <span class="switcher-grouplabel">{g.label}</span>
                <span class="switcher-groupcount">{g.sites.length}</span>
              </div>
              {g.sites.map((s) => (
                <SwitcherRow site={s} activeSlug={hereSlug} />
              ))}
            </div>
          ))
        }
      </div>
      <div class="switcher-groups by-watershed">
        {
          watershedGroups.map((g) => (
            <div class="switcher-group">
              <div class="switcher-grouphead">
                <span class="switcher-grouplabel">{g.label}</span>
                <span class="switcher-groupcount">{g.sites.length}</span>
              </div>
              {g.sites.map((s) => (
                <SwitcherRow site={s} activeSlug={hereSlug} />
              ))}
            </div>
          ))
        }
      </div>
      <p class="switcher-foot">
        Each site is a section of the Watermark platform — pivoted by <b>state</b> or
        <b>watershed</b>; queued sites route to their coming-soon page.
      </p>
    </div>
  </details>
  {herePhase && <span class:list={["phase-pill", herePhase.cls]} title={`Site build phase: ${herePhase.label}`}>{herePhase.label}</span>}
  <nav class="sections" id="bosc-sections" aria-label="Sections">
    {
      NAV_TABS.map((item) => {
        if (item.kind === "divider") return <span class="nav-divider" aria-hidden="true" />;
        const isActive = navItemActive(item, active);
        if (item.kind === "dropdown") {
          return (
            <details class:list={["nav-dd", { active: isActive }]}>
              <summary class="section-tab nav-dd-summary" aria-current={isActive ? "page" : undefined}>
                {item.label}
                <span class="nav-dd-caret" aria-hidden="true">▾</span>
              </summary>
              <div class="nav-dd-menu">
                {item.children.map((child) =>
                  "divider" in child ? (
                    <hr class="nav-dd-hr" />
                  ) : (
                    <a class="nav-dd-item" href={withBase(child.href)}>
                      {child.label}
                    </a>
                  ),
                )}
              </div>
            </details>
          );
        }
        return (
          <a
            class:list={["section-tab", { active: isActive }]}
            href={withBase(item.href)}
            aria-current={isActive ? "page" : undefined}
          >
            {item.label}
          </a>
        );
      })
    }
  </nav>
  <nav class="nav-sheet" id="bosc-nav-sheet" aria-label="Site menu">
    <div class="sheet-group">
      <div class="sheet-grouphead">This site</div>
      {
        siteTabs.map((item) =>
          item.kind === "link" ? (
            <a
              class:list={["sheet-link", { active: navItemActive(item, active) }]}
              href={withBase(item.href)}
              aria-current={navItemActive(item, active) ? "page" : undefined}
            >
              {item.label}
            </a>
          ) : item.kind === "dropdown" ? (
            <>
              <div class="sheet-sublabel">{item.label}</div>
              {item.children.map((child) =>
                "divider" in child ? null : (
                  <a class="sheet-link sheet-link--sub" href={withBase(child.href)}>
                    {child.label}
                  </a>
                ),
              )}
            </>
          ) : null,
        )
      }
    </div>
    <div class="sheet-group">
      <div class="sheet-grouphead">Platform</div>
      {
        platformTabs.map((item) =>
          item.kind === "link" ? (
            <a
              class:list={["sheet-link", { active: navItemActive(item, active) }]}
              href={withBase(item.href)}
              aria-current={navItemActive(item, active) ? "page" : undefined}
            >
              {item.label}
            </a>
          ) : null,
        )
      }
      {
        platformGlobals.map((g) => (
          <a
            class:list={["sheet-link", { active: active === g.section }]}
            href={withBase(g.href)}
            aria-current={active === g.section ? "page" : undefined}
          >
            {g.label}
          </a>
        ))
      }
    </div>
  </nav>
  <div class="topbar-right">
    <a
      class:list={["topbar-ask", { active: active === "ask" }]}
      href={withBase("/ask")}
      aria-current={active === "ask" ? "page" : undefined}
    >
      <Icon name="ask" size={15} /> <span class="topbar-ask-label">Ask</span>
    </a>
    <div class="search">
      <Icon name="search" size={15} class="search-icon" />
      <input
        type="search"
        id="bosc-search"
        placeholder="Search the record…"
        autocomplete="off"
        aria-label="Search the corpus"
        spellcheck="false"
        data-index={searchIndexUrl}
        data-base={base}
      />
      <kbd class="search-kbd" aria-hidden="true">⌘K</kbd>
      <div id="bosc-search-results" class="search-results" hidden></div>
    </div>
  </div>
</header>
