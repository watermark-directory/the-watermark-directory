---
import Icon from "./Icon.astro";
import Logo from "./Logo.astro";
import SwitcherRow from "./SwitcherRow.astro";
import { networkTabs, platformLinks, siteTabs, SUBMIT_LINK, navItemActive, navItemLinks, type SectionId } from "../lib/nav";
import { withBase } from "../lib/site";
import { groupSites, SITE_STATUS_META, SITES, siteForPath } from "../lib/sites";

interface Props {
  active: SectionId;
}
const { active } = Astro.props;
const searchIndexUrl = withBase("/search-index.json");
const base = import.meta.env.BASE_URL || "/";

// The two-tier chrome (design "Global Chrome"). The active tier is resolved from the
// route: inside a site (`here !== null`) → SITE tabs + the site chip; at the network
// level (the directory + cross-cutting globals) → NETWORK tabs + the "All sites" chip.
// The `Watermark.` wordmark always returns to the network home (the Directory).
const here = siteForPath(Astro.url.pathname, base);
const tier: "network" | "site" = here ? "site" : "network";
const siteTabsList = siteTabs();
const networkTabsList = networkTabs();
const platformList = platformLinks();
const leftTabs = tier === "site" ? siteTabsList : networkTabsList;
const networkHome = "/";

// The site chip = the breadcrumb + the switcher trigger. Network tier shows "All sites".
const chipPlace = here ? here.place : "All sites";
const chipCodename = here?.codename ?? null;
const herePhase = here ? SITE_STATUS_META[here.status] : null;

// The grouped selector (#307/#308): the same 32-site panel, pivoted by State or Basin
// (default Basin, design "Site Selector"). No-JS — radio inputs + :checked.
const stateGroups = groupSites("state");
const basinGroups = groupSites("basin");
const hereSlug = here?.slug ?? null;
const totalSites = SITES.length;
const stateCount = stateGroups.length;
const basinCount = basinGroups.length;

// The platform globals also surfaced in the mobile sheet's "Platform" group. Submit
// rides here on phones (on desktop it's the right-cluster pill); Ask + Search follow.
const platformGlobals: { label: string; href: string; section: SectionId }[] = [
  { label: SUBMIT_LINK.label, href: SUBMIT_LINK.href, section: SUBMIT_LINK.section },
  { label: "Ask the corpus", href: "/ask", section: "ask" },
  { label: "Search", href: "/search", section: "search" },
];
---

<header class:list={["topbar", `tier-${tier}`]}>
  <!-- Brand — the wordmark, always a link home to the network. On phones it collapses to the "w." mark. -->
  <a class="brand" href={withBase(networkHome)} aria-label="Watermark — network home">
    <Logo size={22} class="brand-mark" rounded />
    <span class="brand-word">Watermark<span class="brand-dot">.</span></span>
  </a>
  <span class="brand-sep" aria-hidden="true">/</span>

  <!-- The site chip — the breadcrumb into a site and the switcher trigger (no-JS <details>). -->
  <details class="site-switcher">
    <summary class="site-chip" aria-label={tier === "network" ? "All sites — open the site selector" : `Current site: ${chipPlace} — switch site`}>
      {
        tier === "network" && (
          <svg class="chip-grid" viewBox="0 0 24 24" width="13" height="13" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <rect x="3.5" y="4.5" width="17" height="6" rx="1" />
            <rect x="3.5" y="13.5" width="17" height="6" rx="1" />
          </svg>
        )
      }
      <span class="chip-place">{chipPlace}</span>
      {chipCodename && <span class="chip-codename">{chipCodename}</span>}
      <span class="chip-caret" aria-hidden="true">▾</span>
    </summary>
    <div class="switcher-menu">
      <input type="radio" name="switcher-groupby" id="gb-basin" class="gb-radio" checked />
      <input type="radio" name="switcher-groupby" id="gb-state" class="gb-radio" />
      <div class="switcher-head">
        <span class="switcher-head-l">
          <span class="switcher-title">Switch site</span>
          <span class="switcher-count"
            >{totalSites} sites · <span class="sw-scope sw-scope-basin">{basinCount} basins</span><span
              class="sw-scope sw-scope-state">{stateCount} states</span
            ></span
          >
        </span>
        <span class="switcher-groupby">
          <span class="gb-k">Group by</span>
          <label for="gb-state" class="gb-btn gb-state">State</label>
          <label for="gb-basin" class="gb-btn gb-basin">Basin</label>
        </span>
      </div>
      <div class="switcher-groups by-state">
        {
          stateGroups.map((g) => (
            <div class="switcher-group">
              <div class="switcher-grouphead">
                {g.tag && <span class="switcher-grouptag">{g.tag}</span>}
                <span class="switcher-grouplabel">{g.label}</span>
                <span class="switcher-groupcount">{g.sites.length}</span>
              </div>
              <div class="switcher-grouprows">
                {g.sites.map((s) => (
                  <SwitcherRow site={s} activeSlug={hereSlug} />
                ))}
              </div>
            </div>
          ))
        }
      </div>
      <div class="switcher-groups by-basin">
        {
          basinGroups.map((g) => (
            <>
              {g.showRegion && (
                <div class="switcher-region">
                  <span class="switcher-region-tag">{g.regionTag}</span>
                  <span class="switcher-region-label">{g.regionLabel}</span>
                  <span class="switcher-region-count">{g.regionCount} sites</span>
                </div>
              )}
              <div class="switcher-group">
                <div class="switcher-grouphead">
                  {g.tag && <span class="switcher-grouptag">{g.tag}</span>}
                  <span class="switcher-grouplabel">{g.label}</span>
                  <span class="switcher-groupcount">{g.sites.length}</span>
                </div>
                <div class="switcher-grouprows">
                  {g.sites.map((s) => (
                    <SwitcherRow site={s} activeSlug={hereSlug} />
                  ))}
                </div>
              </div>
            </>
          ))
        }
      </div>
      <div class="switcher-foot">
        <span class="switcher-foot-note">
          Each site is a section of the Watermark platform — pivoted by <span class="sw-scope sw-scope-basin"
            >basin</span
          ><span class="sw-scope sw-scope-state">state</span>. Live &amp; building sites open; queued and tracking
          sites route to their coming-soon / watch page.
        </span>
        <span class="switcher-legend" aria-hidden="true">
          <span class="leg leg-live">Live</span>
          <span class="leg leg-building">Building</span>
          <span class="leg leg-queued">Queued</span>
          <span class="leg leg-tracking">Tracking</span>
          <span class="leg leg-locked">
            <svg viewBox="0 0 24 24" width="11" height="11" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <rect x="5" y="11" width="14" height="9" rx="1"></rect>
              <path d="M8 11 V7.5 A4 4 0 0 1 16 7.5 V11"></path>
            </svg>Locked
          </span>
        </span>
      </div>
    </div>
  </details>
  {herePhase && <span class:list={["phase-pill", herePhase.cls]} title={`Site build phase: ${herePhase.label}`}>{herePhase.label}</span>}

  <!-- Left tabs — swap by tier (site vs network). About is a no-JS dropdown. -->
  <nav class="sections" id="bosc-sections" aria-label={tier === "site" ? "This site" : "Network"}>
    {
      leftTabs.map((item) => {
        const isActive = navItemActive(item, active);
        if (item.kind === "mega") {
          const m = item.mega;
          return (
            <details class:list={["nav-dd", "nav-mega", { active: isActive }]}>
              <summary class="section-tab nav-dd-summary" aria-current={isActive ? "page" : undefined}>
                {item.label}
                <span class="nav-dd-caret" aria-hidden="true">▾</span>
              </summary>
              <div class="nav-mega-menu">
                <div class="nav-mega-tiles">
                  {m.tiles.map((t) => (
                    <a class="nav-mega-tile" href={withBase(t.href)}>
                      <span class="nav-mega-tile-label">{t.label}</span>
                      <span class="nav-mega-tile-blurb">{t.blurb}</span>
                    </a>
                  ))}
                </div>
                <div class="nav-mega-cols">
                  <div class="nav-mega-spine">
                    <a class="nav-mega-spine-head" href={withBase(m.spine.href)}>
                      <span class="nav-mega-spine-title">{m.spine.title}</span>
                      <span class="nav-mega-spine-count">{m.spine.count}</span>
                    </a>
                    <p class="nav-mega-spine-blurb">{m.spine.blurb}</p>
                    {m.spine.items.map((it) => (
                      <a class="nav-mega-link" href={withBase(it.href)}>
                        <span class="nav-mega-num">{it.num}</span>
                        <span class="nav-mega-link-main">
                          <span class="nav-mega-link-label">{it.label}</span>
                          {it.blurb && <span class="nav-mega-link-blurb">{it.blurb}</span>}
                        </span>
                      </a>
                    ))}
                    <a class="nav-mega-toc" href={withBase(m.spine.tocHref)}>Open the table of contents →</a>
                  </div>
                  <div class="nav-mega-themes">
                    <div class="nav-mega-themes-head">Themes it crosses</div>
                    <div class="nav-mega-themes-grid">
                      {m.themes.map((th) => (
                        <div class="nav-mega-theme">
                          <a class="nav-mega-theme-title" href={withBase(th.href)}>{th.title}</a>
                          {th.items.map((it) => (
                            <a class="nav-mega-tlink" href={withBase(it.href)}>
                              {it.label}
                            </a>
                          ))}
                        </div>
                      ))}
                    </div>
                  </div>
                </div>
              </div>
            </details>
          );
        }
        if (item.kind === "dropdown") {
          return (
            <details class:list={["nav-dd", { active: isActive }]}>
              <summary class="section-tab nav-dd-summary" aria-current={isActive ? "page" : undefined}>
                {item.label}
                <span class="nav-dd-caret" aria-hidden="true">▾</span>
              </summary>
              <div class="nav-dd-menu">
                {item.children.map((child) =>
                  "divider" in child ? (
                    <hr class="nav-dd-hr" />
                  ) : (
                    <a class="nav-dd-item" href={withBase(child.href)}>
                      <span class="nav-dd-item-label">{child.label}</span>
                      {child.blurb && <span class="nav-dd-item-blurb">{child.blurb}</span>}
                    </a>
                  ),
                )}
              </div>
            </details>
          );
        }
        return (
          <a
            class:list={["section-tab", { active: isActive }]}
            href={withBase(item.href)}
            aria-current={isActive ? "page" : undefined}
          >
            {item.label}
          </a>
        );
      })
    }
  </nav>

  <!-- Mobile sheet (#400): This site / Network / Platform, toggled by the burger checkbox. -->
  <nav class="nav-sheet" id="bosc-nav-sheet" aria-label="Site menu">
    <div class="sheet-group">
      <div class="sheet-grouphead">This site · {here ? here.place : "Lima"}</div>
      {
        siteTabsList.map((item) =>
          item.kind === "link" ? (
            <a
              class:list={["sheet-link", { active: navItemActive(item, active) }]}
              href={withBase(item.href)}
              aria-current={navItemActive(item, active) ? "page" : undefined}
            >
              {item.label}
            </a>
          ) : item.kind === "mega" ? (
            navItemLinks(item).map((l) => (
              <a class="sheet-link" href={withBase(l.href)}>
                {l.label}
              </a>
            ))
          ) : (
            <>
              <div class="sheet-sublabel">{item.label}</div>
              {item.children.map((child) =>
                "divider" in child ? null : (
                  <a class="sheet-link sheet-link--sub" href={withBase(child.href)}>
                    {child.label}
                  </a>
                ),
              )}
            </>
          ),
        )
      }
    </div>
    <div class="sheet-group">
      <div class="sheet-grouphead">Network</div>
      {
        networkTabsList.map((item) =>
          item.kind === "link" ? (
            <a
              class:list={["sheet-link", { active: navItemActive(item, active) }]}
              href={withBase(item.href)}
              aria-current={navItemActive(item, active) ? "page" : undefined}
            >
              {item.label}
            </a>
          ) : item.kind === "dropdown" ? (
            <>
              <div class="sheet-sublabel">{item.label}</div>
              {item.children.map((child) =>
                "divider" in child ? null : (
                  <a class="sheet-link sheet-link--sub" href={withBase(child.href)}>
                    {child.label}
                  </a>
                ),
              )}
            </>
          ) : null,
        )
      }
    </div>
    <div class="sheet-group">
      <div class="sheet-grouphead">Platform</div>
      <div class="sheet-platform">
        {
          platformList.map((item) => (
            <a
              class:list={["sheet-plink", { active: active === item.section }]}
              href={withBase(item.href)}
              aria-current={active === item.section ? "page" : undefined}
            >
              {item.label}
            </a>
          ))
        }
        {
          platformGlobals.map((g) => (
            <a
              class:list={["sheet-plink", { active: active === g.section }]}
              href={withBase(g.href)}
              aria-current={active === g.section ? "page" : undefined}
            >
              {g.label === "Ask the corpus" ? "Ask" : g.label}
            </a>
          ))
        }
      </div>
    </div>
  </nav>

  <!-- Platform cluster (right) — Docs · Wiki · | · Submit · Ask · Search. Constant across tiers. -->
  <div class="topbar-right">
    <span class="platform-links">
      {
        platformList.map((item) => (
          <a
            class:list={["platform-link", { active: active === item.section }]}
            href={withBase(item.href)}
            aria-current={active === item.section ? "page" : undefined}
          >
            {item.label}
          </a>
        ))
      }
    </span>
    <span class="topbar-div" aria-hidden="true"></span>
    <a
      class:list={["topbar-submit", { active: active === SUBMIT_LINK.section }]}
      href={withBase(SUBMIT_LINK.href)}
      aria-current={active === SUBMIT_LINK.section ? "page" : undefined}
    >
      <svg viewBox="0 0 24 24" width="14" height="14" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        <line x1="12" y1="5" x2="12" y2="19"></line>
        <line x1="5" y1="12" x2="19" y2="12"></line>
      </svg>
      <span class="topbar-submit-label">Submit</span>
    </a>
    <a
      class:list={["topbar-ask", { active: active === "ask" }]}
      href={withBase("/ask")}
      aria-current={active === "ask" ? "page" : undefined}
    >
      <Icon name="ask" size={15} /> <span class="topbar-ask-label">Ask</span>
    </a>
    <div class="search">
      <Icon name="search" size={15} class="search-icon" />
      <input
        type="search"
        id="bosc-search"
        placeholder="Search…"
        autocomplete="off"
        aria-label="Search the corpus"
        spellcheck="false"
        data-index={searchIndexUrl}
        data-base={base}
      />
      <kbd class="search-kbd" aria-hidden="true">⌘K</kbd>
      <div id="bosc-search-results" class="search-results" hidden></div>
    </div>
    <label for="bosc-nav-toggle" class="nav-burger" aria-label="Toggle navigation"><Icon name="menu" size={22} /></label>
  </div>
</header>
