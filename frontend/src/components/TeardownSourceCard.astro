---
/**
 * The Record Teardown's `① source` card — the real-source viewer (#218, #284).
 * Preview priority:
 *   1. a committed **scan crop** of the real region (curated; reads best for degraded
 *      scans, carries its own redaction overlay) — the preferred preview when present;
 *   2. else, when the record resolves to a **published** real source document
 *      (`sourceDoc`, via the A2 join), the live document embedded through <DocViewer>;
 *   3. else the record's **real extraction** rendered as a facsimile from the feed;
 *   4. else a quiet "on request" pill (minimal CI fixture only).
 *
 * The publish gate is respected: only a `published` source embeds inline (so the public
 * build never shows a broken embed); any catalogued source still links to its full
 * viewer page, which is dev-full / prod-gated. SSR-readable — the <DocViewer> embed
 * degrades to its own download/open affordances with JS off.
 */
import type { DocumentEntry } from "../lib/feeds";
import type { BlockField } from "../lib/recordBlock";
import { withBase } from "../lib/site";
import type { TeardownPin, TeardownSource } from "../lib/teardown";
import DocViewer from "./DocViewer.astro";

interface Props {
  source: TeardownSource;
  /** The anchor record's real scalar fields (empty when not in the bundle). */
  fields: BlockField[];
  /** The record's real source document (#284), when catalogued. */
  sourceDoc?: DocumentEntry | null;
  size?: "sm" | "md" | "lg";
  /** Generic redaction bar (annotated layout) when there's no crop overlay. */
  redactionLabel?: string;
  pins?: TeardownPin[];
}
const { source, fields, sourceDoc = null, size = "md", redactionLabel, pins = [] } = Astro.props;

const crop = source.scanCrop;
const cap = size === "lg" ? 9 : size === "sm" ? 5 : 7;
const facsimile = fields.slice(0, cap);
const bodyClass = size === "lg" ? "td-srcbody--lg" : size === "sm" ? "td-srcbody--sm" : "";
// Embed the live document only when there's no crop (crop is the preferred preview) and
// the source is on the public allowlist (so the public build never shows a broken embed).
const embed = !crop && !!sourceDoc?.published;
// The header marker shows the real render_class when a source resolves, else the curated badge.
const badge = sourceDoc ? sourceDoc.render_class.toUpperCase() : (source.badge ?? "SCAN");
const docHref = sourceDoc ? withBase(`/network/american-sugar-creek-allen-co/site/documents/${sourceDoc.rel}`) : null;
// A crop carries its own precise overlay; otherwise the generic bar marks the gap.
const showBar = !!redactionLabel && !crop?.redaction;
const hasReal = crop || embed || facsimile.length > 0;
---

<div class="td-srccard">
  <div class="td-srccard-head">
    <div class="td-doc-icon" aria-hidden="true"></div>
    <div class="td-srcfile">
      {docHref ? <a href={docHref}>{source.file}</a> : source.file}
    </div>
    <div class="td-scan">{badge}</div>
  </div>

  <div class:list={["td-srcbody", bodyClass, hasReal && "td-srcbody--real"]}>
    {crop ? (
      <figure class="td-scanfig">
        <img class="td-scanimg" src={withBase(crop.src)} alt={crop.alt} loading="lazy" decoding="async" />
        {crop.redaction && (
          <div
            class="td-cropbox"
            style={`left:${crop.redaction.x};top:${crop.redaction.y};width:${crop.redaction.w};height:${crop.redaction.h};`}
          >
            {crop.redaction.label && <span>{crop.redaction.label}</span>}
          </div>
        )}
      </figure>
    ) : embed && sourceDoc ? (
      <DocViewer entry={sourceDoc} compact />
    ) : facsimile.length ? (
      <dl class="td-facsimile" aria-label={`Extraction from ${source.file}`}>
        {facsimile.map((f) => (
          <div class="td-fac-row">
            <dt class="td-fac-label">{f.label}</dt>
            <dd class:list={["td-fac-value", f.warn && "is-warn"]}>{f.value}</dd>
          </div>
        ))}
      </dl>
    ) : (
      <div class="td-srcfallback"><div class="td-srcfallback-pill">⤓ View source on request</div></div>
    )}

    {showBar && <div class="td-redaction"><span>{redactionLabel}</span></div>}
    {pins.map((p) => (
      <div class:list={["td-pin", p.danger && "is-danger"]} style={`left:${p.x};top:${p.y};`} aria-label={`Annotation ${p.n}`}>{p.n}</div>
    ))}
  </div>

  {/* A catalogued source not embedded inline (crop shown, or gated in public) still
      links to its live viewer page — dev-full, prod-gated. */}
  {docHref && !embed && (
    <p class="td-srcdoc"><a class="td-srcdoc-link" href={docHref}>View the source document →</a></p>
  )}

  <div class="td-srcfoot">{source.pages} · {source.collection}{crop?.caption && <> · {crop.caption}</>}</div>
</div>
<div class="td-srcnote">{source.note}</div>
