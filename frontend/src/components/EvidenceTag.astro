---
// Evidence-discipline badge — the corpus marks confidence inline as
// [verified] / [inference] / [open] / [filename]; this tints them so a reader
// sees the provenance at a glance. Pair with a Citation via `evidenceKind()`.
// `gap` (scope gap, oxblood) and `key` (key figure) complete the design-system
// evidence taxonomy (DesignSync). NB vs the spec: the [bracket] notation is the
// repo's load-bearing convention (kept, not the spec's bracket-less default), and
// the tag sizes with its context via `em` rather than the spec's fixed sm/md px.
//
// The single evidence-pill renderer (#579): figure stats, the timeline, record
// teardowns, profile attributes, and the withholding stack all route through here.
// A trailing `<slot />` carries any in-pill detail (a teardown's sub, a legend gloss).
import { type EvidenceKind, EVIDENCE_LABELS } from "../lib/evidence";

export type { EvidenceKind };

interface Props {
  kind: EvidenceKind;
  /** Override label text; defaults to the kind's label. */
  label?: string;
  /** Tooltip (e.g. the source or note). */
  title?: string;
}
const { kind, label, title } = Astro.props;
---

<span class:list={["evidence", `evidence-${kind}`]} title={title} data-kind={kind}>
  <span class="evidence-dot" aria-hidden="true"></span>[{label ?? EVIDENCE_LABELS[kind] ?? kind}]<slot />
</span>
