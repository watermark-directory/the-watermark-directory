---
import Header from "../components/Header.astro";
import SectionToc from "../components/SectionToc.astro";
import { type SectionId } from "../lib/nav";
import { SITE_NAME, SITE_DESCRIPTION } from "../lib/site";
import "../styles/site.css";

interface BaseProps {
  title: string;
  description?: string;
  section?: SectionId;
}

// `.astro` pages pass these props directly; `.mdx` pages using `layout:` pass
// them nested under `frontmatter`. Accept both.
const raw = Astro.props as BaseProps & { frontmatter?: BaseProps };
const { title, description = SITE_DESCRIPTION, section = "home" } = raw.frontmatter ?? raw;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />
    <meta name="description" content={description} />
    <title>{title === SITE_NAME ? title : `${title} · ${SITE_NAME}`}</title>
  </head>
  <body>
    <input type="checkbox" id="bosc-nav-toggle" class="nav-toggle" hidden />
    <Header active={section} />
    <div class="layout">
      <SectionToc section={section} />
      <main class="content">
        <slot />
      </main>
    </div>
    <footer class="site-footer">
      Static build over the committed content bundle. Draft — chain-of-custody
      evidence; not for distribution.
    </footer>
    <script>
      import "../scripts/search.ts";
      import "../scripts/toc.ts";
    </script>
  </body>
</html>
