---
import Header from "../components/Header.astro";
import Icon from "../components/Icon.astro";
import Logo from "../components/Logo.astro";
import SEO from "../components/SEO.astro";
import SectionToc from "../components/SectionToc.astro";
import { NAV_LINKS, type SectionId, type TocEntry } from "../lib/nav";
import { SITE_NAME, SITE_DESCRIPTION, withBase } from "../lib/site";
import "../styles/site.css";

interface BaseProps {
  title: string;
  description?: string;
  section?: SectionId;
  /** Kill-switch for the rail (rarely needed — it only shows with a `toc`). */
  rail?: boolean;
  /** Page-local table of contents — anchors on THIS page. The rail is a TOC for
   *  the page you're on, never section navigation; it shows only when non-empty. */
  toc?: TocEntry[];
  /** og:type — defaults to "website"; docs essays pass "article". */
  ogType?: "website" | "article";
}

// `.astro` pages pass these props directly; `.mdx` pages using `layout:` pass
// them nested under `frontmatter`. Accept both.
const raw = Astro.props as BaseProps & { frontmatter?: BaseProps };
const {
  title,
  description = SITE_DESCRIPTION,
  section = "home",
  rail = true,
  toc = [],
  ogType = "website",
} = raw.frontmatter ?? raw;
const showRail = rail !== false && toc.length > 0;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />
    <link rel="icon" type="image/svg+xml" href={withBase("/favicon.svg")} />
    <title>{title === SITE_NAME ? title : `${title} · ${SITE_NAME}`}</title>
    <SEO title={title} description={description} type={ogType} />
  </head>
  <body>
    <a class="skip-link" href="#main">Skip to content</a>
    <input
      type="checkbox"
      id="bosc-nav-toggle"
      class="nav-toggle"
      aria-label="Open the section menu"
      aria-controls="bosc-sections"
    />
    <Header active={section} />
    <div class:list={["layout", { "no-rail": !showRail }]}>
      {showRail && <SectionToc items={toc} />}
      <main id="main" class="content" tabindex="-1">
        <slot />
      </main>
    </div>
    <footer class="site-footer">
      <div class="footer-main">
        <p class="footer-contract">
          <strong>Draft — the record is still being assembled.</strong> Every figure
          carries a source; inference is labeled; redactions are shown, not hidden.
          Nothing here is a verdict.
        </p>
        <div class="footer-actions">
          <span class="footer-pill"><span class="dot" aria-hidden="true"></span>provenance-first</span>
          <a class="btn btn--icon" href={withBase("/bosc/submit")}><Icon name="correction" size={15} /> Submit a tip or correction</a>
        </div>
      </div>
      <div class="footer-bar">
        <a class="footer-brand" href={withBase("/bosc")}><Logo size={17} class="footer-mark" />BOSC</a>
        {NAV_LINKS.map((t) => <a href={withBase(t.href)}>{t.label}</a>)}
        <span class="footer-sep" aria-hidden="true">·</span>
        <a href={withBase("/bosc/docs/methodology")}>Methodology</a>
        <a href={withBase("/bosc/about")}>About</a>
        <span class="footer-meta">static · no trackers · every page reads with JS off</span>
      </div>
    </footer>
    <script>
      import "../scripts/search.ts";
      import "../scripts/toc.ts";
    </script>
  </body>
</html>
