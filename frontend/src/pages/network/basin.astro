    display: flex;
    align-items: center;
    gap: 0.45rem;
    padding: 0.18rem 0;
    font-size: 0.9rem;
  }
  .nest-row.d0 { padding-left: 0; }
  .nest-row.d1 { padding-left: 0.9rem; }
  .nest-row.d2 { padding-left: 2.1rem; }
  .nest-row.d3 { padding-left: 3.3rem; }
  .nest-row.d4 { padding-left: 4.5rem; }
  .nest-river {
    font-weight: 700;
    color: #3a3f4d;
  }
  .nest-row.d0 .nest-river,
  .nest-row.d1 .nest-river {
    font-weight: 800;
    color: #1f2330;
  }
  .nest-arrow {
    color: #aeb4c2;
  }
  .nest-dot {
    display: inline-block;
    width: 7px;
    height: 7px;
    border-radius: 50%;
    flex: 0 0 auto;
  }
  .nest-site {
    font-weight: 700;
    color: #1f2330;
    text-decoration: none;
  }
  .nest-site:hover {
    text-decoration: underline;
  }
  .nest-code {
    font-size: 0.6rem;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    font-weight: 700;
    color: #7a82c4;
    background: #f3f4fb;
    border: 1px solid #c5cae9;
    border-radius: 4px;
    padding: 0 0.3rem;
    font-family: var(--mono, ui-monospace, monospace);
  }
  .nest-status {
    font-size: 0.72rem;
    font-weight: 700;
    margin-left: auto;
  }
  .nest-legend {
    margin-top: 0.9rem;
    padding-top: 0.7rem;
    border-top: 1px solid #eef0f4;
