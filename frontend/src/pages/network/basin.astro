    gap: 1.4rem;
    align-items: start;
  }
  @media (max-width: 720px) {
    .basin-nest {
      grid-template-columns: 1fr;
    }
  }
  .nest-tree {
    border: 1px solid var(--rule, #e3e5ec);
    border-radius: 14px;
    padding: 1.1rem 1.25rem;
    background: #fafbfc;
  }
  .nest-kicker {
    font-size: 0.7rem;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: #8a90a2;
    font-weight: 700;
    margin-bottom: 0.7rem;
  }
