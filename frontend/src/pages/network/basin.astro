---
/**
 * The basin (#308/#323) — the watershed points as nested nodes on ONE connected basin, mirroring
 * the Directory "The basin" design: a drainage nesting tree (basin → watershed → site, derived
 * from each node's drainage_path), a cross-site scorecard, and the facility-status "second clock".
 * Two clocks, kept distinct: the site BUILD status (live/onboarding/open — our website) vs the
 * FACILITY status (investigation → confirmed → construction → live — the data center in the
 * ground). Data is the `network` object feed joined with the sites.ts registry. Charts are indigo.
 */
import RankedBarChart from "../../components/charts/RankedBarChart.astro";
import Base from "../../layouts/Base.astro";
import { hasFeed, loadFeed } from "../../lib/bundle";
import type { BasinNetwork, WatershedNode } from "../../lib/feeds";
import { withBase } from "../../lib/site";
import { FACILITY_STATUS_META, facilityStatus, SITES } from "../../lib/sites";

const net = hasFeed("network") ? loadFeed<BasinNetwork>("network") : null;
const nodes: WatershedNode[] = net?.nodes ?? [];

const siteBySlug = new Map(SITES.map((s) => [s.slug, s]));
const nodeHref = (slug: string): string => siteBySlug.get(slug)?.href ?? `/network/${slug}`;
const codenameOf = (slug: string): string | null => siteBySlug.get(slug)?.codename ?? null;

// Build status (our website) — the FIRST clock. Distinct from facility status below.
const STATUS_META: Record<string, { label: string; color: string; dot: string }> = {
  live: { label: "Live", color: "#2e7d32", dot: "#2e7d32" },
  onboarding: { label: "Onboarding", color: "#b46e00", dot: "#b46e00" },
  open: { label: "Open", color: "#5b6172", dot: "#aeb4c2" },
};
const statusOf = (slug: string): { label: string; color: string; dot: string } =>
  STATUS_META[siteBySlug.get(slug)?.status ?? "open"] ?? STATUS_META.open;

// --- the drainage tree: build a trie from each node's drainage_path (reversed: basin → site) ---
interface RiverNode {
  name: string;
  children: Map<string, RiverNode>;
  sites: WatershedNode[];
}
const root: RiverNode = { name: "Western Lake Erie Basin", children: new Map(), sites: [] };
for (const n of nodes) {
  let cur = root;
  for (const river of [...n.drainage_path].reverse()) {
    let next = cur.children.get(river);
    if (!next) {
      next = { name: river, children: new Map(), sites: [] };
      cur.children.set(river, next);
    }
    cur = next;
  }
  cur.sites.push(n); // the site sits at its most-upstream receiving water (path[0])
}
interface TreeRow {
  depth: number;
  kind: "river" | "site";
  name: string;
  slug?: string;
}
const treeRows: TreeRow[] = [];
function walk(node: RiverNode, depth: number): void {
  treeRows.push({ depth, kind: "river", name: node.name });
  for (const s of node.sites) treeRows.push({ depth: depth + 1, kind: "site", name: s.place, slug: s.slug });
  for (const child of node.children.values()) walk(child, depth + 1);
}
walk(root, 0);

// --- scorecard helpers ---
const regimeLabel = (r: string): string => r.replace(/_/g, " ");
const STATUS_TEXT: Record<string, string> = {
  no_receiving_water: "unscreened · no ECHO receiving water",
  no_7q10: "unscreened · ungaged tributary",
  no_design_flow: "unscreened · no design flow",
  not_in_inventory: "unscreened · not in ECHO",
};
const screenText = (n: WatershedNode): string => {
  const s = n.screen;
  if (s.status === "screened" && s.dilution_ratio != null) return `${s.flag} · ${s.dilution_ratio.toFixed(2)}:1`;
  return STATUS_TEXT[s.status] ?? "unscreened";
};
const num = (v: number | null | undefined, d = 1): string => (v == null ? "—" : v.toFixed(d));

// Charts (indigo = data): grid bundled price is the genuine differentiator; mfg LQ the universal base.
const priceData = nodes
  .filter((n) => n.grid.avg_price_cents_kwh != null)
  .map((n) => ({ label: n.place, value: n.grid.avg_price_cents_kwh as number }))
  .sort((a, b) => b.value - a.value);
const mfgData = nodes
  .filter((n) => n.economy.manufacturing_lq != null)
  .map((n) => ({ label: n.place, value: n.economy.manufacturing_lq as number }))
  .sort((a, b) => b.value - a.value);
const screenedCount = nodes.filter((n) => n.screen.status === "screened").length;
---

<Base
  title="The basin — one connected system"
  section="network"
  description="The Maumee watershed points as nested nodes on one basin: sites nest inside watersheds, watersheds inside the basin, all draining to Lake Erie under one TMDL cap — compared across receiving-water regime, grid, economy, toxics, and facility status."
>
  <article class="prose">
    <div class="submit-eyebrow">The Watermark network · the basin</div>
    <h1>How the points nest</h1>
    <p class="section-lead">
      The watershed points are not parallel, independent sites. Every one sits at a point in the
      Maumee drainage — <strong>sites nest inside watersheds, watersheds inside the basin</strong>,
      all draining to Lake Erie under the <strong>same 2023 TMDL phosphorus cap</strong>. A
      cross-reference between two sites isn't a guess about distance; it's an edge in this tree. So a
      data-center load at <em>any</em> node accumulates downstream into one fully-allocated budget.
    </p>
    {net == null && <p class="stub-note">No network feed in this bundle.</p>}
  </article>

  {
    net != null && (
      <>
        <section class="basin-nest" aria-label="The drainage, as a tree">
          <div class="nest-tree">
            <div class="nest-kicker">The drainage, as a tree</div>
            {treeRows.map((row) =>
              row.kind === "river" ? (
                <div class:list={["nest-row", "is-river", `d${row.depth}`]}>
                  <span class="nest-river">{row.name}</span>
                </div>
              ) : (
                <div class:list={["nest-row", "is-site", `d${row.depth}`]}>
                  <span class="nest-arrow">→</span>
                  <span class="nest-dot" style={`background:${statusOf(row.slug ?? "").dot}`} />
                  <a class="nest-site" href={withBase(nodeHref(row.slug ?? ""))}>{row.name}</a>
                  {codenameOf(row.slug ?? "") && <span class="nest-code">{codenameOf(row.slug ?? "")}</span>}
                  <span class="nest-status" style={`color:${statusOf(row.slug ?? "").color}`}>
                    {statusOf(row.slug ?? "").label}
                  </span>
                </div>
              ),
            )}
            <div class="nest-legend">
              <span style="color:#2e7d32"><span class="nest-dot" style="background:#2e7d32" />Live</span>
              <span style="color:#b46e00"><span class="nest-dot" style="background:#b46e00" />Onboarding</span>
              <span style="color:#5b6172"><span class="nest-dot" style="background:#aeb4c2" />Open</span>
            </div>
          </div>

          <div class="nest-notes">
            <div class="nest-note is-accent">
              <div class="nest-note-k">Why nest by watershed</div>
              <p>
                Power meets water at the watershed scale — a data center's draw, discharge, and
                downstream effects are basin facts. Nesting sites by drainage makes a cross-site
                claim (Lima's intake vs. Defiance's) a structural relationship, not a coincidence of
                state lines.
              </p>
            </div>
            <div class="nest-note">
              <div class="nest-note-k">The reference point</div>
              <p>
                <strong>Lima (BOSC)</strong> sits on the Ottawa River, a tributary of the Auglaize.
                It's the only live build — the record grammar every other point inherits as it comes
                online.
              </p>
            </div>
          </div>
        </section>

        <section class="basin-scorecard" aria-label="Cross-site scorecard">
          <div class="scorecard-head">
            <h2>Every point, side by side</h2>
            <span class="two-clocks">Build phase &amp; facility status are two clocks — kept distinct.</span>
          </div>
          <p>
            Ordered upstream &rarr; downstream. The dilution screen is one dimension — only
            <strong>{" "}{screenedCount} of {nodes.length}</strong> are cleanly screenable (the rest
            discharge to ungaged tributaries or carry no ECHO receiving water; the data gap is itself
            a finding).
          </p>
          <div class="scorecard-wrap">
            <table class="scorecard">
              <thead>
                <tr>
                  <th>Node</th>
                  <th>Subtree &rarr; down</th>
                  <th>Receiving-water regime</th>
                  <th>Low-flow screen</th>
                  <th>Serving utility</th>
                  <th>¢/kWh</th>
                  <th>mfg / info LQ</th>
                  <th>Facility status</th>
                </tr>
              </thead>
              <tbody>
                {nodes.map((n) => {
                  const fs = FACILITY_STATUS_META[facilityStatus(n.slug)];
                  return (
                    <tr>
                      <td>
                        <a href={withBase(nodeHref(n.slug))}>{n.place}</a>
                        {codenameOf(n.slug) && <span class="code-tag">{codenameOf(n.slug)}</span>}
                      </td>
                      <td class="dim">{n.subtree} &rarr; {n.downstream}</td>
                      <td>{regimeLabel(n.regime)}</td>
                      <td>
                        <span class:list={["screen", n.screen.status === "screened" ? n.screen.flag : "unscreened"]}>
                          {screenText(n)}
                        </span>
                      </td>
                      <td>{n.grid.holding_company ?? "—"}</td>
                      <td class="mono">{num(n.grid.avg_price_cents_kwh)}</td>
                      <td class="mono">{num(n.economy.manufacturing_lq)} / {num(n.economy.information_lq, 2)}</td>
                      <td>
                        <span class="fac-pill" style={`color:${fs.color};background:${fs.bg}`}>
                          <span class="nest-dot" style={`background:${fs.dot}`} />{fs.label}
                        </span>
                      </td>
                    </tr>
                  );
                })}
              </tbody>
            </table>
          </div>
          <p class="dim two-clocks-note">
            <strong>Two clocks, never conflated.</strong> The build phase (live / onboarding / open,
            the dots in the tree above) tracks <em>our</em> progress assembling the website; facility
            status (investigation → confirmed → construction → live) tracks the data center in the
            ground. A queued site can document a live facility, and a live site one still under
            investigation.
          </p>
        </section>

        <section class="basin-charts">
          <RankedBarChart
            title="The grid is where the nodes differ"
            kicker="Bundled retail price · by serving utility"
            data={priceData}
            unit="¢/kWh"
            source="EIA-861 per-utility bundled full-service price"
          />
          <RankedBarChart
            title="Every node is a manufacturing-concentrated county"
            kicker="Manufacturing location quotient (>1 = over-represented)"
            data={mfgData}
            unit="LQ"
            source="BLS QCEW (county sector share / national)"
          />
        </section>

        <article class="prose">
          <h2>What the network shows</h2>
          <ol>
            <li>
              <strong>Lima is the outlier in exactly one dimension — receiving-water choice.</strong>
              It is the lone screened violation, on a flow-starved tributary. Defiance's mainstem
              dilutes ~6:1; Toledo (22 MGD) and Fort Wayne (74 MGD, the largest) sit on the diluting
              mainstem. Size is irrelevant.
            </li>
            <li>
              <strong>The economic shape is universal.</strong> Every node is manufacturing-heavy
              (mfg LQ &gt; 1) with a near-absent information sector (info LQ &lt; 1) — the
              "load-not-jobs onto a shrinking industrial base" pattern is basin-wide, not a Lima
              quirk.
            </li>
            <li>
              <strong>One shared sink, one shared cap.</strong> All eight drain to {net.sink} under
              one TMDL phosphorus budget. A new load anywhere upstream lands in the same
              fully-allocated basin — the connectivity is the point.
            </li>
          </ol>
          <p class="dim">
            Computed by <code>bosc basin-network</code> over the curated topology + each node's
            committed economy / grid / toxics artifacts and its low-flow screen.
          </p>
        </article>
      </>
    )
  }
</Base>

<style>
