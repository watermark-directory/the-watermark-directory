---
/**
 * OPC scenario explorer — the interactive companion to the Cost chapter, and the native
 * successor to the retired marimo `opc_scenario.py` notebook (the evaluation lives at
 * docs/marimo-integration-investigation.md; the platform consolidated on the Astro
 * frontend, so the notebook was reimplemented as a React island rather than a WASM export).
 *
 * Island-over-SSR: the <noscript> table is the no-JS fallback — the source totals at the
 * source's own 25% convention, from the same `opcScenario` model the island runs.
 */
import OpcScenario from "../../../../components/islands/OpcScenario.tsx";
import ReportShell from "../../../../layouts/ReportShell.astro";
import { hasFeed, loadFeed } from "../../../../lib/bundle";
import type { RecordItem } from "../../../../lib/feeds";
import { fmtUsdFull } from "../../../../lib/money";
import { opcScenarioFromRecords, sourceProgramTotal } from "../../../../lib/opcScenario";
import { withSite, withStory } from "../../../../lib/site";

const records = hasFeed("records") ? loadFeed<RecordItem[]>("records") : [];
const scenario = opcScenarioFromRecords(records);

// SSR fallback: the source figures at the source's own contingency convention (the no-JS
// reader sees the Tetra Tech program total, unmodeled — the island re-prices from there).
const ssrSubs = scenario?.subs ?? [];
const ssrPct = scenario?.sourceContingencyPct ?? 25;
const ssrConstruction = ssrSubs.reduce((a, s) => a + s.constructionSubtotal, 0);
const ssrSource = sourceProgramTotal(ssrSubs);
---

<ReportShell
  title="OPC scenario explorer"
  description="The six Tetra Tech cost estimates for the public roadwork, made manipulable: move the contingency-and-inflation rate and pick intersections to re-derive the modeled program cost from the high-confidence construction subtotals — over the committed record, never editing it."
  eyebrow="Cost · the public roadwork, priced"
  h1="The roadwork estimate, as a knob you can turn"
>
  <Fragment slot="lead">
      <p class="section-lead">
        The public's share of the project arrives as roads — four roundabouts and two
        corridor rebuilds the developer books as a private contribution. The price is set by six Tetra Tech
        <em>Opinion of Probable Project Cost</em> estimates extracted from the PAAC
        production. Each total is the high-confidence <strong>construction subtotal</strong>
        carried up by a <strong>contingency + inflation</strong> rate (the source applies 25%).
        Turn the rate, pick intersections, and watch the modeled program cost re-derive —
        over the committed estimate, which it reads but never edits. Full record:
        <a href={withSite("/site/records/opc/")}>the cost estimates (OPC) →</a>;
        the narrative: <a href={withStory("/cost")}>follow the money →</a>.
      </p>
  </Fragment>

    {
      scenario ? (
        <OpcScenario client:only="react" scenario={scenario} />
      ) : (
        <article class="prose">
          <p>
            The OPC summary estimate isn't present in this content bundle. Run <code>bosc export</code>{" "}
            with the AEDG extractions to populate the records feed.
          </p>
        </article>
      )
    }

    {/* No-JS fallback: the source figures at the source's own convention. Direct template
        HTML with only the `.map()` nested — wrapping the whole table in a `{scenario && …}`
        expression makes the compiler parse the table's `</td>` as JSX and break, so the
        frontmatter precomputes safe `ssr*` values (empty when no bundle) instead. */}
    <noscript>
      <article class="prose">
        <h2>The six estimates, at the source's {ssrPct}% convention</h2>
        <table>
          <thead>
            <tr>
              <th>Intersection</th>
              <th>Construction subtotal</th>
              <th>Total (at {ssrPct}%)</th>
            </tr>
          </thead>
          <tbody>
            {ssrSubs.map((s) => (
              <tr>
                <td>{s.name}</td>
                <td>{fmtUsdFull(s.constructionSubtotal)}</td>
                <td>{fmtUsdFull(s.sourceTotal)}</td>
              </tr>
            ))}
            <tr>
              <td><strong>Program</strong></td>
              <td><strong>{fmtUsdFull(ssrConstruction)}</strong></td>
              <td><strong>{fmtUsdFull(ssrSource)}</strong></td>
            </tr>
          </tbody>
        </table>
        <p>
          Construction subtotals are <code>[verified]</code>; the totals are those subtotals at the
          {ssrPct}% contingency-and-inflation convention. Enable JavaScript to turn the rate and pick
          intersections.
        </p>
      </article>
    </noscript>
</ReportShell>
