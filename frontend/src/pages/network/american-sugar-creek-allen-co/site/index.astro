---
import Base from "../../../../layouts/Base.astro";
import { hasFeed, loadFeed, loadManifest } from "../../../../lib/bundle";
import { type DocumentCollectionItem, type MeetingItem, type TimelineEntry } from "../../../../lib/feeds";
import { REFERENCE } from "../../../../lib/reference";
import { withBase, siteUrl } from "../../../../lib/site";

const manifest = loadManifest();
const byName = new Map(manifest.feeds.map((f) => [f.name, f]));
const count = (n: string): number => byName.get(n)?.count ?? 0;
const num = (n: number): string => n.toLocaleString("en-US");

const documents = hasFeed("documents") ? loadFeed<DocumentCollectionItem[]>("documents") : [];
const nFiles = documents.reduce((a, c) => a + c.entries.length, 0);
const timeline = hasFeed("timeline") ? loadFeed<TimelineEntry[]>("timeline") : [];
const meetings = hasFeed("meetings") ? loadFeed<MeetingItem[]>("meetings") : [];

// Door ids match the section's nav anchors so the rail (shown on leaf pages) resolves.
const doors = [
  { id: "documents", kind: "Catalog", href: siteUrl("/site/documents/"), count: num(nFiles), title: "Documents", desc: "Source-document catalog, grouped by collection — names, types, sizes, LFS status.", note: `${documents.length} collections` },
  { id: "records", kind: "Structured records", href: siteUrl("/site/records/"), count: num(count("records")), title: "Records", desc: "Structured record groups read from the corpus — deeds, permits, filings, plans, cost estimates.", note: "the per-record unit" },
  { id: "timeline", kind: "Chronology", href: siteUrl("/timeline"), count: num(timeline.length), title: "Timeline", desc: "Events in sequence — the spine the story pays off into.", note: "cause → consequence" },
  { id: "exhibits", kind: "Curated excerpts", href: siteUrl("/site/exhibits"), count: num(count("exhibits")), title: "Exhibits", desc: "Curated, citable slices of the source record.", note: "downloadable" },
  { id: "people", kind: "Profiles", href: siteUrl("/site/people/"), count: num(count("people")), title: "People", desc: "Individual profiles — roles, affiliations, aliases, sources.", note: "the human detail" },
  { id: "places", kind: "Geography", href: siteUrl("/site/places/"), count: num(count("places")), title: "Places & parcels", desc: "The campus, the corridor sites, and the parcels the record turns on.", note: "geographic detail" },
  { id: "legal", kind: "Filings & analysis", href: siteUrl("/site/legal"), count: num(meetings.length), title: "Legal history", desc: "Meeting summaries, PRR & mandamus, and Select-Committee testimony.", note: "filings & analysis" },
  { id: "reference", kind: "External data", href: siteUrl("/site/reference/"), count: num(REFERENCE.length), title: "Reference datasets", desc: "Authoritative external datasets, each documented with its provenance and gaps.", note: "EPA · USGS · BLS …" },
  { id: "watershed", kind: "Hydrology & toxics", href: siteUrl("/watershed/"), count: "live", title: "The watershed", desc: "Hydrology dashboards, the Maumee map, before/during/after imagery, and RSEI toxics — the basin the campus sits in.", note: "USGS · NOAA · EPA" },
];
---

<Base title="The corpus" section="site" rail={false}>
  <div class="hub">
    <div class="hub-head">
      <div>
        <div class="hub-eyebrow">Section · the corpus</div>
        <h1>The source record</h1>
        <p class="hub-lead">
          Everything the project is built from — documents, the structured records
          read from them, the timeline, people &amp; places, the legal history,
          external reference datasets, and the watershed data.
        </p>
      </div>
      <span class="hub-count">{num(nFiles)} source files indexed</span>
    </div>
    <div class="hub-grid">
      {
        doors.map((d) => (
          <a class="hub-door" id={d.id} href={withBase(d.href)}>
            <div class="hub-door-top">
              <span class="hub-door-kind">{d.kind}</span>
              <span class="hub-door-count">{d.count}</span>
            </div>
            <div class="hub-door-title">{d.title}</div>
            <div class="hub-door-desc">{d.desc}</div>
            <div class="hub-door-foot">
              <span class="hub-door-browse">Browse</span>
              <span class="hub-door-note">{d.note}</span>
              <span class="hub-door-arrow" aria-hidden="true">›</span>
            </div>
          </a>
        ))
      }
    </div>
  </div>
</Base>
