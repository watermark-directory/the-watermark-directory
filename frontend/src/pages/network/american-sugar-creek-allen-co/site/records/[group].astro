---
import type { GetStaticPaths } from "astro";
import Base from "../../../../../layouts/Base.astro";
import BackLink from "../../../../../components/BackLink.astro";
import RecordBlock from "../../../../../components/RecordBlock.astro";
import { hasFeed, loadFeed } from "../../../../../lib/bundle";
import type { RecordItem } from "../../../../../lib/feeds";
import { groupLabel, groupsOf } from "../../../../../lib/records";
import { recordToBlock } from "../../../../../lib/recordBlock";
import { withSite } from "../../../../../lib/site";

export const getStaticPaths: GetStaticPaths = () => {
  const records = hasFeed("records") ? loadFeed<RecordItem[]>("records") : [];
  return groupsOf(records).map((group) => ({
    params: { group },
    props: { records: records.filter((r) => r.group === group) },
  }));
};

interface Props {
  records: RecordItem[];
}
const { group } = Astro.params;
const { records } = Astro.props;
const label = groupLabel(String(group));
const anchors = records.filter((r) => recordToBlock(r).seenIn).length;
---

<Base title={label} section="site">
  <article class="prose">
    <BackLink href={withSite("/site/records/")} label="Records" />
    <h1>{label}</h1>
    <p class="section-lead">
      {records.length} record(s) — open one for its full reading and, where it's a story
      anchor, the teardown.
      {anchors > 0 && ` ${anchors} of these is a story anchor — its seen-in-the-story badge links back to the chapter that unpacked it.`}
    </p>
  </article>
  <div class="rb-list">
    {records.map((r) => <RecordBlock record={recordToBlock(r)} density="compact" />)}
  </div>
</Base>
