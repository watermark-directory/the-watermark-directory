---
import { getCollection, render } from "astro:content";
import Base from "../../../../layouts/Base.astro";
import { bySlug } from "../../../../lib/narrative";
import { getSection } from "../../../../lib/nav";
import { withBase } from "../../../../lib/site";

export async function getStaticPaths() {
  // Only the curated narrative set (lib/narrative.ts) is published; the glob may
  // load other docs/ markdown, which we drop here.
  const entries = await getCollection("narrative", (e) => bySlug.has(e.id));
  return entries.map((entry) => ({ params: { slug: entry.id }, props: { entry } }));
}

const { entry } = Astro.props;
const doc = bySlug.get(entry.id)!;
const section = getSection(doc.section);
const { Content, headings } = await render(entry);
// The rail is this essay's own headings (Astro slugs each one as an `id`).
const toc = headings.filter((h) => h.depth === 2).map((h) => ({ anchor: h.slug, label: h.text }));
---

<Base title={doc.title} section={doc.section} description={doc.blurb} toc={toc} ogType="article">
  <article class="prose">
    <p><a href={withBase(section.href)}>← {section.label}</a> · <a href={withBase("/network/american-sugar-creek-allen-co/docs/")}>All narrative</a></p>
    <Content />
  </article>
</Base>
