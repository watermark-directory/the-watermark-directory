---
import CorridorMap from "../../../../components/islands/CorridorMap.tsx";
import Base from "../../../../layouts/Base.astro";
import { mergedGeo } from "../../../../lib/geo";
import { layerLabel, layersPresent, type GeoFeature } from "../../../../lib/geoStyle";
import { withBase } from "../../../../lib/site";

// Build-time: the same merged feed the island fetches, used here to server-render
// the legend + feature table — the no-JS fallback and a plain data view.
const fc = mergedGeo();
const features = fc.features as GeoFeature[];
const present = layersPresent(features);

const stripHtml = (s: string | undefined): string =>
  (s ?? "").replace(/<[^>]+>/g, " ").replace(/\s+/g, " ").trim();

const legend = present.map((layer) => {
  const inLayer = features.filter((f) => f.properties.layer === layer);
  return { layer, color: inLayer[0]?.properties.color ?? "#787882", count: inLayer.length };
});
const mapSrc = withBase("/feeds/geo/corridor-map.geojson");
---

<Base title="Watershed & corridor map" section="watershed">
  <article class="prose">
    <p><a href={withBase("/network/american-sugar-creek-allen-co/watershed/")}>← The Maumee watershed</a></p>
    <h1>Watershed &amp; corridor map</h1>
    <p class="section-lead">
      The USGS WBD watershed boundary (the Pike Run subwatershed within the Ottawa
      River watershed) framing the campus, the JSMC parcels, the North Cole Street
      corridor and roadwork, FEMA floodway/floodplain, WWTP discharge points, and the
      RSEI toxic-release overlay (off by default). Pan/zoom, toggle layers, switch
      basemaps (street, Esri aerial, dated 2014/2024 Wayback aerials), and click a
      feature for its record. {features.length} features across {present.length} layers.
      For the dated before/during/after view, see the
      <a href={withBase("/network/american-sugar-creek-allen-co/watershed/imagery")}>imagery slider</a>.
    </p>

    <div class="deck-surface">
      <CorridorMap client:only="react" src={mapSrc} />
      <noscript>
        <div class="deck-loading">
          Interactive map needs JavaScript — the legend and feature list below
          carry the same data.
        </div>
      </noscript>
    </div>

    <h2>Legend</h2>
    <ul class="legend">
      {
        legend.map((l) => (
          <li>
            <span class="swatch" style={`background:${l.color}`} />
            {layerLabel(l.layer)} <span class="card-meta">({l.count})</span>
          </li>
        ))
      }
    </ul>

    <h2>Features</h2>
  </article>
  <div class="dtable">
    <table>
      <thead>
        <tr>
          <th>Layer</th>
          <th>Feature</th>
        </tr>
      </thead>
      <tbody>
        {
          features.map((f) => (
            <tr>
              <td>
                <span class="dswatch" style={`background:${legend.find((l) => l.layer === f.properties.layer)?.color ?? "#787882"}`} />
                {layerLabel(f.properties.layer)}
              </td>
              <td>{stripHtml(f.properties.label)}</td>
            </tr>
          ))
        }
      </tbody>
    </table>
  </div>
</Base>
