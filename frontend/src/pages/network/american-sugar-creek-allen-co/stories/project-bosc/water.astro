---
/**
 * Guided walk — Chapter 4 of 6: "What it does to the water". The verified anchor
 * is the NPDES 7Q10 teardown (the receiving streams are already near-undiluted at
 * design low flow). The signature interaction is the dilution screen (#222) — a
 * `client:only` island (`DilutionScreen`) over an SSR seasonal table: scrub the
 * cooling draw / season and watch the net consumptive draw cross the Ottawa's low
 * flow (~24× annual, ~3× summer, dry at 1Q10). The draw model is feed-sourced
 * (`buildDilution`, no fork); the ratio is a reservoir-buffered worst-case bound,
 * carried as [inference] — not a record read. Pays off into the live dashboard.
 *
 * The chapter then follows the water past the model into the record: WHY the draw
 * is [inference] and not [verified] (the cooling flowrate was claimed and granted
 * as a trade secret, eDoc 3859883); where the cooling water GOES (the blowdown →
 * American Bath WWTP keystone, Res #679-24 / #137-26, dual forcemains); and the
 * GROUND it all sits on (≈309 ac graded to Pike Run, the 401 isolated-wetland
 * fills, the Level-2 delineation Ohio EPA returned incomplete as grading ran).
 */
import Base from "../../../../../layouts/Base.astro";
import PathWayfinding from "../../../../../components/PathWayfinding.astro";
import RecordTeardown from "../../../../../components/RecordTeardown.astro";
import DilutionScreen from "../../../../../components/islands/DilutionScreen.tsx";
import { NPDES_TEARDOWN } from "../../../../../lib/teardowns";
import { buildDilution, dilutionMultiple } from "../../../../../lib/dilution";
import { chapterByStep, WALK_INDEX_HREF, WALK_TOTAL, walkHref } from "../../../../../lib/walk";
import { withSite } from "../../../../../lib/site";

const STEP = 4;
const prev = chapterByStep(STEP - 1);
const next = chapterByStep(STEP + 1);

// The Water chapter's data — feed-sourced. Two stories the corpus keeps separate:
// the [verified] discharge finding (the river is already effluent) and the
// [inference] consumptive-loss scale (what the campus takes out of the basin).
const dilution = buildDilution();
const fmtMult = (m: number): string =>
  Number.isFinite(m) ? `${m >= 10 ? Math.round(m) : m.toFixed(1)}×` : "∞ (dry)";
const effluentCfs = dilution.discharge.wwtpCfs + dilution.discharge.campusFm2Cfs;
const naturalBarPct = Math.max(Math.round((dilution.discharge.naturalCfs / effluentCfs) * 100), 2);
---

<Base
  title="What it does to the water — Chapter 4"
  section="story"
  description="A data center cools itself with water. Read what the receiving streams can spare — Ohio EPA already wrote it down, in the low flows it uses to permit every discharge."
>
  <div class="walk-chapter-page">
    <PathWayfinding step={STEP} />

    <div class="walk-chapter-eyebrow">Chapter {STEP} of {WALK_TOTAL} · the guided walk</div>
    <h1 class="walk-chapter-h1">What it does to the water</h1>

    <div class="walk-prose">
      <p>
        A data center cools itself with water, and the water it gives back is not
        the water it takes — evaporation is a permanent loss to the basin. Before
        asking what the campus removes, read what the receiving streams can spare.
        Ohio EPA already wrote it down, in the low-flow number it uses to set the
        limits on every discharge.
      </p>
    </div>

    <RecordTeardown record={NPDES_TEARDOWN} layout="split" />

    <section class="walk-interactive" aria-label="The river is already effluent">
      <h2 class="walk-explore-h">The river is already effluent</h2>
      <div class="dil">
        <div class="dil-head">
          <strong>What the campus discharges into</strong>
          <span class="dil-tag dil-tag--verified" title="Read directly from the Ohio EPA NPDES fact sheets (the feed's assimilative rows) and the cited water balance.">[verified] · fact-sheet discharge</span>
        </div>
        <p class="dil-framing">
          Before the campus takes a drop, read what the river already carries. At design low flow the three
          county WWTPs discharge <strong>{dilution.discharge.wwtpCfs} cfs</strong> of treated effluent into
          streams whose <em>natural</em> low flow totals just <strong>{dilution.discharge.naturalCfs} cfs</strong> —
          and the campus adds its own routed <strong>{dilution.discharge.campusFm2Cfs} cfs</strong> FM-2 discharge.
          The Ottawa leaving Lima runs <strong>{dilution.discharge.effluentPct}% treated effluent</strong>, before
          counting a drop of what the campus evaporates.
        </p>
        <div class="dil-bars">
          <div class="dil-barrow">
            <div class="dil-barlabel">Streams · natural low flow<span class="dil-barnum">{dilution.discharge.naturalCfs.toFixed(2)} cfs</span></div>
            <div class="dil-track"><div class="dil-bar dil-bar--river" style={`width:${naturalBarPct}%`}></div></div>
          </div>
          <div class="dil-barrow">
            <div class="dil-barlabel">Treated effluent · WWTP + campus<span class="dil-barnum">{effluentCfs.toFixed(2)} cfs</span></div>
            <div class="dil-track"><div class="dil-bar dil-bar--draw" style="width:100%"></div></div>
          </div>
        </div>
        <table class="dtable">
          <caption>The three county WWTP discharges vs their receiving streams' cited 7Q10 — each already runs undiluted at design low flow.</caption>
          <thead><tr><th scope="col">Discharger</th><th scope="col">Receiving stream</th><th scope="col">Discharge</th><th scope="col">7Q10</th></tr></thead>
          <tbody>
            {
              dilution.discharge.rows.map((r) => (
                <tr>
                  <td>{r.discharger}</td>
                  <td>{r.receiving}</td>
                  <td>{r.dischargeCfs.toFixed(2)} cfs</td>
                  <td>{r.lowFlowCfs.toFixed(2)} cfs</td>
                </tr>
              ))
            }
          </tbody>
        </table>
        <p class="dil-cite">⌖ {dilution.discharge.cite}</p>
      </div>
    </section>

    <div class="walk-prose">
      <p>
        That is what the campus discharges <em>into</em>. It also takes water <em>out</em> of the basin:
        a data center cools by evaporation, and the water it gives back is not the water it takes. But
        read the next comparison carefully — it is a <strong>worst-case bound</strong>, not the operating
        reality. Lima doesn't pump from the river at low flow; it lives off five off-stream reservoirs
        filled at high flow. So setting the campus's net loss against the Ottawa's low flow measures the
        <em>scale</em> of the basin stress, not a withdrawal from the river — the honest tag is
        <code>[inference]</code>, not <code>[verified]</code>.
      </p>
      <p>
        There is a second reason the draw is modeled rather than read. The one number that would
        settle it — the cooling system's design flowrate — was claimed by the developer as a trade
        secret, and Ohio EPA granted the claim on <strong>2025-10-08</strong> (eDoc 3859883). The
        justification is unusually candid about the stakes: the air permit, it argues, is “the only
        public document that requests the size” of the equipment, so “by preventing this information
        from becoming public via the air permitting process, the facility has taken a significant
        step to ensure the confidentiality of this information.” The flowrate is not missing by
        accident — the single public path to it was identified and closed. So we model the draw, tag
        it <code>[inference]</code>, and can say precisely why the <code>[verified]</code> figure
        does not exist.
      </p>
      <p>
        And because the screen is built from live gauges, you don't have to take a static number on
        faith — the hydrology dashboard re-runs it against the Ottawa's current flow from USGS on every
        build.
      </p>
    </div>

    <section class="walk-interactive" aria-label="What the campus takes out of the basin">
      <h2 class="walk-explore-h">What the campus takes out of the basin</h2>
      <div class="dil-surface">
        <DilutionScreen client:only="react" data={dilution} />
        <noscript>
          <div class="dil-noscript">
            The interactive screen needs JavaScript — the seasonal table below is
            the same data.
          </div>
        </noscript>
      </div>

      <table class="dtable dil-table">
        <caption>
          Net consumptive loss at full buildout (<strong>{dilution.drawAtBuildoutCfs.toFixed(2)} cfs</strong>,
          from {dilution.maxCoolingMgd.toFixed(2)} MGD cooling × {dilution.consumptiveFraction} consumptive) as a
          scale against the Ottawa's low-flow floors. The campus draws from reservoirs, not the river — a worst-case
          bound, <code>[inference]</code>.
        </caption>
        <thead>
          <tr><th scope="col">Season</th><th scope="col">Ottawa low flow</th><th scope="col">Loss ÷ low flow</th><th scope="col">Source</th></tr>
        </thead>
        <tbody>
          {
            dilution.floors.map((f) => (
              <tr>
                <td>{f.label}</td>
                <td>{f.cfs.toFixed(2)} cfs</td>
                <td><strong>{fmtMult(dilutionMultiple(dilution.drawAtBuildoutCfs, f.cfs))}</strong></td>
                <td class="dil-td-cite">{f.cite}</td>
              </tr>
            ))
          }
        </tbody>
      </table>
    </section>

    <div class="walk-prose">
      <p>
        Now weigh that against what the proponents say. AEDG's own FAQ assures that
        data centers “increasingly use closed-loop cooling systems that recirculate
        water” — but the air permit you read in the last chapter fixes
        <strong>36 evaporative cooling towers</strong>, and evaporative towers lose
        water to the sky by design. Google's “120% water replenishment” pledge is
        real, but it's <strong>global and offsite</strong> — it says nothing about the
        Ottawa. The tower count is <code>[verified]</code>; the consumptive draw above
        is <code>[inference]</code>; the claim that this “reduces water use” here is
        neither.
      </p>
    </div>

    <section class="walk-interactive" aria-label="Where the cooling water goes">
      <h2 class="walk-explore-h">Where the water goes when it's done cooling</h2>
      <div class="walk-prose">
        <p>
          The water an evaporative tower doesn't lose to the sky comes back dirtier than it left.
          The towers concentrate whatever is in the make-up water — dissolved salts, treatment
          chemicals — into a waste stream called <em>blowdown</em>, and that stream has to go
          somewhere. For Project BOSC, the somewhere is on the record. In August 2024 — more than a
          year before the public knew whose data center this was — the County Commissioners approved
          <strong>Resolution #679-24</strong>: a <strong>$47,600</strong> task order to MS
          Consultants for a “WWTP Data Center Flows Treatment Evaluation,” studying the campus
          blowdown's demands, its flows over a typical year, and its water-quality parameters for
          storage and treatment at the <strong>American Bath WWTP</strong> — the County to gather
          the figures from “the developer and data center manufacturer.” It is the first
          primary-source document tying the cooling system to the public sewer.
          <code>[verified]</code>, from the produced record.
        </p>
        <p>
          What that study scopes, the build-out commits to: a dedicated BOSC pump station and
          <strong>dual forcemains</strong> — a 10-inch line to the American Bath plant and a 16-inch
          line to Lima's existing 78-inch interceptor, sized for <strong>2.5 MGD</strong> peak (Res
          #137-26). The campus's waste heat leaves the site as water, and the public sewer system is
          being enlarged to receive it — the cost of that enlargement is the next chapter's
          business.
        </p>
      </div>
    </section>

    <section class="walk-interactive" aria-label="The site and its headwaters">
      <h2 class="walk-explore-h">It starts in a soybean field</h2>
      <div class="walk-prose">
        <p>
          All of it lands on ground that drains the wrong way for it. The campus is roughly
          <strong>309 acres</strong> of former CAUV farmland — the construction-stormwater coverage
          (facility 2GC08468, Turner Construction) was modified to 309.2 acres in June 2026 — graded
          to discharge into <strong>Pike Run</strong>, a headwater tributary of the same Ottawa
          system the 7Q10 above describes. Two on-site isolated wetlands, <strong>0.33 acres</strong>
          of Category-1 (0.29 forested, 0.04 not), were authorized for fill on 2025-08-12, the loss
          offset by credits bought at the Pearson Metropark mitigation bank a county away (eDoc
          3788677).
        </p>
        <p>
          A broader fill across the site's <strong>358-acre</strong> wetland delineation went
          differently. The developer applied for it on <strong>2025-12-09</strong> — the day after
          the first erosion-control inspection recorded clearing and mass grading already underway —
          and Ohio EPA returned the application <strong>incomplete</strong> two weeks later, for
          missing an analysis of practicable on-site alternatives (eDoc 3949585). The corpus doesn't
          show how that one resolved. What it shows is the order: the earth was moving before the
          wider wetland question was answered. <em>Analysis of the produced record, not a legal
          conclusion.</em>
        </p>
      </div>
    </section>

    <h2 class="walk-explore-h">Explore this in the library</h2>
    <div class="doors">
      <a class="door" href={withSite("/watershed/hydrology")}>
        <span class="door-label">Live hydrology dashboard</span>
        <span class="door-blurb">The screen, re-run against the Ottawa's current USGS flow.</span>
      </a>
      <a class="door" href={withSite("/watershed/map")}>
        <span class="door-label">Watershed map</span>
        <span class="door-blurb">The WWTP outfalls and the streams they discharge to.</span>
      </a>
      <a class="door" href={withSite("/docs/hydrology")}>
        <span class="door-label">The hydrology write-up</span>
        <span class="door-blurb">The full Tier-0 water balance and the assimilative-capacity screen.</span>
      </a>
      <a class="door" href={withSite("/site/legal/")}>
        <span class="door-label">The sanitary build-out</span>
        <span class="door-blurb">Resolution #679-24, the blowdown-treatment study, and the BOSC forcemains to the American Bath WWTP.</span>
      </a>
      <a class="door" href={withSite("/site/records/")}>
        <span class="door-label">The site &amp; wetland permits</span>
        <span class="door-blurb">The 401 isolated-wetland authorizations, the stormwater coverage, and the discharge to Pike Run.</span>
      </a>
    </div>

    <nav class="walk-nav" aria-label="Chapter navigation">
      {
        prev?.live ? (
          <a class="walk-nav-link walk-nav-prev" href={walkHref(prev.slug)}>← {prev.step}. {prev.title}</a>
        ) : prev ? (
          <span class="walk-nav-link walk-nav-prev is-disabled" title="Drafting">← {prev.step}. {prev.title}</span>
        ) : (
          <span></span>
        )
      }
      <a class="walk-nav-leave" href={WALK_INDEX_HREF}>All chapters</a>
      {
        next?.live ? (
          <a class="walk-nav-link walk-nav-next" href={walkHref(next.slug)}>{next.step}. {next.title} →</a>
        ) : next ? (
          <span class="walk-nav-link walk-nav-next is-disabled" title="Drafting">{next.step}. {next.title} →</span>
        ) : (
          <span></span>
        )
      }
    </nav>
  </div>
</Base>
