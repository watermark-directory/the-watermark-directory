---
/**
 * The BOSC network hub (#304) — an overview of the watershed-point sites. Lima is the live
 * reference build; the basin sites link to their coming-soon page. The switcher in the
 * topbar is the primary entry; this is the section landing the registry resolves to.
 */
import Base from "../../layouts/Base.astro";
import { SITES, siteBadge } from "../../lib/sites";
import { withBase } from "../../lib/site";

const statusLabel: Record<string, string> = {
  live: "Live",
  onboarding: "Onboarding",
  open: "Open",
};
---

<Base
  title="The BOSC network"
  section="network"
  description="Data-center development across Ohio's Maumee watershed, point by point — Lima is the reference build; the basin sites come online incrementally."
>
  <article class="prose">
    <div class="submit-eyebrow">The BOSC network</div>
    <h1>One platform, watershed point by watershed point</h1>
    <p class="section-lead">
      Project BOSC began as one campus on the Ottawa River in Lima. The same record grammar —
      provenance-first, inference labeled, redactions shown — generalizes across the Maumee basin,
      where the data-center build-out meets the watershed. <strong>Lima is the live reference build;</strong>
      the basin sites are coming online. Each is a section of one platform, cross-linked for real.
    </p>
  </article>

  <div class="netgrid">
    {
      SITES.map((s) => (
        <a class:list={["netgrid-card", { "is-live": s.selectable, "is-soon": !s.selectable }]} href={withBase(s.href)}>
          <span class:list={["netgrid-badge", { "has-codename": Boolean(s.codename) }]}>{siteBadge(s)}</span>
          <span class="netgrid-body">
            <span class="netgrid-place">
              {s.codename && <span class="netgrid-codename">{s.codename}</span>}
              {s.place}
            </span>
            <span class="netgrid-basin">{s.basin}</span>
          </span>
          <span class="netgrid-meta">
            <span class:list={["netgrid-status", `is-${s.status}`]}>{statusLabel[s.status]}</span>
            <span class="netgrid-go">{s.selectable ? "Enter the site ›" : s.issue ? `Coming soon · #${s.issue}` : "Coming soon"}</span>
          </span>
        </a>
      ))
    }
  </div>
</Base>
