---
import { selectableSitePaths } from "../../../../lib/sites";
export const getStaticPaths = selectableSitePaths;
import Base from "../../../../layouts/Base.astro";
import FigureStat from "../../../../components/FigureStat.astro";
import BulletChart from "../../../../components/charts/BulletChart.astro";
import { hasFeed, loadFeed } from "../../../../lib/bundle";
import type { ProvenancedValue, ScenarioResult } from "../../../../lib/feeds";
import type { FigureStatData } from "../../../../lib/viz";
import { withSite } from "../../../../lib/site";

const scenarios = hasFeed("hydrology-scenarios")
  ? loadFeed<ScenarioResult[]>("hydrology-scenarios")
  : [];

const numOf = (v: ProvenancedValue): string => (v.value == null ? "—" : v.value.toLocaleString("en-US"));
// document/connector-sourced values are grounded; assumption/derived are inferred.
const grounded = (v: ProvenancedValue): boolean =>
  v.source === "document" || v.source === "connector" || v.source === "reference";
const fmt = (v: ProvenancedValue): string => `${numOf(v)}${v.unit ? ` ${v.unit}` : ""}`;

/** Map a provenanced metric onto the unified figure/stat treatment. */
const toStat = (label: string, v: ProvenancedValue, neg?: boolean): FigureStatData => ({
  label,
  value: numOf(v),
  unit: v.unit ?? undefined,
  evidence: grounded(v) ? "verified" : "inference",
  basis: grounded(v) ? "grounded" : "modeled",
  sub: v.citation ?? v.source ?? undefined,
  warn: neg,
});

// Headline screen (#306): the worst-case scenario by *modeled* consumptive draw — picked
// from the data, not by name — against the river's grounded 7Q10 design low flow. The
// bullet keeps each row's own evidence register: the draw is inferred (amber), the design
// low flow is document-grounded (verified). Drawn straight from the feed; no fork.
const worst =
  scenarios.length > 0
    ? scenarios.reduce((a, b) => ((b.consumptive_loss.value ?? 0) > (a.consumptive_loss.value ?? 0) ? b : a))
    : null;
const drawV = worst?.consumptive_loss ?? null;
const lowV = worst?.ottawa_7q10 ?? null;
const showScreen = worst != null && (drawV?.value ?? 0) > 0 && (lowV?.value ?? 0) > 0;
const drawRatio = showScreen ? Math.round((drawV!.value as number) / (lowV!.value as number)) : 0;
---

<Base title="Hydrology" section="watershed">
  <article class="prose">
    <h1>Hydrology — water balance</h1>
    <p class="section-lead">
      Each scenario screens the Ottawa River's low-flow capacity against the
      campus's consumptive cooling draw: live flow minus consumptive loss against
      the 7Q10 design low flow, and the assimilative headroom that remains. Live
      gauge and permit figures are <strong>grounded</strong>; scenario draws are
      labelled assumptions.
    </p>
    <p class="card-meta">
      A written walk-through of this screen — including the newly document-sourced
      sanitary figures — is in the
      <a href={withSite("/site/legal/water-balance-screen")}>water-balance assimilative screen</a> memo.
    </p>

    {
      showScreen && drawV && lowV && worst && (
        <BulletChart
          kicker="Bullet · draw vs design low flow"
          title={`At the 7Q10 design low flow, the ${worst.scenario.name} cooling draw dwarfs the river`}
          scaleLabel="scale · cubic feet per second"
          unit="cfs"
          rows={[
            {
              label: `Consumptive draw · ${worst.scenario.name}`,
              value: drawV.value as number,
              fill: "#9a6a14",
              evidence: grounded(drawV) ? "verified" : "inference",
              evidenceNote: drawV.citation ?? drawV.source ?? undefined,
            },
            {
              label: "Ottawa 7Q10 design low flow",
              value: lowV.value as number,
              evidence: grounded(lowV) ? "verified" : "inference",
              evidenceNote: lowV.citation ?? lowV.source ?? undefined,
            },
          ]}
          note={`The modeled ${worst.scenario.name} cooling draw (${fmt(drawV)}) is about ${drawRatio}× the Ottawa's 7Q10 design low flow (${fmt(lowV)}) — the drought flow Ohio writes discharge permits at. Live flow today (${fmt(worst.ottawa_live)}) is far higher, but the screen is written for the dry floor.`}
        />
      )
    }

    {scenarios.length === 0 && <p class="stub-note">No hydrology scenarios have been modeled yet.</p>}

    {
      scenarios.map((s) => {
        // The three genuinely-scalar provenanced metrics.
        const stats: FigureStatData[] = [
          toStat("Consumptive loss", s.consumptive_loss),
          toStat("Ottawa 7Q10", s.ottawa_7q10),
          toStat("Ottawa live flow", s.ottawa_live),
        ];
        // `assimilative` is a per-discharger array, not a scalar: surface the binding
        // (worst-diluted) reach as the headline, carrying its own cited provenance.
        const assim = s.assimilative ?? [];
        const binding =
          assim.length > 0 ? assim.reduce((a, b) => (b.dilution_ratio < a.dilution_ratio ? b : a)) : null;
        if (binding) {
          stats.push({
            label: "Binding dilution",
            value: `${binding.dilution_ratio.toFixed(2)}:1`,
            evidence: grounded(binding.design_low_flow) ? "verified" : "inference",
            basis: grounded(binding.design_low_flow) ? "grounded" : "modeled",
            sub: `${binding.discharger} → ${binding.receiving_water}`,
            warn: binding.flag !== "ok",
          });
        }
        const violations = assim.filter((r) => r.flag === "violation").length;
        return (
          <div class="scenario">
            <h2>{s.scenario.name}</h2>
            {s.scenario.description && <p class="card-meta">{s.scenario.description}</p>}
            <p class="card-meta">
              Cooling demand: {fmt(s.scenario.cooling_demand)} · consumptive fraction{" "}
              {fmt(s.scenario.consumptive_fraction)}
            </p>
            <div class="fs-grid">
              {stats.map((st) => (
                <FigureStat stat={st} size="lg" />
              ))}
            </div>
            {assim.length > 0 && (
              <p class="card-meta">
                Assimilative screen · {violations} of {assim.length} receiving reaches fail the dilution
                band at design low flow ({assim.map((r) => `${r.discharger} ${r.dilution_ratio.toFixed(2)}:1`).join(" · ")}).
                A screening band, not a permit determination.
              </p>
            )}
            {s.balance.warnings.length > 0 && (
              <>
                <p class="card-meta">
                  Tier-0 water balance · {s.balance.nodes.length} nodes · modeling caveats:
                </p>
                <ul class="hydro-caveats">
                  {s.balance.warnings.map((w) => (
                    <li>{w}</li>
                  ))}
                </ul>
              </>
            )}
          </div>
        );
      })
    }
  </article>
</Base>

<style>
  .hydro-caveats { margin: 6px 0 0; padding-left: 1.1rem; }
  .hydro-caveats li { font-size: 0.85rem; color: var(--bosc-muted); line-height: 1.5; margin-top: 4px; }
</style>
