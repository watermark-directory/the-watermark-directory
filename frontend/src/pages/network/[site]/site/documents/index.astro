---
import { selectableSitePaths } from "../../../../../lib/sites";
export const getStaticPaths = selectableSitePaths;
import Base from "../../../../../layouts/Base.astro";
import { hasFeed, loadFeed } from "../../../../../lib/bundle";
import { docAccess } from "../../../../../lib/docView";
import { formatBytes, type DocumentCollectionItem } from "../../../../../lib/feeds";
import { withSite } from "../../../../../lib/site";

const collections = hasFeed("documents") ? loadFeed<DocumentCollectionItem[]>("documents") : [];

// Storage/access chip per row: published (public + viewable), dev-only (bytes present,
// gated in prod), or LFS pointer (bytes absent). The viewer page renders any of them.
const ACCESS_CHIP = {
  published: { cls: "dchip--present", label: "● published" },
  "dev-only": { cls: "dchip--devonly", label: "dev-only" },
  absent: { cls: "dchip--lfs", label: "LFS pointer" },
} as const;

// One flat row per document across every collection (#725) — the catalog is a single
// sortable/filterable table, not a stack of per-collection tables. SSR carries the full
// table (readable with JS off); `scripts/doc-catalog.ts` adds the toolbar + sort.
const rows = collections.flatMap((c) =>
  c.entries.map((e) => ({
    collection: c.title,
    slug: c.slug,
    rel: e.rel,
    name: e.name,
    type: e.render_class,
    size: e.size_bytes,
    access: docAccess(e),
  })),
);
const collectionNames = [...new Set(rows.map((r) => r.collection))].sort((a, b) => a.localeCompare(b));
const types = [...new Set(rows.map((r) => r.type))].sort((a, b) => a.localeCompare(b));
const accesses = [...new Set(rows.map((r) => r.access))];
---

<Base title="Documents catalog" section="site">
  <article class="prose">
    <h1>Documents catalog</h1>
    <p class="section-lead">
      {rows.length.toLocaleString("en-US")} primary source documents across
      {collections.length} collections, mirrored from <code>data/documents/</code>.
      Source bytes are immutable chain-of-custody evidence; as-received filenames
      are preserved verbatim.
    </p>
  </article>

  <div class="doccat-tools" hidden>
    <input
      type="search"
      class="doccat-search"
      placeholder="Search name or collection…"
      aria-label="Search documents by name or collection"
      autocomplete="off"
    />
    <label class="doccat-filter">
      <span>Collection</span>
      <select data-filter="collection">
        <option value="">All collections</option>
        {collectionNames.map((n) => <option value={n}>{n}</option>)}
      </select>
    </label>
    <label class="doccat-filter">
      <span>Type</span>
      <select data-filter="type">
        <option value="">All types</option>
        {types.map((t) => <option value={t}>{t}</option>)}
      </select>
    </label>
    <label class="doccat-filter">
      <span>Access</span>
      <select data-filter="access">
        <option value="">All</option>
        {accesses.map((a) => <option value={a}>{ACCESS_CHIP[a].label.replace("● ", "")}</option>)}
      </select>
    </label>
    <span class="doccat-count" aria-live="polite"></span>
  </div>

  <div class="dtable doccat">
    <table id="doccat-table">
      <thead>
        <tr>
          <th data-sort="collection" aria-sort="none">Collection</th>
          <th data-sort="name" aria-sort="none">File</th>
          <th data-sort="type" aria-sort="none">Type</th>
          <th class="num" data-sort="size" data-numeric aria-sort="none">Size</th>
          <th data-sort="access" aria-sort="none">Access</th>
        </tr>
      </thead>
      <tbody>
        {
          rows.map((r) => (
            <tr
              data-collection={r.collection}
              data-slug={r.slug}
              data-name={r.name.toLowerCase()}
              data-type={r.type}
              data-access={r.access}
              data-size={r.size}
            >
              <td class="doccat-coll">{r.collection}</td>
              <td class="file">
                <a href={withSite(`/site/documents/${r.rel}`)}>{r.name}</a>
              </td>
              <td><span class="dchip dchip--type">{r.type}</span></td>
              <td class="num">{formatBytes(r.size)}</td>
              <td><span class={`dchip ${ACCESS_CHIP[r.access].cls}`}>{ACCESS_CHIP[r.access].label}</span></td>
            </tr>
          ))
        }
      </tbody>
    </table>
  </div>
  <p class="doccat-empty" hidden>No documents match these filters.</p>

  <script>
    import "../../../../../scripts/doc-catalog.ts";
  </script>
</Base>
