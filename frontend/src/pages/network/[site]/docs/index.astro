---
import { selectableSitePaths } from "../../../../lib/sites";
export const getStaticPaths = selectableSitePaths;
import Base from "../../../../layouts/Base.astro";
import { NARRATIVE } from "../../../../lib/narrative";
import { getSection, sections, type SectionId } from "../../../../lib/nav";
import { withSite } from "../../../../lib/site";

// Group the migrated narrative by the section each piece belongs to.
const groups = sections().map((s) => ({
  section: s,
  docs: NARRATIVE.filter((d) => d.section === (s.id as SectionId)),
})).filter((g) => g.docs.length > 0);
---

<Base title="Docs" section="reports" rail={false} description="The project's narrative prose — methodology, dossier, hydrology, economics, and legal analysis.">
  <div class="hub">
    <div class="hub-head">
      <div>
        <div class="hub-eyebrow">Platform · docs</div>
        <h1>Docs</h1>
        <p class="hub-lead">
          The project's long-form prose, migrated from <code>docs/</code> into the
          site (issue #69). The same files still feed the legacy generator — this
          reads them as-is, rewriting their cross-links into the new sections.
        </p>
      </div>
      <span class="hub-count">{NARRATIVE.length} essays · {groups.length} sections</span>
    </div>

    {
      groups.map((g) => (
        <>
          <h2 class="hub-subhead" id={g.section.id}>{getSection(g.section.id).label}</h2>
          <div class="hub-grid">
            {g.docs.map((d) => (
              <a class="hub-door" href={`${withSite("/docs/")}${d.slug}`}>
                <div class="hub-door-top">
                  <span class="hub-door-kind">{getSection(g.section.id).tab}</span>
                </div>
                <div class="hub-door-title">{d.title}</div>
                {d.blurb && <div class="hub-door-desc">{d.blurb}</div>}
                <div class="hub-door-foot">
                  <span class="hub-door-browse">Read</span>
                  <span class="hub-door-arrow" aria-hidden="true">›</span>
                </div>
              </a>
            ))}
          </div>
        </>
      ))
    }
  </div>
</Base>
