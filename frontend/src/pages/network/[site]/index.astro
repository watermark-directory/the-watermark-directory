---
/**
 * The site home (design "Site Home" → the Live state). Lima is the live reference build, so the
 * front door renders the design's Live composition: hero + the facility chip + a real open-leads
 * pointer, the two doors (record / the story), the "The story · six chapters" grid, the corpus
 * strip, and the provenance footer. The orientation prose folded into the story home (STORY_BASE).
 * `phase` is a prop on the design; here it's fixed to Live (the other phases need per-site leads /
 * contributor feeds Lima doesn't have — building them would mean fabricating). Real feeds throughout.
 */
import Base from "../../../layouts/Base.astro";
import FigureStat from "../../../components/FigureStat.astro";
import PartialSiteHome from "../../../components/PartialSiteHome.astro";
import { isReferenceSite } from "../../../lib/readiness";
import { hasFeed, loadFeed, loadManifest } from "../../../lib/bundle";
import type { DocumentCollectionItem } from "../../../lib/feeds";
import { NARRATIVE } from "../../../lib/narrative";
import {
  activeSite,
  FACILITY_STATUS_META,
  facilityStatus,
  selectableSitePaths,
  siteForSlug,
  siteState,
} from "../../../lib/sites";
import type { FigureStatData } from "../../../lib/viz";
import { WALK_CHAPTERS, walkHref } from "../../../lib/walk";
import { withSite, withStory } from "../../../lib/site";

// One `network/[site]/…` route per selectable site (#724/#734); Lima alone today.
export const getStaticPaths = selectableSitePaths;

// The active site (from the route prop) drives the dateline/facility chrome — no hardcoded
// "Lima, Ohio" — so a second selectable site renders its own place/state (#741).
const { slug } = Astro.props as { slug: string };
const site = siteForSlug(slug) ?? activeSite();
const dateline = `${site.place}, ${siteState(slug)}`;

const manifest = loadManifest();
const byName = new Map(manifest.feeds.map((f) => [f.name, f]));
const count = (name: string): number => byName.get(name)?.count ?? 0;
const num = (n: number): string => n.toLocaleString("en-US");

const docCollections = hasFeed("documents") ? loadFeed<DocumentCollectionItem[]>("documents") : [];
const nDocuments = docCollections.reduce((a, c) => a + c.entries.length, 0);
const nChapters = WALK_CHAPTERS.length;
const nLeads = count("leads");

// The facility clock (separate from the site-build clock) — the active site's campus lifecycle.
const fac = FACILITY_STATUS_META[facilityStatus(slug)];

// Corpus at a glance — five real, derivable counts (the design's at-a-glance strip).
const stats: FigureStatData[] = [
  {
    label: "Source files",
    value: num(nDocuments),
    evidence: "verified",
    sub: `${docCollections.length} collections`,
  },
  { label: "Records", value: num(count("records")), evidence: "verified", sub: "deeds · permits · filings" },
  { label: "Timeline events", value: num(count("timeline")), evidence: "verified", sub: "dated" },
  {
    label: "Entities & places",
    value: num(count("entities") + count("places")),
    evidence: "verified",
    sub: `${num(count("relationships"))} relationships`,
  },
  { label: "Essays", value: num(NARRATIVE.length), evidence: "verified", sub: "long-form" },
];
---

<Base title="Watermark" section="home" rail={false} description="Watermark — the public record, by watershed.">
  {isReferenceSite(slug) ? (
  <div class="home home--live">
    <div class="home-hero">
      <div class="home-kicker">Public record · {dateline}</div>
      <h1>A 340-acre data center,<br />built to be invisible.</h1>
      <p class="home-lead">
        A Delaware shell. Withheld land prices. 114 backup generators. A consumptive cooling
        loss that dwarfs a river running at <span class="td-key">0.2 cfs</span>. The record was
        made thin on purpose — here it's reassembled in the open, and
        <strong>every figure is checkable.</strong>
      </p>
      <div class="home-hero-meta">
        <span class="home-fac-chip" style={`--fac:${fac.color};--fac-bg:${fac.bg}`}>
          <svg viewBox="0 0 24 24" width="13" height="13" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <rect x="4" y="4.5" width="16" height="6.5" rx="1.4"></rect>
            <rect x="4" y="13" width="16" height="6.5" rx="1.4"></rect>
            <line x1="7" y1="7.75" x2="7.2" y2="7.75"></line>
            <line x1="7" y1="16.25" x2="7.2" y2="16.25"></line>
          </svg>
          Facility · {fac.label}
        </span>
        <a class="home-leads-pill" href={withSite("/leads")}>
          <span class="home-leads-dot" aria-hidden="true"></span>
          {nLeads} open leads · help close them
        </a>
      </div>
    </div>

    {/* The entry fork — two co-equal doors: the researcher's library (quiet outline,
        left) and the newcomer's story / guided walk (filled forest, right). */}
    <div class="home-doors">
      <a class="home-door home-door--archive" href={withSite("/site/")}>
        <div class="home-door-top">
          <span class="home-door-eyebrow">For the researcher</span>
          <span class="home-door-count">{num(nDocuments)} files</span>
        </div>
        <span class="home-door-title">Browse the record</span>
        <span class="home-door-desc">
          Straight to the documents, records, timeline, and entities. Provenance-first;
          follow any citation to its source.
        </span>
        <span class="home-door-go">Enter the library →</span>
      </a>
      <a class="home-door home-door--walk" href={withStory("")}>
        <div class="home-door-top">
          <span class="home-door-eyebrow">For the newcomer</span>
          <span class="home-door-count">{nChapters} chapters · ~18 min</span>
        </div>
        <span class="home-door-title">Read the story</span>
        <span class="home-door-desc">
          A path that teaches you to read the record one document at a time — no jargon, no
          prior knowledge.
        </span>
        <span class="home-door-go">▶ Start the story →</span>
      </a>
    </div>

    {/* The story · six chapters (design "Site Home" Live) — the narrative spine, one project
        read one document at a time, crossing every theme in the record. */}
    <div class="home-story" id="story">
      <div class="home-story-head">
        <span class="home-story-kicker">The story · in {nChapters} chapters</span>
        <span class="home-story-note">one project, read one document at a time</span>
        <a class="home-story-toc" href={withStory("/contents")}>Table of contents →</a>
      </div>
      <div class="home-story-grid">
        {
          WALK_CHAPTERS.map((c) => (
            <a class="home-chapter" href={walkHref(c.slug)}>
              <span class="home-chapter-n">{c.step}</span>
              <span class="home-chapter-main">
                <span class="home-chapter-title">{c.title}</span>
                <span class="home-chapter-skill">{c.skill}</span>
              </span>
            </a>
          ))
        }
      </div>
    </div>

    <div class="home-stats" id="corpus">
      <div class="home-stats-label">The corpus at a glance</div>
      <div class="home-stats-grid">
        {stats.map((s) => <FigureStat stat={s} size="sm" />)}
      </div>
    </div>

    {/* The third way in — a question, not a path. Answers are cited and drawn only from the corpus. */}
    <a class="home-ask" href="/ask">
      <span class="home-ask-mark" aria-hidden="true">✦</span>
      <span class="home-ask-text">
        <strong>Or just ask the record a question.</strong> Answers are drawn only from the
        corpus, every claim cited — and where the record is silent, it says so.
      </span>
      <span class="home-ask-go">Ask the corpus →</span>
    </a>

    <div class="home-disclaimer" id="disclaimer">
      <span class="footer-pill"><span class="dot" aria-hidden="true"></span>provenance-first</span>
      <p>
        <strong>Pre-launch.</strong> Assembled from public records the developer didn't write.
        Sourced figures carry their citation; <a href={withSite("/leads")}>open leads</a>
        stay labeled as <code>[inference]</code> until a source corroborates them. Nothing here
        is legal advice or a verdict — verify every figure against its cited source.
      </p>
    </div>
  </div>
  ) : (
    <PartialSiteHome slug={slug} site={site} dateline={dateline} />
  )}
</Base>
