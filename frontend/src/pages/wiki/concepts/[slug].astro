---
import type { GetStaticPaths } from "astro";
import Base from "../../../layouts/Base.astro";
import ProfileHeader from "../../../components/ProfileHeader.astro";
import { hasFeed, loadFeed } from "../../../lib/bundle";
import type { ConceptItem } from "../../../lib/feeds";
import type { ProfileHeaderData, ProfileRel } from "../../../lib/profile";
import { withBase } from "../../../lib/site";
import { conceptBacklinks, norm, renderBody, wikiIndex } from "../../../lib/wiki";

export const getStaticPaths: GetStaticPaths = () => {
  const concepts = hasFeed("concepts") ? loadFeed<ConceptItem[]>("concepts") : [];
  return concepts.map((concept) => ({ params: { slug: concept.slug }, props: { concept } }));
};

interface Props {
  concept: ConceptItem;
}
const { concept } = Astro.props;
const index = wikiIndex();
const paragraphs = renderBody(concept.body, index);
const related = concept.related
  .map((r) => index.get(norm(r)))
  .filter((t): t is NonNullable<typeof t> => Boolean(t));
const backlinks = conceptBacklinks(concept.slug);

const rels: ProfileRel[] = related.map((t) => ({ kind: t.kind, label: t.label, href: t.url }));

const header: ProfileHeaderData = {
  kindLabel: `Concept${concept.kind && concept.kind !== "concept" ? ` · ${concept.kind}` : ""}`,
  name: concept.title,
  variants: concept.aliases,
  descriptor: concept.summary || undefined,
  evidence: "verified",
  relLabel: "Related",
  relationships: rels.length ? rels : undefined,
  correctHref: withBase(
    `/bosc/submit?ref_kind=concept&ref_id=${encodeURIComponent(concept.slug)}&ref_label=${encodeURIComponent(concept.title)}`,
  ),
};

const sections = [
  { anchor: "overview", label: "Identity" },
  ...(backlinks.length ? [{ anchor: "backlinks", label: "Backlinks" }] : []),
];
const profileToc = sections.length >= 2 ? sections : [];
---

<Base title={concept.title} section="wiki" description={concept.summary} toc={profileToc}>
  <p class="prose"><a href={withBase("/wiki/concepts/")}>← Concepts</a></p>
  <div id="overview"><ProfileHeader profile={header} /></div>

  <article class="prose">
    {
      concept.tags.length > 0 && (
        <ul class="chips">
          {concept.tags.map((t) => (
            <li class="chip">{t}</li>
          ))}
        </ul>
      )
    }

    {paragraphs.map((html) => <p set:html={html} />)}

    {
      backlinks.length > 0 && (
        <div class="backlinks">
          <h2 id="backlinks">Backlinks</h2>
          <ul class="neighborhood">
            {backlinks.map((b) => (
              <li>
                <a href={b.url}>{b.label}</a>
              </li>
            ))}
          </ul>
        </div>
      )
    }
  </article>
</Base>
