---
import Base from "../../../layouts/Base.astro";
import { hasFeed, loadFeed } from "../../../lib/bundle";
import type { ConceptItem } from "../../../lib/feeds";
import { withBase } from "../../../lib/site";

const concepts = hasFeed("concepts") ? loadFeed<ConceptItem[]>("concepts") : [];
---

<Base title="Concepts" section="wiki">
  <article class="prose">
    <p><a href={withBase("/wiki/")}>← Wiki</a></p>
    <h1>Concepts</h1>
    <p class="section-lead">
      The concept glossary — term and method definitions cross-linked through the
      record. {concepts.length} concept(s).
    </p>
    {concepts.length === 0 && <p class="stub-note">No concepts feed in this bundle.</p>}
    <div class="cards">
      {
        concepts.map((c) => (
          <a class="card" href={`${withBase("/wiki/concepts/")}${c.slug}/`}>
            <span class="card-title">{c.title}</span>
            <span class="card-meta">{c.summary}</span>
          </a>
        ))
      }
    </div>
  </article>
</Base>
