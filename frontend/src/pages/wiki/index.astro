---
import Base from "../../layouts/Base.astro";
import { hasFeed, loadFeed, loadManifest } from "../../lib/bundle";
import { slugify, type ConceptItem, type EntityNode } from "../../lib/feeds";
import { withBase } from "../../lib/site";

const manifest = loadManifest();
const byName = new Map(manifest.feeds.map((f) => [f.name, f]));
const count = (n: string): number => byName.get(n)?.count ?? 0;

const entities = hasFeed("entities") ? loadFeed<EntityNode[]>("entities") : [];
const roleTotal = (e: EntityNode): number => Object.values(e.roles ?? {}).reduce((a, b) => a + b, 0);
const topEntities = [...entities].sort((a, b) => roleTotal(b) - roleTotal(a)).slice(0, 8);
const concepts = hasFeed("concepts") ? loadFeed<ConceptItem[]>("concepts") : [];
---

<Base title="Wiki" section="wiki">
  <article class="prose">
    <h1>Wiki</h1>
    <p class="section-lead">
      Entity and concept pages with backlinks and a graph neighborhood — the
      cross-linked index of who and what appears in the record.
    </p>

    <h2 id="entities">Entities</h2>
    <p>
      {count("entities")} resolved parties, each with its graph neighborhood and
      sources. → <a href={withBase("/wiki/entities/")}>Browse entities</a> ·
      <a href={withBase("/wiki/graph")}>open the interactive graph</a>
    </p>
    <ul class="neighborhood">
      {
        topEntities.map((e) => (
          <li>
            <a href={`${withBase("/wiki/entities/")}${slugify(e.key)}/`}>{e.display}</a>
            <span class="card-meta"> · {e.kind}</span>
          </li>
        ))
      }
    </ul>

    <h2 id="people">People</h2>
    <p>
      {count("people")} curated individual profiles live under the BOSC site. →
      <a href={withBase("/site/people/")}>Open profiles</a>
    </p>

    <h2 id="concepts">Concepts</h2>
    <p>
      {count("concepts")} glossary concepts, cross-linked via <code>[[wiki links]]</code>. →
      <a href={withBase("/wiki/concepts/")}>Open the glossary</a>
    </p>
    <div class="cards">
      {
        concepts.slice(0, 6).map((c) => (
          <a class="card" href={`${withBase("/wiki/concepts/")}${c.slug}/`}>
            <span class="card-title">{c.title}</span>
            <span class="card-meta">{c.summary}</span>
          </a>
        ))
      }
    </div>
  </article>
</Base>
