---
import EntityGraph from "../../components/islands/EntityGraph.tsx";
import Base from "../../layouts/Base.astro";
import { hasFeed, loadFeed } from "../../lib/bundle";
import { slugify, type EntityNode } from "../../lib/feeds";
import { withBase } from "../../lib/site";

// SSR fallback / data view: the entity list the island visualizes.
const entities = hasFeed("entities") ? loadFeed<EntityNode[]>("entities") : [];
const roleTotal = (e: EntityNode): number => Object.values(e.roles ?? {}).reduce((a, b) => a + b, 0);
const sorted = [...entities].sort((a, b) => roleTotal(b) - roleTotal(a) || a.display.localeCompare(b.display));
---

<Base title="Entity graph" section="wiki">
  <article class="prose">
    <p><a href={withBase("/wiki/")}>← Wiki</a></p>
    <h1>Entity graph</h1>
    <p class="section-lead">
      The {entities.length}-node relationship graph of the resolved entities.
      Click a node to open its page; hover for its degree. Open an entity's page
      and use “view in graph” to focus its neighborhood.
    </p>

    <div class="deck-surface">
      <EntityGraph client:only="react" src={withBase("/feeds/graph.json")} />
      <noscript>
        <div class="deck-loading">
          The interactive graph needs JavaScript — the entity list below is the
          same data.
        </div>
      </noscript>
    </div>

    <h2>Entities</h2>
    <ul class="neighborhood">
      {
        sorted.map((e) => (
          <li>
            <a href={`${withBase("/wiki/entities/")}${slugify(e.key)}/`}>{e.display}</a>
            <span class="card-meta"> · {e.kind}</span>
          </li>
        ))
      }
    </ul>
  </article>
</Base>
