---
import Base from "../../layouts/Base.astro";
import { NARRATIVE } from "../../lib/narrative";
import { withBase } from "../../lib/site";

// Published reports: the long-form analytical essays already in the corpus, in a
// curated reading order. Pulled from the narrative collection by slug so titles and
// blurbs stay in sync with the source docs.
const ORDER = [
  "end-use-and-workloads",
  "defense-nexus",
  "toxics-and-the-corridor",
  "the-load-and-the-grid",
  "the-economic-ledger",
  "dossier",
  "hydrology",
  "economics",
  "legal/mandamus-analysis",
  "legal/proponent-analysis",
  "bigger-picture",
];
const bySlug = new Map(NARRATIVE.map((d) => [d.slug, d]));
const published = ORDER.map((s) => bySlug.get(s)).filter((d): d is NonNullable<typeof d> => Boolean(d));

// Reports with an interactive companion page link there instead of the plain essay
// (the companion links onward to the full cited text).
const INTERACTIVE: Record<string, string> = {
  "end-use-and-workloads": "/reports/end-use-and-workloads",
  "defense-nexus": "/reports/defense-nexus",
  "the-economic-ledger": "/reports/the-economic-ledger",
  "toxics-and-the-corridor": "/reports/toxics-and-the-corridor",
  "the-load-and-the-grid": "/reports/the-load-and-the-grid",
};
const reportHref = (slug: string): string => INTERACTIVE[slug] ?? `/docs/${slug}`;

// Forthcoming: the extension narratives tracked in epic #233 — deeper dives that the
// corpus is being assembled to support. Carried here as drafting, not findings. The
// four originally scoped (end-use, defense, toxics, grid) are now all published above;
// any further #233 threads land back here as drafting cards before they ship.
const forthcoming: { title: string; blurb: string }[] = [];
---

<Base
  title="Reports"
  section="reports"
  description="Long-form analysis over the corpus — the dossier, the water and economics reads, the legal analyses, and the extension narratives in progress."
>
  <article class="prose">
    <h1>Reports</h1>
    <p class="section-lead">
      Long-form analysis built <em>over</em> the corpus — each report stands on cited
      records, with inference labeled and nothing dressed as a verdict. The
      <a href={withBase("/start")}>guided walk</a> teaches you to read the record; these
      go deeper on one thread at a time.
    </p>
  </article>

  <h2 class="walk-explore-h">The capstone</h2>
  <div class="doors">
    <a class="door door--capstone" href={withBase("/reports/public-balance-sheet")}>
      <span class="door-label">
        The public balance sheet <span class="door-badge">interactive</span>
      </span>
      <span class="door-blurb">
        Every narrative's band on one register-encoded sheet — the economic give, the load,
        the river — and the cost of opacity in aggregate: the public's exposure rides on
        records the county won't produce, and disclosing them collapses the band.
      </span>
    </a>
  </div>

  <h2 class="walk-explore-h">Published</h2>
  <div class="doors">
    {
      published.map((d) => (
        <a class="door" href={withBase(reportHref(d.slug))}>
          <span class="door-label">
            {d.title}
            {INTERACTIVE[d.slug] && <span class="door-badge">interactive</span>}
          </span>
          <span class="door-blurb">{d.blurb}</span>
        </a>
      ))
    }
  </div>

  {
    forthcoming.length > 0 && (
      <>
        <h2 class="walk-explore-h">In progress — extension narratives</h2>
        <article class="prose">
          <p>
            Deeper dives the corpus is being assembled to support, tracked in epic #233.
            Listed here as <strong>drafting</strong> — open threads, not findings.
          </p>
        </article>
        <div class="doors">
          {forthcoming.map((r) => (
            <div class="door door--draft">
              <span class="door-label">
                {r.title} <span class="mf-tag mf-tag--open">[drafting]</span>
              </span>
              <span class="door-blurb">{r.blurb}</span>
            </div>
          ))}
        </div>
      </>
    )
  }
</Base>
