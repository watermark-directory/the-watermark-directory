---
/**
 * The public balance sheet (epic #271 Phase 4 capstone, #273) — the meta-view that
 * composes every narrative's band on one sheet and prices the opacity in aggregate. No
 * new data: it reads the existing consumer models through the shared UncertainOutcome
 * contract. Reads as a map of what isn't known, not a verdict.
 *
 * Island-over-SSR: the table is the no-JS fallback (the bands, precomputed from the same
 * models). The toxics band needs the feed's discharge constants (buildDilution) — passed
 * to the island so the balance sheet never forks the narratives.
 */
import BalanceSheet from "../../components/islands/BalanceSheet.tsx";
import Base from "../../layouts/Base.astro";
import { type BalanceUnit, buildBalanceSheet } from "../../lib/balanceSheet";
import { buildDilution } from "../../lib/dilution";
import { fmtUsdM } from "../../lib/money";
import { withBase } from "../../lib/site";

const dc = buildDilution().discharge;
const effluentCfs = dc.wwtpCfs + dc.campusFm2Cfs;
const sheet = buildBalanceSheet(effluentCfs, dc.naturalCfs);

const fmt = (n: number, unit: BalanceUnit): string =>
  unit === "usd" ? fmtUsdM(n) : unit === "mw" ? `${Math.round(n)} MW` : `${n.toFixed(0)}%`;
const e = sheet.econExposure;
---

<Base
  title="The public balance sheet"
  section="reports"
  description="Every narrative's band on one register-encoded sheet — the economic give, the load, the river — and the cost of opacity in aggregate: the public's exposure rides on records the county won't produce, and disclosing them collapses the band."
>
  <div class="walk-chapter-page">
    <article class="prose">
      <p><a href={withBase("/reports")}>← Reports</a></p>
      <div class="walk-chapter-eyebrow">Extension narrative · #233 · the capstone</div>
      <h1 class="walk-chapter-h1">The cost of opacity, on one sheet</h1>
      <p class="section-lead">
        Each report ends <code>[open]</code> for the same reason — a figure the record
        withholds. Set them side by side and the pattern becomes a quantity: the public's
        monetized 15-year exposure runs
        <strong>{fmtUsdM(e.low)} – {fmtUsdM(e.high)}</strong>, and it rides on
        <strong>{sheet.resolvingRecords.length} records the county has not produced</strong>.
        This page composes every band the narratives compute — it adds no new data, and it
        returns no verdict. It is a map of what isn't known, and what would close it.
      </p>
    </article>

    <BalanceSheet client:only="react" toxicsEffluentCfs={effluentCfs} toxicsNaturalCfs={dc.naturalCfs} />

    <noscript>
      <article class="prose">
        <h2>The bands</h2>
        <table>
          <thead><tr><th>Narrative</th><th>Band</th><th>Register</th><th>What would resolve it</th></tr></thead>
          <tbody>
            {sheet.rows.map((row) => (
              <tr>
                <td>{row.narrative}</td>
                <td>{fmt(row.outcome.low, row.unit)} – {fmt(row.outcome.high, row.unit)}</td>
                <td><code>[{row.outcome.register}]</code></td>
                <td>{row.outcome.resolvingRecord}</td>
              </tr>
            ))}
          </tbody>
        </table>
        <p>
          {sheet.resolvingRecords.length} withheld records span the public's exposure. Enable JavaScript for
          the register-encoded bands; the <a href={withBase("/site/legal/corpus-completeness-audit")}>corpus
          audit</a> tracks what's missing.
        </p>
      </article>
    </noscript>
  </div>
</Base>
