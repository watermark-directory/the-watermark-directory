---
/**
 * Preview of the restricted-site screen (design "Site Locked"). No real registry site is
 * locked today — locking is a per-site policy decision. This route renders the SiteLocked
 * screen with sample props so the capability is reviewable; when a site's `locked` flag is
 * set in the registry, its /network/<slug> route renders this same screen for real.
 */
import SiteLocked from "../components/SiteLocked.astro";
import Base from "../layouts/Base.astro";
---

<Base title="Site Locked — preview" section="directory" description="Preview of the restricted-site (locked) screen.">
  <p class="prose" style="margin-bottom:1rem;">
    <strong>Preview.</strong> No live site is locked — this shows the restricted-site screen the
    selector routes to when a registry site is flagged <code>locked</code>.
  </p>
  <SiteLocked
    place="Columbus"
    location="Franklin County, Ohio"
    codename="RESTRICTED"
    basin="Scioto mainstem"
    lockReason="sourcing"
    sealedCount={146}
    reviewWhen="monthly"
  />
</Base>
