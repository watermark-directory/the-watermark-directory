---
import Base from "../../layouts/Base.astro";
import Timeline from "../../components/Timeline.astro";
import type { TimelineItem } from "../../lib/viz";
import { hasFeed, loadFeed } from "../../lib/bundle";
import { evidenceKind, type TimelineEntry } from "../../lib/feeds";
import { walkAnchorFor } from "../../lib/walk";
import { withBase } from "../../lib/site";

const entries = hasFeed("timeline") ? loadFeed<TimelineEntry[]>("timeline") : [];
const isDated = (e: TimelineEntry): boolean => /^\d{4}/.test(e.date);
const dated = entries.filter(isDated).sort((a, b) => a.date.localeCompare(b.date));
const ordered = [...dated, ...entries.filter((e) => !isDated(e))];

const items: TimelineItem[] = ordered.map((e) => {
  const anchor = walkAnchorFor(e.source) ?? (e.also_sources ?? []).map(walkAnchorFor).find(Boolean);
  return {
    date: e.date || "",
    kind: e.category.replace(/_/g, " "),
    title: e.title,
    summary: e.detail ?? undefined,
    evidence: evidenceKind(e.citation),
    seenInCh: anchor?.ch,
    seenInHref: anchor ? withBase(`/walk/${anchor.slug}`) : undefined,
  };
});
---

<Base title="Timeline" section="site">
  <article class="prose">
    <p><a href={withBase("/site/")}>← The BOSC site</a></p>
    <h1>Timeline</h1>
    <p class="section-lead">
      {entries.length} events, cause → consequence — each traceable to the
      extraction that supplied it, the evidence node colored by its citation.
    </p>
  </article>
  <div class="rb-list">
    <Timeline events={items} />
  </div>
</Base>
