---
/**
 * The Record Screen (design "Record Screen", #193): the per-record leaf at
 * /site/records/<group>/<id>. It opens with the reference Record Block (the
 * library's packed unit) and, when the record is a curated walk anchor, runs the
 * Record Teardown on the same id below it (the walk's teaching flow) — one feed,
 * never a fork. A `verify` link, a group-index row, or a walk chip all land here,
 * on the block, with the teardown one scroll down. The per-page TOC rail is #195.
 */
import type { GetStaticPaths } from "astro";
import Base from "../../../../layouts/Base.astro";
import RecordBlock from "../../../../components/RecordBlock.astro";
import RecordTeardown from "../../../../components/RecordTeardown.astro";
import { hasFeed, loadFeed } from "../../../../lib/bundle";
import { slugify, type RecordItem } from "../../../../lib/feeds";
import { groupLabel } from "../../../../lib/records";
import { recordToBlock } from "../../../../lib/recordBlock";
import { teardownForRel } from "../../../../lib/teardowns";
import { withBase } from "../../../../lib/site";

export const getStaticPaths: GetStaticPaths = () => {
  const records = hasFeed("records") ? loadFeed<RecordItem[]>("records") : [];
  return records.map((r) => ({
    params: { group: r.group, id: slugify(r.rel) },
    props: { record: r },
  }));
};

interface Props {
  record: RecordItem;
}
const { record } = Astro.props;
const block = recordToBlock(record);
const teardown = teardownForRel(record.rel);
const hasAnnotated = Boolean(teardown?.pins?.length);
const groupName = groupLabel(record.group).replace(/ —.*$/, "");
---

<Base
  title={record.title}
  section="site"
  rail={false}
  description={`${record.title} — the record, read in the open with provenance on every figure.`}
>
  <div class="rec">
    <nav class="rec-crumb" aria-label="Breadcrumb">
      <a href={withBase("/site/")}>The BOSC site</a> ›
      <a href={withBase("/site/records/")}>Records</a> ›
      <a href={withBase(`/site/records/${record.group}`)}>{groupName}</a> ›
      <span class="rec-crumb-here">{record.title}</span>
    </nav>

    <div class="rec-part" id="the-record">The record</div>
    <div class="rb-list"><RecordBlock record={block} density="full" /></div>

    {
      teardown && (
        <Fragment>
          <div class="rec-handoff">
            <span class="rec-handoff-mark" aria-hidden="true">↓</span>
            <p class="rec-handoff-text">
              <strong>How we read it.</strong> The block above is the answer; the teardown
              below is the working — the same record, slowed down so the figure can be checked.
            </p>
          </div>

          <div class="rec-flow" id="the-teardown">
            <input class="rec-flow-radio" type="radio" id="flow-split" name="rec-flow" checked />
            <input class="rec-flow-radio" type="radio" id="flow-scroll" name="rec-flow" />
            {hasAnnotated && (
              <input class="rec-flow-radio" type="radio" id="flow-annotated" name="rec-flow" />
            )}
            <div class="rec-flow-head">
              <span class="rec-part is-indigo">The teardown · run on this id</span>
              <div class="rec-flow-seg" role="group" aria-label="Teardown layout">
                <span class="rec-flow-flow">flow</span>
                <label for="flow-split">Split</label>
                <label for="flow-scroll">Scroll</label>
                {hasAnnotated && <label for="flow-annotated">Annotated</label>}
              </div>
            </div>
            <div class="rec-flow-panel rec-flow-panel--split">
              <RecordTeardown record={teardown} layout="split" />
            </div>
            <div class="rec-flow-panel rec-flow-panel--scroll">
              <RecordTeardown record={teardown} layout="scroll" />
            </div>
            {hasAnnotated && (
              <div class="rec-flow-panel rec-flow-panel--annotated">
                <RecordTeardown record={teardown} layout="annotated" />
              </div>
            )}
          </div>
          <p class="rec-flow-note">
            Same five beats, {hasAnnotated ? "three" : "two"} shapes: <b>split</b> for a clean
            two-column source, <b>scroll</b> for the vertical reflow
            {hasAnnotated ? ", and " : ". "}
            {hasAnnotated && (
              <Fragment>
                <b>annotated</b> for the redaction-heavy artifact.{" "}
              </Fragment>
            )}
            The flow is a choice on the screen — the record data never changes.
          </p>
        </Fragment>
      )
    }
  </div>
</Base>
