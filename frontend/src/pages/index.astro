---
/**
 * The BOSC network root (#307 PR 2). The live site is Lima, served under `/bosc` (the
 * physical re-root that makes future watershed sites clean siblings — `/gcp`, …). This
 * root redirects there; the network of sites is reached via the topbar switcher, and the
 * full overview lives at `/network`. On Cloudflare this is a 301 (`public/_redirects`);
 * the meta-refresh below is the local/static fallback.
 */
import { withBase } from "../lib/site";
const target = withBase("/bosc/");
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta http-equiv="refresh" content={`0; url=${target}`} />
    <link rel="canonical" href={target} />
    <meta name="robots" content="noindex" />
    <title>Project BOSC — the network</title>
  </head>
  <body>
    <p>Redirecting to <a href={target}>the BOSC site</a>…</p>
  </body>
</html>
