---
/**
 * The Watermark network root (#307 PR 2). The live site is Lima, served under `/bosc` (the
 * physical re-root that makes future watershed sites clean siblings — `/gcp`, …). This
 * root redirects there; the network of sites is reached via the topbar switcher, and the
 * full directory lives at `/directory`. On Cloudflare this is a TEMPORARY 302 (`public/_redirects`)
 * — the root will host real network content once a second site lands, so it must not be
 * hard-cached. The meta-refresh below is the local/static fallback.
 */
import { withBase } from "../lib/site";
const target = withBase("/bosc/");
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta http-equiv="refresh" content={`0; url=${target}`} />
    <link rel="canonical" href={target} />
    <meta name="robots" content="noindex" />
    <title>Watermark — the network</title>
  </head>
  <body>
    <p>Redirecting to <a href={target}>the record</a>…</p>
  </body>
</html>
