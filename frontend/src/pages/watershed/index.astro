---
import BeforeAfterSlider from "../../components/BeforeAfterSlider.astro";
import Base from "../../layouts/Base.astro";
import { hasFeed, loadManifest } from "../../lib/bundle";
import { withBase } from "../../lib/site";

const manifest = loadManifest();
const geoLayers = manifest.feeds.filter((f) => f.name.startsWith("geo/"));
const scenarios = manifest.feeds.find((f) => f.name === "hydrology-scenarios")?.count ?? 0;
const rseiFeatures = manifest.feeds.find((f) => f.name === "geo/rsei")?.count ?? 0;
const watershedFeatures = manifest.feeds.find((f) => f.name === "geo/watershed")?.count ?? 0;
const hasImagery = manifest.feeds.some((f) => f.name === "geo/imagery");
const hasEconBaseline = manifest.feeds.some((f) => f.name === "economics-baseline");
---

<Base title="The Maumee watershed" section="watershed">
  <article class="prose">
    <h1>The Maumee watershed</h1>
    <p class="section-lead">
      The water the BOSC site sits in: stormwater and water-balance modeling of
      the Lima municipal loop, the watershed map, imagery before/during/after,
      and the RSEI toxic-release picture.
    </p>

    <h2 id="hydrology">Hydrology</h2>
    <p>
      {scenarios} committed water-balance / stormwater scenario(s) — the low-flow
      dilution / assimilative screen. → <a href={withBase("/watershed/hydrology")}>Open the dashboard</a>
    </p>
    <p>
      Narrative: <a href={withBase("/docs/hydrology")}>Hydrology — Tier-0 findings</a> ·
      <a href={withBase("/docs/economics")}>Economics — demand &amp; public benefits</a>
      {hasEconBaseline && (
        <> · <a href={withBase("/watershed/economics-baseline")}>Economics — localized baseline (BLS QCEW)</a></>
      )}
    </p>

    <h2 id="map">Watershed map</h2>
    <p>
      The interactive <a href={withBase("/watershed/map")}>watershed &amp; corridor map</a>
      renders {geoLayers.filter((g) => g.name !== "geo/imagery").length} typed GeoJSON layers
      on deck.gl + MapLibre, with dated aerials and click-through to each record — the
      campus, JSMC, the corridor and roadwork, FEMA floodway/floodplain, WWTP discharge
      points, the RSEI overlay, and {watershedFeatures
        ? `the USGS WBD watershed boundary (${watershedFeatures} hydrologic unit${watershedFeatures === 1 ? "" : "s"} — Pike Run subwatershed + the Ottawa River watershed)`
        : "the watershed boundary"}.
    </p>
    <ul>
      {geoLayers.map((g) => <li><code>{g.name}</code> — {g.count} feature(s)</li>)}
    </ul>

    <h2 id="imagery">Imagery — before / during / after</h2>
    {
      hasImagery ? (
        <p>
          Dated Esri <strong>Wayback</strong> aerials over the campus AOI — scrub through
          the data-center buildout. → <a href={withBase("/watershed/imagery")}>Open the imagery slider</a>
        </p>
      ) : (
        <BeforeAfterSlider />
      )
    }

    <h2 id="rsei">RSEI / toxics</h2>
    <p>
      {hasFeed("rsei") ? "EPA RSEI toxic-release inventory available" : "No RSEI inventory feed in this bundle"}
      {rseiFeatures ? `; ${rseiFeatures} mapped release site(s).` : "."}
      {hasFeed("rsei") && <> → <a href={withBase("/watershed/rsei")}>Open the inventory</a></>}
    </p>
  </article>
</Base>
