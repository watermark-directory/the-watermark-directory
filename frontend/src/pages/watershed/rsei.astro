---
import Base from "../../layouts/Base.astro";
import { hasFeed, loadFeed } from "../../lib/bundle";
import type { RseiInventory } from "../../lib/feeds";

const rsei = hasFeed("rsei") ? loadFeed<RseiInventory>("rsei") : null;
const facilities = rsei?.facilities ?? [];
// Rank by EPA's modeled Risk-Screening Score (comparative only, unitless).
const ranked = [...facilities]
  .sort((a, b) => (Number(b.score) || 0) - (Number(a.score) || 0))
  .slice(0, 25);
const num = (v: unknown): string => (v == null ? "—" : Number(v).toLocaleString("en-US"));
---

<Base title="RSEI / toxics" section="watershed">
  <article class="prose">
    <h1>RSEI / toxic-release inventory</h1>
    {
      rsei ? (
        <>
          <p class="section-lead">{rsei.meta.subject ?? "EPA RSEI toxic-release inventory"}</p>
          <p class="card-meta">
            Source: {rsei.meta.source} ({rsei.meta.version}) ·
            {rsei.meta.facility_count} facilities, {rsei.meta.scored_facility_count} scored.
          </p>
          {rsei.meta.caveats && rsei.meta.caveats.length > 0 && (
            <div class="callout">
              <p class="callout-title">How to read these numbers</p>
              <ul>
                {rsei.meta.caveats.map((c) => (
                  <li>{c}</li>
                ))}
              </ul>
            </div>
          )}
          <h2>Top facilities by Risk-Screening Score</h2>
          <table>
            <thead>
              <tr>
                <th>Facility</th>
                <th>City</th>
                <th>RSEI Score</th>
                <th>Pounds</th>
              </tr>
            </thead>
            <tbody>
              {ranked.map((f) => (
                <tr>
                  <td>{f.name}</td>
                  <td>{f.city}</td>
                  <td>{num(f.score)}</td>
                  <td>{num(f.pounds)}</td>
                </tr>
              ))}
            </tbody>
          </table>
        </>
      ) : (
        <p class="stub-note">No RSEI inventory feed in this bundle.</p>
      )
    }
  </article>
</Base>
