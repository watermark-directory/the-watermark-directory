---
import Base from "../../../layouts/Base.astro";
import { hasFeed, loadManifest } from "../../../lib/bundle";
import { withBase } from "../../../lib/site";

const manifest = loadManifest();
const byName = new Map(manifest.feeds.map((f) => [f.name, f]));
const count = (n: string): number => byName.get(n)?.count ?? 0;
const num = (n: number): string => n.toLocaleString("en-US");
const geoMapLayers = manifest.feeds.filter((f) => f.name.startsWith("geo/") && f.name !== "geo/imagery").length;

interface Door {
  id: string;
  kind: string;
  href: string;
  count: string;
  title: string;
  desc: string;
  note: string;
}
const doors: Door[] = [
  { id: "hydrology", kind: "Analysis", href: "/bosc/watershed/hydrology", count: num(count("hydrology-scenarios")), title: "Hydrology", desc: "Water-balance / low-flow dilution screen — live flow vs the 7Q10 design low flow, and the headroom that remains.", note: "dashboard" },
  { id: "map", kind: "Interactive map", href: "/bosc/watershed/map", count: num(geoMapLayers), title: "Watershed map", desc: "Typed GeoJSON layers on deck.gl + MapLibre — campus, corridor, floodway, WWTP, RSEI, watershed.", note: "interactive" },
  { id: "imagery", kind: "Aerial imagery", href: "/bosc/watershed/imagery", count: "—", title: "Imagery", desc: "Dated Esri Wayback aerials over the campus AOI — before / during / after the buildout.", note: "before / after" },
  { id: "rsei", kind: "External data", href: "/bosc/watershed/rsei", count: num(count("geo/rsei")), title: "RSEI / toxics", desc: "EPA RSEI toxic-release inventory on the same reaches the campus discharges to.", note: "release sites" },
];
if (hasFeed("economics-baseline")) {
  doors.push({ id: "economics", kind: "Baseline data", href: "/bosc/watershed/economics-baseline", count: "—", title: "Economics baseline", desc: "Localized BLS QCEW / Census employment baseline for the corridor.", note: "BLS · Census" });
}
---

<Base title="The Maumee watershed" section="watershed" rail={false}>
  <div class="hub">
    <div class="hub-head">
      <div>
        <div class="hub-eyebrow">Section · the Maumee watershed</div>
        <h1>The water it sits in</h1>
        <p class="hub-lead">
          Stormwater and water-balance modeling of the Lima municipal loop, the
          watershed map, dated imagery, and the RSEI toxic-release picture.
        </p>
      </div>
      <span class="hub-count"><span class="dot" aria-hidden="true"></span>Ottawa River · 7Q10 ≈ 0.2 cfs</span>
    </div>
    <div class="hub-grid">
      {
        doors.map((d) => (
          <a class="hub-door" id={d.id} href={withBase(d.href)}>
            <div class="hub-door-top">
              <span class="hub-door-kind">{d.kind}</span>
              <span class="hub-door-count">{d.count}</span>
            </div>
            <div class="hub-door-title">{d.title}</div>
            <div class="hub-door-desc">{d.desc}</div>
            <div class="hub-door-foot">
              <span class="hub-door-browse">Browse</span>
              <span class="hub-door-note">{d.note}</span>
              <span class="hub-door-arrow" aria-hidden="true">›</span>
            </div>
          </a>
        ))
      }
    </div>
  </div>
</Base>
