---
// The data catalog — a network-global, build-time read of the `catalog` bundle feed
// (epic #631 Phase 3 / #659). What datasets exist across the BOSC `data/` tree, where
// each came from, its license/access tier, and whether it's fresh — the legible successor
// to the hand-maintained corpus-completeness audit. Static + JS-off (no interactive
// filters): grouped by collection, freshness/scope shown as pills.
import Base from "../../layouts/Base.astro";
import { hasFeed, loadFeed } from "../../lib/bundle";
import { catalogFreshness, type CatalogFreshness, type CatalogItem } from "../../lib/feeds";

const items = hasFeed("catalog") ? loadFeed<CatalogItem[]>("catalog") : [];

// Group by collection (the natural dataset axis: echo, eia, hydrology, parcels, …).
const byCollection = new Map<string, CatalogItem[]>();
for (const it of items) {
  const list = byCollection.get(it.collection) ?? [];
  list.push(it);
  byCollection.set(it.collection, list);
}
const collections = [...byCollection.entries()]
  .map(([name, rows]) => ({
    name,
    rows: rows.sort((a, b) => a.id.localeCompare(b.id)),
    // the dominant source label for the group header
    source: rows[0]?.source ?? "",
    kind: rows[0]?.producer_kind ?? "",
  }))
  .sort((a, b) => a.name.localeCompare(b.name));

// Headline counts.
const total = items.length;
const reviewed = items.filter((i) => i.status === "reviewed").length;
const stale = items.filter((i) => catalogFreshness(i.observed) === "stale").length;
const tierCounts = [...new Set(items.map((i) => i.access_tier))]
  .map((t) => ({ tier: t, n: items.filter((i) => i.access_tier === t).length }))
  .sort((a, b) => b.n - a.n);

const FRESH_LABEL: Record<CatalogFreshness, string> = {
  fresh: "fresh",
  stale: "stale",
  missing: "missing",
  unmaterialized: "LFS pointer",
  unknown: "unobserved",
};
const SITE_SCOPE_LABEL: Record<string, string> = {
  "lima-legacy": "Lima",
  "slug-scoped": "per-site",
  "basin-shared": "basin",
};
function fileSummary(it: CatalogItem): string {
  const n = it.observed?.file_count ?? it.storage.length;
  return `${n} file${n === 1 ? "" : "s"}`;
}
---

<Base title="Data catalog" section="about">
  <article class="prose catalog">
    <p><a href="/about">← About</a></p>
    <h1>Data catalog</h1>
    {
      items.length === 0 ? (
        <p class="stub-note">No <code>catalog</code> feed in this bundle.</p>
      ) : (
        <>
          <p class="section-lead">
            Every dataset under the BOSC <code>data/</code> tree, in the open — what it is, where it
            came from, its license and access tier, and whether the committed copy is current.
            Generated from the registry (<code>bosc catalog</code>) and its reconcile snapshot; this
            is the legible successor to the hand-maintained corpus-completeness audit.
          </p>

          <div class="cat-summary">
            <div class="cat-stat"><span class="cat-stat-n">{total}</span><span class="cat-stat-l">datasets</span></div>
            <div class="cat-stat"><span class="cat-stat-n">{collections.length}</span><span class="cat-stat-l">collections</span></div>
            <div class="cat-stat"><span class="cat-stat-n">{reviewed}</span><span class="cat-stat-l">reviewed</span></div>
            <div class="cat-stat"><span class="cat-stat-n">{stale}</span><span class="cat-stat-l">stale</span></div>
          </div>
          <p class="cat-tiers">
            access · {tierCounts.map((t, i) => (
              <span>{i > 0 ? " · " : ""}<strong>{t.n}</strong> {t.tier}</span>
            ))}
          </p>

          {collections.map((coll) => (
            <section class="cat-coll">
              <h2 id={coll.name}>{coll.name} <span class="cat-coll-n">({coll.rows.length})</span></h2>
              <table class="cat-table">
                <thead>
                  <tr>
                    <th>Dataset</th>
                    <th>Source</th>
                    <th>License</th>
                    <th>Access</th>
                    <th>Scope</th>
                    <th>State</th>
                  </tr>
                </thead>
                <tbody>
                  {coll.rows.map((it) => {
                    const fresh = catalogFreshness(it.observed);
                    return (
                      <tr>
                        <td>
                          <span class="cat-title">{it.title}</span>
                          <span class="cat-id">{it.id} · {fileSummary(it)}</span>
                        </td>
                        <td>
                          {it.external_url ? (
                            <a href={it.external_url} rel="nofollow noopener">{it.source}</a>
                          ) : (
                            it.source
                          )}
                          <span class="cat-kind">{it.producer_kind}</span>
                        </td>
                        <td>{it.license ?? "—"}</td>
                        <td><span class={`cat-pill tier-${it.access_tier}`}>{it.access_tier}</span></td>
                        <td><span class="cat-scope">{SITE_SCOPE_LABEL[it.site_scope] ?? it.site_scope}</span></td>
                        <td><span class={`cat-pill fresh-${fresh}`}>{FRESH_LABEL[fresh]}</span></td>
                      </tr>
                    );
                  })}
                </tbody>
              </table>
            </section>
          ))}

          <p class="cat-foot">
            <code>fresh</code> is within the dataset's refresh cadence; <code>LFS pointer</code> means
            the bytes aren't materialized in this checkout (expected — large binaries live in Git LFS),
            not missing. Reconciled by <code>bosc catalog reconcile</code>; drift is gated in CI by
            <code>bosc catalog check</code>.
          </p>
        </>
      )
    }
  </article>
</Base>

<style>
  .catalog .section-lead { max-width: 60ch; }

  .cat-summary {
    display: flex;
    gap: 2.5rem;
    margin: 1.5rem 0 0.5rem;
    flex-wrap: wrap;
  }
  .cat-stat { display: flex; flex-direction: column; }
  .cat-stat-n {
    font-family: var(--bosc-mono);
    font-size: 1.9rem;
    line-height: 1;
    color: var(--bosc-ink);
  }
  .cat-stat-l {
    font-size: 0.72rem;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: var(--bosc-faint);
    margin-top: 0.3rem;
  }
  .cat-tiers {
    font-size: 0.85rem;
    color: var(--bosc-muted);
    margin: 0.25rem 0 2rem;
  }

  .cat-coll { margin: 2.25rem 0; }
  .cat-coll h2 { margin-bottom: 0.5rem; }
  .cat-coll-n { color: var(--bosc-faint); font-weight: 400; font-size: 0.8em; }

  .cat-table { width: 100%; font-size: 0.85rem; border-collapse: collapse; }
  .cat-table th {
    text-align: left;
    font-size: 0.68rem;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: var(--bosc-faint);
    border-bottom: 1px solid var(--bosc-rule);
    padding: 0.35rem 0.6rem 0.35rem 0;
    font-weight: 600;
  }
  .cat-table td {
    vertical-align: top;
    padding: 0.5rem 0.6rem 0.5rem 0;
    border-bottom: 1px solid var(--td-line, var(--bosc-rule));
  }
  .cat-title { display: block; color: var(--bosc-ink); }
  .cat-id {
    display: block;
    font-family: var(--bosc-mono);
    font-size: 0.72rem;
    color: var(--bosc-faint);
    margin-top: 0.15rem;
  }
  .cat-kind {
    display: block;
    font-family: var(--bosc-mono);
    font-size: 0.7rem;
    color: var(--bosc-faint);
    margin-top: 0.15rem;
  }
  .cat-scope {
    font-family: var(--bosc-mono);
    font-size: 0.74rem;
    color: var(--bosc-muted);
  }

  .cat-pill {
    display: inline-block;
    font-family: var(--bosc-mono);
    font-size: 0.7rem;
    padding: 0.05rem 0.4rem;
    border: 1px solid var(--bosc-rule);
    white-space: nowrap;
  }
  .tier-public { color: var(--td-verified); background: var(--td-verified-bg); border-color: var(--td-check-line); }
  .tier-throttled,
  .tier-restricted { color: var(--td-amber-text); border-color: var(--td-amber-rule); }

  .fresh-fresh { color: var(--td-verified); background: var(--td-verified-bg); border-color: var(--td-check-line); }
  .fresh-stale { color: var(--td-amber-text); background: var(--td-inference-bg); border-color: var(--td-amber-rule); }
  .fresh-missing { color: var(--bosc-danger); border-color: var(--bosc-danger); }
  .fresh-unmaterialized,
  .fresh-unknown { color: var(--td-open); background: var(--td-open-bg); }

  .cat-foot {
    font-size: 0.8rem;
    color: var(--bosc-muted);
    border-top: 1px solid var(--bosc-rule);
    padding-top: 1rem;
    margin-top: 2.5rem;
    max-width: 64ch;
  }
</style>
