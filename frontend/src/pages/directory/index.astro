---
/**
 * The network directory (#304; route /directory) — reimagined as a three-lens index (#308
 * "Directory" dictate): one network, read three ways. The same 32 sites reorganize around one
 * of three hypotheses — H1 Water & Power (the live reference thesis), H2 Defense & Federal
 * Enclave, H3 Corporate & Economic Surveillance. The lens switch is no-JS (radio + :checked),
 * so the page reads with JavaScript off, like every Watermark page.
 *
 * Discipline (see `lib/directory.ts`): H2/H3 are hypotheses under test. A site carries a
 * defense/surveillance entry only with a real, on-the-record fact; inference is labeled; the
 * rest are "Not yet assessed". Counts are real (Lima from the bundle) or a dash — never invented.
 */
import Base from "../../layouts/Base.astro";
import { hasFeed, loadFeed, loadManifest } from "../../lib/bundle";
import { buildLens, indexAssessments, LENS_ORDER, lensConfig, lensCount } from "../../lib/directory";
import type {
  DocumentCollectionItem,
  HypothesisAssessmentItem,
  HypothesisItem,
} from "../../lib/feeds";
import { withBase } from "../../lib/site";

const manifest = loadManifest();
const byName = new Map(manifest.feeds.map((f) => [f.name, f]));
const feedCount = (n: string): number => byName.get(n)?.count ?? 0;
const num = (n: number): string => n.toLocaleString("en-US");

// Lima's real figures from the live bundle — the only fully-assembled site today.
const documents = hasFeed("documents") ? loadFeed<DocumentCollectionItem[]>("documents") : [];
const nFiles = documents.reduce((a, c) => a + c.entries.length, 0);
const nRecords = feedCount("records");
const limaCounts = { docs: nFiles ? num(nFiles) : "—", records: nRecords ? num(nRecords) : "—" };

// The boom-origin hypotheses + their (site x hypothesis) evidence cells (#308) — now read from
// the bundle, no longer hardcoded in directory.ts. Each cell carries a Citation (provenance).
const hypItems = hasFeed("hypotheses") ? loadFeed<HypothesisItem[]>("hypotheses") : [];
const hypByKey = new Map(hypItems.map((h) => [h.id, h]));
const cells = hasFeed("hypothesis-assessments")
  ? loadFeed<HypothesisAssessmentItem[]>("hypothesis-assessments")
  : [];
const lensData = indexAssessments(cells);

const lenses = LENS_ORDER.map((key) => ({
  cfg: lensConfig(key, hypByKey.get(key)),
  view: buildLens(key, limaCounts, lensData),
  count: lensCount(key, lensData),
}));

const statusSwatch = (kind: "live" | "new") =>
  kind === "live"
    ? { color: "#2e7d32", bg: "#e9f3ea", dot: "#2e7d32" }
    : { color: "#8a90a2", bg: "#eceef2", dot: "#aeb4c2" };
---

<Base
  title="The directory"
  section="directory"
  rail={false}
  description="The Watermark directory — one network of data-center watershed points across Ohio, read three ways: where compute meets water and power, where it meets the defense base, and who owns it. Lima is the live reference build."
>
  <div class="dir">
    <div class="dir-head">
      <div class="dir-eyebrow">Watermark · global section · the directory</div>
      <h1>Directory — one network, three hypotheses</h1>
      <p class="dir-lead">
        The platform-level index now holds <b>{lenses[0].count}</b>. The watershed lens — where
        compute meets water and power — is the live reference build (Lima / BOSC). Two further theses are opening
        alongside it: <b>defense &amp; federal-enclave</b> analysis, and <b>corporate &amp; economic surveillance</b>.
        The directory reads the same network through whichever lens you pick.
      </p>
    </div>

    <div class="dir-lenswrap">
      {
        lenses.map((l, i) => (
          <input
            type="radio"
            name="dir-lens"
            id={`lens-${l.cfg.key}`}
            class="dir-lens-input"
            checked={i === 0}
            aria-label={`${l.cfg.n} — ${l.cfg.name}`}
          />
        ))
      }

      <div class="dir-lens-cards">
        {
          lenses.map((l) => {
            const sw = statusSwatch(l.cfg.statusKind);
            return (
              <label
                for={`lens-${l.cfg.key}`}
                class:list={["dir-lcard", `lc-${l.cfg.key}`]}
                style={`--acc:${l.cfg.accent};--accbg:${l.cfg.accentBg}`}
              >
                <span class="dir-lcard-top">
                  <span class="dir-lcard-n" style={`background:${l.cfg.accent}`}>{l.cfg.n}</span>
                  <span class="dir-lcard-status" style={`color:${sw.color};background:${sw.bg}`}>
                    <span class="dot" style={`background:${sw.dot}`} />
                    {l.cfg.status}
                  </span>
                  <span class="dir-lcard-check" style={`color:${l.cfg.accent}`}>✓</span>
                </span>
                <span class="dir-lcard-name">{l.cfg.name}</span>
                <span class="dir-lcard-claim">{l.cfg.claim}</span>
                <span class="dir-lcard-count">{l.count}</span>
              </label>
            );
          })
        }
      </div>

      <p class="dir-lens-note">
        Not mutually exclusive — a single site can sit in all three. <b>Lima (BOSC)</b> is the worked example under each.
      </p>

      {
        lenses.map((l) => {
          const acc = l.cfg.accent;
          const sw = statusSwatch(l.cfg.statusKind);
          return (
            <div class:list={["dir-pane", `pane-${l.cfg.key}`]}>
              {/* Lens framing */}
              <div class="dir-frame" style={`background:${l.cfg.accentBg};border-color:${l.cfg.accentBd}`}>
                <div class="dir-frame-l">
                  <div class="dir-frame-tags">
                    <span class="dir-frame-name" style={`color:${acc}`}>
                      {l.cfg.n} · {l.cfg.name}
                    </span>
                    <span class="dir-frame-status" style={`color:${sw.color};background:${sw.bg}`}>
                      <span class="dot" style={`background:${sw.dot}`} />
                      {l.cfg.status}
                    </span>
                  </div>
                  <div class="dir-frame-claim">{l.cfg.claim}</div>
                  <p class="dir-frame-blurb">{l.cfg.blurb}</p>
                  {l.cfg.key === "water" && (
                    <a class="dir-frame-link" href={withBase("/directory/basin")}>
                      Open the drainage tree &amp; basin scorecard ›
                    </a>
                  )}
                </div>
                <div class="dir-frame-r">
                  <div class="dir-axis-title">{l.view.axisTitle}</div>
                  {l.view.axisGroups.map((ag) => (
                    <div class="dir-axis-group">
                      {ag.label && <div class="dir-axis-label">{ag.label}</div>}
                      <div class="dir-axis-chips">
                        {ag.chips.map((ch) => (
                          <span class="dir-achip">
                            {ch.name}
                            <span class="dir-achip-n">{ch.count}</span>
                          </span>
                        ))}
                      </div>
                    </div>
                  ))}
                </div>
              </div>

              {/* Cross-site scorecard */}
              <div class="dir-score">
                <div class="dir-score-head">
                  <div>
                    <div class="dir-score-eyebrow" style={`color:${acc}`}>Cross-site scorecard</div>
                    <h2 class="dir-score-title">{l.cfg.scoreTitle}</h2>
                  </div>
                  <span class="dir-score-note">{l.cfg.scoreNote}</span>
                </div>

                <div class="dir-table">
                  <div class="dir-trow dir-thead" style={`grid-template-columns:${l.view.gridCols}`}>
                    {l.view.cols.map((c) => (
                      <span class:list={["dir-th", { "is-right": c.align === "right" }]}>{c.label}</span>
                    ))}
                  </div>

                  {l.view.groups.map((g) => (
                    <div class="dir-group">
                      {g.divide && (
                        <div class="dir-divide" style={`color:${acc}`}>
                          <span class="dir-divide-l">{g.divide.label}</span>
                          <span class="dir-divide-n">{g.divide.note}</span>
                        </div>
                      )}
                      <div class="dir-grouphead">
                        <span class="dir-group-abbr" style={`color:${acc}`}>{g.abbr}</span>
                        <span class="dir-group-label">{g.label}</span>
                        <span class="dir-group-count">{g.count}</span>
                      </div>
                      {g.kind === "rows" ? (
                        g.rows.map((r) => (
                          <div
                            class:list={["dir-trow", "dir-drow", { "is-live": r.live }]}
                            style={`grid-template-columns:${l.view.gridCols}`}
                          >
                            {r.cells.map((c) =>
                              c.kind === "site" ? (
                                <span class="dir-cell-site">
                                  <span class="dir-badge" style={`background:${c.badgeBg};color:${c.badgeColor}`}>
                                    {c.badge}
                                  </span>
                                  <span class="dir-place">{c.place}</span>
                                </span>
                              ) : c.kind === "num" ? (
                                <span class:list={["dir-cell-num", { "is-muted": c.muted }]}>{c.text}</span>
                              ) : c.kind === "pill" && c.pill ? (
                                <span>
                                  <span class="dir-pill" style={`color:${c.pill.color};background:${c.pill.bg}`}>
                                    <span class="dot" style={`background:${c.pill.dot}`} />
                                    {c.pill.label}
                                  </span>
                                </span>
                              ) : (
                                <span class:list={["dir-cell-text", { "is-muted": c.muted }]}>{c.text}</span>
                              ),
                            )}
                          </div>
                        ))
                      ) : (
                        <div class="dir-chips">
                          {g.chips.map((ch) => (
                            <span class="dir-chip">
                              <span class="dot" style={`background:${ch.dot}`} />
                              {ch.place}
                            </span>
                          ))}
                        </div>
                      )}
                    </div>
                  ))}

                  <div class="dir-foot">{l.cfg.footNote}</div>
                </div>
              </div>
            </div>
          );
        })
      }
    </div>
  </div>
</Base>

<style>
  .dir {
    max-width: 1240px;
    margin: 0 auto;
  }
  .dir-eyebrow {
    font-size: 0.72rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--bosc-indigo);
    font-weight: 700;
  }
  .dir-head h1 {
    font-size: 2rem;
    font-weight: 800;
    letter-spacing: -0.02em;
    margin: 0.3rem 0 0.4rem;
  }
  .dir-lead {
    max-width: 60rem;
    font-size: 0.97rem;
    line-height: 1.6;
    color: var(--bosc-muted);
    margin: 0;
  }

  /* The no-JS lens switch: radios drive the active card + the visible pane. */
  .dir-lens-input {
    position: absolute;
    width: 1px;
    height: 1px;
    padding: 0;
    margin: -1px;
    overflow: hidden;
    clip: rect(0 0 0 0);
    white-space: nowrap;
    border: 0;
  }
  .dir-lens-cards {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 0.8rem;
    margin-top: 1.6rem;
  }
  .dir-lcard {
    display: flex;
    flex-direction: column;
    cursor: pointer;
    background: #fff;
    border: 1.5px solid #e3e5ec;
    border-radius: 14px;
    padding: 1rem 1.05rem;
    box-shadow: 0 1px 3px rgba(20, 24, 40, 0.05);
    transition:
      border-color 0.12s ease,
      box-shadow 0.12s ease;
  }
  .dir-lcard:hover {
    border-color: #aab1e0;
  }
  .dir-lcard-top {
    display: flex;
    align-items: center;
    gap: 0.55rem;
  }
  .dir-lcard-n {
    font-size: 0.68rem;
    font-weight: 800;
    font-family: var(--bosc-mono);
    color: #fff;
    border-radius: 6px;
    padding: 2px 8px;
  }
  .dir-lcard-status,
  .dir-frame-status {
    display: inline-flex;
    align-items: center;
    gap: 0.35rem;
    font-size: 0.64rem;
    font-weight: 700;
    border-radius: 999px;
    padding: 2px 9px;
  }
  .dir-lcard-status .dot,
  .dir-frame-status .dot {
    width: 5px;
    height: 5px;
    border-radius: 50%;
  }
  .dir-lcard-check {
    margin-left: auto;
    font-weight: 800;
    font-size: 0.88rem;
    display: none;
  }
  .dir-lcard-name {
    font-size: 1.05rem;
    font-weight: 800;
    letter-spacing: -0.01em;
    margin-top: 0.7rem;
  }
  .dir-lcard-claim {
    font-size: 0.82rem;
    color: var(--bosc-muted);
    line-height: 1.45;
    margin-top: 0.25rem;
  }
  .dir-lcard-count {
    margin-top: 0.7rem;
    padding-top: 0.6rem;
    border-top: 1px solid #eef0f4;
    font-size: 0.72rem;
    color: #8a90a2;
    font-family: var(--bosc-mono);
  }
  .dir-lens-note {
    font-size: 0.79rem;
    color: #8a90a2;
    line-height: 1.5;
    margin: 0.7rem 0 0;
  }

  /* Active card + visible pane, driven by the matching radio. */
  #lens-water:checked ~ .dir-lens-cards .lc-water,
  #lens-defense:checked ~ .dir-lens-cards .lc-defense,
  #lens-surveillance:checked ~ .dir-lens-cards .lc-surveillance {
    border-color: var(--acc);
    background: var(--accbg);
    box-shadow: 0 8px 22px rgba(20, 24, 40, 0.12);
  }
  #lens-water:checked ~ .dir-lens-cards .lc-water .dir-lcard-check,
  #lens-defense:checked ~ .dir-lens-cards .lc-defense .dir-lcard-check,
  #lens-surveillance:checked ~ .dir-lens-cards .lc-surveillance .dir-lcard-check {
    display: inline;
  }
  #lens-water:focus-visible ~ .dir-lens-cards .lc-water,
  #lens-defense:focus-visible ~ .dir-lens-cards .lc-defense,
  #lens-surveillance:focus-visible ~ .dir-lens-cards .lc-surveillance {
    outline: 2px solid var(--acc);
    outline-offset: 2px;
  }

  .dir-pane {
    display: none;
  }
  #lens-water:checked ~ .pane-water,
  #lens-defense:checked ~ .pane-defense,
  #lens-surveillance:checked ~ .pane-surveillance {
    display: block;
  }

  /* Lens framing */
  .dir-frame {
    margin-top: 1.3rem;
    border: 1px solid #e3e5ec;
    border-radius: 14px;
    padding: 1.25rem 1.35rem;
    display: flex;
    gap: 1.6rem;
    flex-wrap: wrap;
  }
  .dir-frame-l {
    flex: 1 1 380px;
    min-width: 300px;
  }
  .dir-frame-r {
    flex: 1 1 300px;
    min-width: 280px;
  }
  .dir-frame-tags {
    display: flex;
    align-items: center;
    gap: 0.6rem;
    flex-wrap: wrap;
  }
  .dir-frame-name {
    font-size: 0.68rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    font-weight: 800;
  }
  .dir-frame-claim {
    font-size: 1.2rem;
    font-weight: 800;
    letter-spacing: -0.01em;
    margin-top: 0.55rem;
  }
  .dir-frame-blurb {
    font-size: 0.84rem;
    line-height: 1.55;
    color: #3a3f4d;
    margin: 0.6rem 0 0;
    max-width: 36rem;
  }
  .dir-frame-link {
    display: inline-block;
    margin-top: 0.7rem;
    font-size: 0.82rem;
    font-weight: 700;
    color: var(--bosc-indigo);
    text-decoration: none;
  }
  .dir-frame-link:hover {
    text-decoration: underline;
  }
  .dir-axis-title {
    font-size: 0.64rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: #8a90a2;
    font-weight: 700;
    margin-bottom: 0.7rem;
  }
  .dir-axis-group {
    margin-bottom: 0.65rem;
  }
  .dir-axis-label {
    font-size: 0.7rem;
    font-weight: 700;
    color: #5b6172;
    margin-bottom: 0.4rem;
  }
  .dir-axis-chips {
    display: flex;
    flex-wrap: wrap;
    gap: 0.4rem;
  }
  .dir-achip {
    display: inline-flex;
    align-items: center;
    gap: 0.45rem;
    font-size: 0.72rem;
    font-weight: 600;
    color: #3a3f4d;
    background: #fff;
    border: 1px solid #e3e5ec;
    border-radius: 999px;
    padding: 3px 11px;
  }
  .dir-achip-n {
    font-size: 0.66rem;
    color: #aeb4c2;
    font-family: var(--bosc-mono);
  }

  /* Cross-site scorecard */
  .dir-score {
    margin-top: 1.9rem;
  }
  .dir-score-head {
    display: flex;
    align-items: flex-end;
    justify-content: space-between;
    gap: 1rem;
    margin-bottom: 0.85rem;
    flex-wrap: wrap;
  }
  .dir-score-eyebrow {
    font-size: 0.66rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    font-weight: 700;
  }
  .dir-score-title {
    font-size: 1.35rem;
    font-weight: 800;
    letter-spacing: -0.02em;
    margin: 0.3rem 0 0;
  }
  .dir-score-note {
    font-size: 0.78rem;
    color: #8a90a2;
    max-width: 24rem;
    text-align: right;
  }
  .dir-table {
    border: 1px solid #e3e5ec;
    border-radius: 14px;
    overflow: hidden;
  }
  .dir-trow {
    display: grid;
    column-gap: 1rem;
    align-items: center;
  }
  .dir-thead {
    background: #f7f8fb;
    border-bottom: 1px solid #e3e5ec;
    padding: 0.7rem 1.1rem;
    font-size: 0.62rem;
    letter-spacing: 0.05em;
    text-transform: uppercase;
    color: #8a90a2;
    font-weight: 700;
  }
  .dir-th.is-right {
    text-align: right;
  }
  .dir-divide {
    display: flex;
    align-items: baseline;
    gap: 0.7rem;
    padding: 0.8rem 1.1rem 0.55rem;
    background: #f1f3f7;
  }
  .dir-divide-l {
    font-size: 0.75rem;
    font-weight: 800;
    letter-spacing: 0.05em;
    text-transform: uppercase;
  }
  .dir-divide-n {
    font-size: 0.72rem;
    color: #8a90a2;
  }
  .dir-grouphead {
    display: flex;
    align-items: center;
    gap: 0.55rem;
    padding: 0.55rem 1.1rem;
    background: #fcfcfd;
    border-bottom: 1px solid #f1f2f5;
  }
  .dir-group-abbr {
    font-size: 0.6rem;
    font-weight: 800;
    letter-spacing: 0.03em;
    background: #eef0f4;
    border: 1px solid #d7dae4;
    border-radius: 5px;
    padding: 2px 7px;
    font-family: var(--bosc-mono);
  }
  .dir-group-label {
    font-size: 0.72rem;
    font-weight: 800;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    color: #5b6172;
  }
  .dir-group-count {
    margin-left: auto;
    font-size: 0.68rem;
    color: #aeb4c2;
    font-family: var(--bosc-mono);
  }
  .dir-drow {
    padding: 0.65rem 1.1rem;
    border-bottom: 1px solid #f1f2f5;
    background: #fff;
  }
  .dir-drow.is-live {
    background: #fafbff;
  }
  .dir-cell-site {
    display: flex;
    align-items: center;
    gap: 0.55rem;
    min-width: 0;
  }
  .dir-badge {
    flex: 0 0 auto;
    width: 30px;
    height: 30px;
    border-radius: 7px;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 0.58rem;
    font-weight: 800;
    font-family: var(--bosc-mono);
  }
  .dir-place {
    font-size: 0.86rem;
    font-weight: 700;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }
  .dir-cell-text {
    font-size: 0.78rem;
    line-height: 1.35;
    color: #5b6172;
  }
  .dir-cell-text.is-muted {
    color: #aeb4c2;
  }
  .dir-cell-num {
    text-align: right;
    font-size: 0.8rem;
    font-weight: 600;
    font-family: var(--bosc-mono);
    color: var(--bosc-ink);
  }
  .dir-cell-num.is-muted {
    color: #c0c4cf;
  }
  .dir-pill {
    display: inline-flex;
    align-items: center;
    gap: 0.35rem;
    font-size: 0.68rem;
    font-weight: 700;
    border-radius: 999px;
    padding: 3px 9px;
  }
  .dir-pill .dot {
    width: 5px;
    height: 5px;
    border-radius: 50%;
  }
  .dir-chips {
    padding: 0.75rem 1.1rem 0.95rem;
    display: flex;
    flex-wrap: wrap;
    gap: 0.45rem;
  }
  .dir-chip {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    font-size: 0.74rem;
    color: #5b6172;
    background: #f7f8fb;
    border: 1px solid #e8eaef;
    border-radius: 999px;
    padding: 4px 11px;
  }
  .dir-chip .dot {
    width: 6px;
    height: 6px;
    border-radius: 50%;
  }
  .dir-foot {
    padding: 0.7rem 1.1rem;
    background: #f7f8fb;
    font-size: 0.75rem;
    color: #8a90a2;
    line-height: 1.45;
  }

  @media (max-width: 760px) {
    .dir-lens-cards {
      grid-template-columns: 1fr;
    }
    .dir-score-note {
      text-align: left;
    }
    /* The scorecard scrolls horizontally on phones rather than crushing the columns. */
    .dir-table {
      overflow-x: auto;
    }
    .dir-trow {
      min-width: 640px;
    }
  }
</style>
