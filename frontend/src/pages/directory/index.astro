---
/**
 * The network directory (#304; route renamed /network → /directory in #402) — the section hub for
 * the watershed-point sites. It adopts the shared section-hub grammar (`.hub` / `.hub-head` /
 * `.hub-grid`, same as the corpus and watershed hubs): a door grid into the directory's
 * cross-cutting views (the basin), then the site grid itself with the two-clock status. Lima is the
 * live reference build; the basin sites link to their coming-soon page. The topbar switcher is the
 * primary entry; this is the section landing the registry resolves to.
 */
import Base from "../../layouts/Base.astro";
import { FACILITY_STATUS_META, facilityStatus, SITES, siteBadge } from "../../lib/sites";
import { withBase } from "../../lib/site";

// Two independent axes of status, never conflated:
//   (A) Site — OUR progress assembling the site/research (queued → building → live).
//   (B) Facility — the data center itself: whether it's a confirmed DC location, then campus
//       progress (investigation → confirmed → construction → live).
const statusLabel: Record<string, string> = {
  live: "Live",
  building: "Building",
  queued: "Queued",
  tracking: "Tracking",
};
const nSites = SITES.length;
const nLive = SITES.filter((s) => s.selectable).length;

// The directory's cross-cutting views, as section-hub doors (the shared `.hub-door` idiom).
const doors = [
  {
    id: "basin",
    kind: "Cross-site analysis",
    href: "/directory/basin",
    count: String(nSites),
    title: "The basin",
    desc: "The watershed points as nested nodes on one connected basin — a drainage tree and a cross-site scorecard, all draining to Lake Erie under one shared TMDL cap.",
    note: "one connected system",
  },
];
---

<Base
  title="The network directory"
  section="directory"
  rail={false}
  description="The Watermark network directory — data-center development across Ohio's Maumee watershed, point by point. Lima is the live reference build; the basin sites come online incrementally."
>
  <div class="hub">
    <div class="hub-head">
      <div>
        <div class="hub-eyebrow">Section · the network directory</div>
        <h1>One platform, watershed point by watershed point</h1>
        <p class="hub-lead">
          Watermark began as one campus on the Ottawa River in Lima. The same record grammar —
          provenance-first, inference labeled, redactions shown — generalizes across the Maumee basin,
          where the data-center build-out meets the watershed. <strong>Lima is the live reference build;</strong>
          the basin sites are coming online. Each is a section of one platform, cross-linked for real.
        </p>
      </div>
      <span class="hub-count"><span class="dot" aria-hidden="true"></span>{nSites} sites · {nLive} live</span>
    </div>

    <div class="hub-grid">
      {
        doors.map((d) => (
          <a class="hub-door" id={d.id} href={withBase(d.href)}>
            <div class="hub-door-top">
              <span class="hub-door-kind">{d.kind}</span>
              <span class="hub-door-count">{d.count}</span>
            </div>
            <div class="hub-door-title">{d.title}</div>
            <div class="hub-door-desc">{d.desc}</div>
            <div class="hub-door-foot">
              <span class="hub-door-browse">Open</span>
              <span class="hub-door-note">{d.note}</span>
              <span class="hub-door-arrow" aria-hidden="true">›</span>
            </div>
          </a>
        ))
      }
    </div>

    <section class="netdir-sites" aria-label="The sites">
      <div class="hub-eyebrow netdir-sites-head">The sites</div>
      <p class="netgrid-legend">
        Two clocks, kept separate: <strong>Site</strong> is our build of the record;
        <strong>Facility</strong> is the data center itself — whether it's a confirmed location, then
        campus progress. A queued site can document a live facility, and vice versa.
      </p>
      <div class="netgrid">
        {
          SITES.map((s) => {
            const fac = FACILITY_STATUS_META[facilityStatus(s.slug)];
            return (
              <a class:list={["netgrid-card", { "is-live": s.selectable, "is-soon": !s.selectable }]} href={withBase(s.href)}>
                <span class:list={["netgrid-badge", { "has-codename": Boolean(s.codename) }]}>{siteBadge(s)}</span>
                <span class="netgrid-body">
                  <span class="netgrid-place">
                    {s.codename && <span class="netgrid-codename">{s.codename}</span>}
                    {s.place}
                  </span>
                  <span class="netgrid-basin">{s.basin}</span>
                  <span class="netgrid-axes">
                    <span class="netgrid-axis">
                      <span class="netgrid-axis-k">Site</span>
                      <span class:list={["netgrid-status", `is-${s.status}`]}>{statusLabel[s.status]}</span>
                    </span>
                    <span class="netgrid-axis">
                      <span class="netgrid-axis-k">Facility</span>
                      <span class="netgrid-fac" style={`color:${fac.color};background:${fac.bg}`}>{fac.label}</span>
                    </span>
                  </span>
                </span>
                <span class="netgrid-meta">
                  <span class="netgrid-go">{s.selectable ? "Enter the site ›" : s.issue ? `Coming soon · #${s.issue}` : "Coming soon"}</span>
                </span>
              </a>
            );
          })
        }
      </div>
    </section>
  </div>
</Base>

<style>
  .netdir-sites {
    margin-top: 2.2rem;
  }
  .netdir-sites-head {
    margin-bottom: 0.4rem;
  }
  .netgrid-legend {
    margin: 0.4rem 0 1rem;
    font-size: 0.85rem;
    line-height: 1.5;
    color: #6b7280;
  }
  .netgrid-axes {
    display: flex;
    flex-wrap: wrap;
    gap: 0.35rem 0.9rem;
    margin-top: 0.5rem;
  }
  .netgrid-axis {
    display: inline-flex;
    align-items: center;
    gap: 0.35rem;
  }
  .netgrid-axis-k {
    font-size: 0.6rem;
    text-transform: uppercase;
    letter-spacing: 0.04em;
    color: #9aa1b2;
    font-weight: 700;
  }
  .netgrid-fac {
    font-size: 0.66rem;
    font-weight: 700;
    border-radius: 999px;
    padding: 2px 9px;
    white-space: nowrap;
  }
</style>
