-code\">Ohio Revised Code</a>\n\t\t\t</div>\n\n\t\t\t<div class=\"breadcrumbs-separator\">/</div>\n\n\t\t\t<div class=\"breadcrumbs-node\">\n\t\t\t\t<a href=\"/ohio-revised-code/general-provisions\">General Provisions</a>\n\t\t\t</div>\n\n\t\t\t<div class=\"breadcrumbs-separator\">/</div>\n\n\t\t\t<div class=\"breadcrumbs-node\">\n\t\t\t\t<a href=\"/ohio-revised-code/chapter-1\">Chapter 1 Definitions; Rules of Construction</a>\n\t\t\t</div>\n\n\t\t</div>\n\n\t\t\n\n\t\t\t<div class=\"profile-navigator no-print\">\n\n\t\t\t\t<div class=\"previous\">\n\t\t\t\t\t<a href=\"/ohio-revised-code/section-1.471\">\n\t\t\t\t\t\t<img src=\"/images/global/profile-pager/previous.png\" alt=\"Previous\">\n\t\t\t\t\t</a>\n\t\t\t\t</div>\n\n\t\t\t\t<div class=\"next\">\n\t\t\t\t\t<a href=\"/ohio-revised-code/section-1.49\">\n\t\t\t\t\t\t<img src=\"/images/global/profile-pager/next.png\" alt=\"Next\">\n\t\t\t\t\t</a>\n\t\t\t\t</div>\n\n\t\t\t</div>\n\n\t\t\n\n\t</section>\n\n\t<div class=\"clear\">&nbsp;</div>\n\n\t\n\n\t<div>\n\n\t\t\n\n\t\t\n\n\t</div>\n\n\t<div class=\"laws-section-info\">\n\n\t\t<div class=\"laws-section-info-module\">\n\t\t\t<div class=\"label\">Effective:</div>\n\t\t\t<div class=\"value\">January 3, 1972</div>\n\t\t</div>\n\n\t\t\n\n\t\t\n\n\t\t<div class=\"laws-section-info-module\">\n\t\t\t<div class=\"label\">Latest Legislation: </div>\n\t\t\t<div class=\"value\">House Bill 607 - 109th General Assembly</div>\n\t\t</div>\n\n\t\t<div class=\"laws-section-info-module no-print\">\n\t\t\t<div class=\"label\">PDF:</div>\n\t\t\t<div class=\"value\"><a target=\"_blank\" href=\"/assets/laws/revised-code/authenticated/0/1/1.48/1-3-1972/1.48-1-3-1972.pdf\">Download Authenticated PDF</a></div>\n\t\t</div>\n\t\t&nbsp;\n\t</div>\n\n\t<section class=\"laws-body\">\n\n\t\t<span><p>A statute is presumed to be prospective in its operation unless expressly made retrospective.</p></span>\n\n\t\t\n\n\t</section>\n\n\t\n\n\t\t<section class=\"laws-history\">\n\n\t\t\t<h2>Available