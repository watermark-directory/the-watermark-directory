data/documents/**/*.jpg filter=lfs diff=lfs merge=lfs -text
data/documents/**/*.jpeg filter=lfs diff=lfs merge=lfs -text
data/documents/**/*.tif filter=lfs diff=lfs merge=lfs -text
data/documents/**/*.tiff filter=lfs diff=lfs merge=lfs -text
data/documents/**/*.pdf filter=lfs diff=lfs merge=lfs -text
data/documents/**/*.doc filter=lfs diff=lfs merge=lfs -text
data/documents/**/*.docx filter=lfs diff=lfs merge=lfs -text
data/documents/**/*.xls filter=lfs diff=lfs merge=lfs -text
data/documents/**/*.xlsx filter=lfs diff=lfs merge=lfs -text
data/documents/**/*.rtf filter=lfs diff=lfs merge=lfs -text
data/documents/**/*.png filter=lfs diff=lfs merge=lfs -text
data/documents/**/*.odg filter=lfs diff=lfs merge=lfs -text
# *.wav is intentionally NOT LFS-tracked: hearing audio is multi-GB and lives in an
# evidence bucket, not git. It is git-ignored (see .gitignore) and recorded in
# data/documents/legal/select-committee-2026/hearings-audio/hearings-audio-externalized.yaml.
data/documents/**/*.mp3 filter=lfs diff=lfs merge=lfs -text
data/documents/**/*.m4a filter=lfs diff=lfs merge=lfs -text
data/documents/**/*.flac filter=lfs diff=lfs merge=lfs -text
# Captured web evidence (HTML/text): preserve the exact response bytes, including
# CRLF line endings — never normalize a source byte under data/documents (chain of
# custody). Small enough to stay in-repo (not LFS), unlike the scans above.
data/documents/**/*.html -text
data/documents/**/*.txt -text
# AOI-clipped satellite captures (`bosc imagery pull`) — committed reference evidence
# GeoTIFFs; large binaries, so LFS like the scans above. (Small test-fixture COGs
# under tests/fixtures/ deliberately stay in-repo so the suite is hermetic.)
data/reference/imagery/**/*.tif filter=lfs diff=lfs merge=lfs -text
data/reference/imagery/**/*.tiff filter=lfs diff=lfs merge=lfs -text

# Reference PDFs (authoritative outside maps/datasets) are large binaries — LFS-track them too.
data/reference/**/*.pdf filter=lfs diff=lfs merge=lfs -text
