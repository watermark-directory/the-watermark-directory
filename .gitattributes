# Captured web evidence (HTML/text): preserve the exact response bytes, including
# CRLF line endings — never normalize a source byte under data/documents (chain of
# custody). Small enough to stay in-repo (not LFS), unlike the scans above.
data/documents/**/*.html -text
data/documents/**/*.txt -text
