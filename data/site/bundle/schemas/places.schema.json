{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "places feed",
  "type": "array",
  "items": {
    "additionalProperties": false,
    "description": "A curated place (POI) profile — the place peer of a person profile.",
    "properties": {
      "slug": {
        "title": "Slug",
        "type": "string"
      },
      "name": {
        "title": "Name",
        "type": "string"
      },
      "kind": {
        "title": "Kind",
        "type": "string"
      },
      "depth": {
        "title": "Depth",
        "type": "string"
      },
      "parcels": {
        "items": {
          "type": "string"
        },
        "title": "Parcels",
        "type": "array"
      },
      "members": {
        "items": {
          "type": "string"
        },
        "title": "Members",
        "type": "array"
      },
      "aliases": {
        "items": {
          "type": "string"
        },
        "title": "Aliases",
        "type": "array"
      },
      "tags": {
        "items": {
          "type": "string"
        },
        "title": "Tags",
        "type": "array"
      },
      "location": {
        "anyOf": [
          {
            "$ref": "#/$defs/PlaceLocation"
          },
          {
            "type": "null"
          }
        ],
        "default": null
      },
      "track": {
        "anyOf": [
          {
            "$ref": "#/$defs/PlaceTrack"
          },
          {
            "type": "null"
          }
        ],
        "default": null
      },
      "relationships": {
        "items": {
          "$ref": "#/$defs/PlaceRelationship"
        },
        "title": "Relationships",
        "type": "array"
      },
      "citations": {
        "items": {
          "$ref": "#/$defs/Citation"
        },
        "title": "Citations",
        "type": "array"
      },
      "body": {
        "default": "",
        "title": "Body",
        "type": "string"
      }
    },
    "required": [
      "slug",
      "name",
      "kind",
      "depth"
    ],
    "title": "PlaceItem",
    "type": "object"
  },
  "$defs": {
    "Citation": {
      "additionalProperties": false,
      "description": "Structured provenance for a feed item or a single figure.\n\nMirrors :class:`bosc.hydrology.model.ProvenancedValue`'s evidence discipline so the\nwhole bundle speaks one provenance language: ``source_kind`` says where the value\ncame from, ``source`` is the citable artifact (a repo-relative ``data/`` path, an\nexternal dataset label, a permit/instrument number), ``page`` locates it within a\nmulti-page source, and ``verified`` is derived so a consumer never re-computes it.",
      "properties": {
        "source": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Source"
        },
        "source_kind": {
          "default": "document",
          "enum": [
            "document",
            "connector",
            "reference",
            "assumption",
            "derived"
          ],
          "title": "Source Kind",
          "type": "string"
        },
        "page": {
          "anyOf": [
            {
              "type": "integer"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Page"
        },
        "confidence": {
          "default": "medium",
          "enum": [
            "high",
            "medium",
            "low"
          ],
          "title": "Confidence",
          "type": "string"
        },
        "note": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Note"
        },
        "verified": {
          "description": "True when grounded in a record or a live gauge (``[verified]`` in prose).",
          "readOnly": true,
          "title": "Verified",
          "type": "boolean"
        }
      },
      "required": [
        "verified"
      ],
      "title": "Citation",
      "type": "object"
    },
    "PlaceLocation": {
      "additionalProperties": false,
      "properties": {
        "method": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Method"
        },
        "confidence": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Confidence"
        },
        "asof": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Asof"
        },
        "bbox": {
          "anyOf": [
            {
              "items": {
                "type": "number"
              },
              "type": "array"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Bbox"
        }
      },
      "title": "PlaceLocation",
      "type": "object"
    },
    "PlaceRelationship": {
      "additionalProperties": false,
      "properties": {
        "role": {
          "title": "Role",
          "type": "string"
        },
        "entity": {
          "title": "Entity",
          "type": "string"
        }
      },
      "required": [
        "role",
        "entity"
      ],
      "title": "PlaceRelationship",
      "type": "object"
    },
    "PlaceTrack": {
      "additionalProperties": false,
      "properties": {
        "enabled": {
          "default": false,
          "title": "Enabled",
          "type": "boolean"
        },
        "collections": {
          "items": {
            "type": "string"
          },
          "title": "Collections",
          "type": "array"
        },
        "since": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Since"
        }
      },
      "title": "PlaceTrack",
      "type": "object"
    }
  }
}
