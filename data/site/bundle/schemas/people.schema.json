{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "people feed",
  "type": "array",
  "items": {
    "additionalProperties": false,
    "description": "A curated individual profile (only expanded-research ones are published).",
    "properties": {
      "slug": {
        "title": "Slug",
        "type": "string"
      },
      "name": {
        "title": "Name",
        "type": "string"
      },
      "entity_key": {
        "anyOf": [
          {
            "type": "string"
          },
          {
            "type": "null"
          }
        ],
        "default": null,
        "title": "Entity Key"
      },
      "aliases": {
        "items": {
          "type": "string"
        },
        "title": "Aliases",
        "type": "array"
      },
      "roles": {
        "items": {
          "type": "string"
        },
        "title": "Roles",
        "type": "array"
      },
      "affiliations": {
        "items": {
          "type": "string"
        },
        "title": "Affiliations",
        "type": "array"
      },
      "summary": {
        "anyOf": [
          {
            "type": "string"
          },
          {
            "type": "null"
          }
        ],
        "default": null,
        "title": "Summary"
      },
      "expanded": {
        "default": false,
        "title": "Expanded",
        "type": "boolean"
      },
      "tags": {
        "items": {
          "type": "string"
        },
        "title": "Tags",
        "type": "array"
      },
      "sources": {
        "items": {
          "$ref": "#/$defs/Citation"
        },
        "title": "Sources",
        "type": "array"
      },
      "body": {
        "default": "",
        "title": "Body",
        "type": "string"
      }
    },
    "required": [
      "slug",
      "name"
    ],
    "title": "PersonItem",
    "type": "object"
  },
  "$defs": {
    "Citation": {
      "additionalProperties": false,
      "description": "Structured provenance for a feed item or a single figure.\n\nMirrors :class:`bosc.hydrology.model.ProvenancedValue`'s evidence discipline so the\nwhole bundle speaks one provenance language: ``source_kind`` says where the value\ncame from, ``source`` is the citable artifact (a repo-relative ``data/`` path, an\nexternal dataset label, a permit/instrument number), ``page`` locates it within a\nmulti-page source, and ``verified`` is derived so a consumer never re-computes it.",
      "properties": {
        "source": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Source"
        },
        "source_kind": {
          "default": "document",
          "enum": [
            "document",
            "connector",
            "reference",
            "assumption",
            "derived"
          ],
          "title": "Source Kind",
          "type": "string"
        },
        "page": {
          "anyOf": [
            {
              "type": "integer"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Page"
        },
        "confidence": {
          "default": "medium",
          "enum": [
            "high",
            "medium",
            "low"
          ],
          "title": "Confidence",
          "type": "string"
        },
        "note": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Note"
        },
        "verified": {
          "description": "True when grounded in a record or a live gauge (``[verified]`` in prose).",
          "readOnly": true,
          "title": "Verified",
          "type": "boolean"
        }
      },
      "required": [
        "verified"
      ],
      "title": "Citation",
      "type": "object"
    }
  }
}
