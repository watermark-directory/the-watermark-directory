{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "hydrology-scenarios feed",
  "type": "array",
  "items": {
    "additionalProperties": false,
    "description": "A scenario evaluated against the water balance + cited low flows.",
    "properties": {
      "scenario": {
        "$ref": "#/$defs/Scenario"
      },
      "consumptive_loss": {
        "$ref": "#/$defs/ProvenancedValue"
      },
      "receiving_7q10": {
        "anyOf": [
          {
            "$ref": "#/$defs/ProvenancedValue"
          },
          {
            "type": "null"
          }
        ],
        "default": null
      },
      "receiving_live": {
        "anyOf": [
          {
            "$ref": "#/$defs/ProvenancedValue"
          },
          {
            "type": "null"
          }
        ],
        "default": null
      },
      "receiving_water_name": {
        "anyOf": [
          {
            "type": "string"
          },
          {
            "type": "null"
          }
        ],
        "default": null,
        "title": "Receiving Water Name"
      },
      "balance": {
        "$ref": "#/$defs/WaterBalance"
      },
      "assimilative": {
        "items": {
          "$ref": "#/$defs/AssimilativeCheck"
        },
        "title": "Assimilative",
        "type": "array"
      }
    },
    "required": [
      "scenario",
      "consumptive_loss",
      "balance",
      "assimilative"
    ],
    "title": "ScenarioResult",
    "type": "object"
  },
  "$defs": {
    "AssimilativeCheck": {
      "additionalProperties": false,
      "description": "Low-flow dilution of one discharge into its receiving water.\n\nThe dilution ratio is ``(design_low_flow + upstream_returns) / discharge``.\nA screening heuristic flags the result; it is **not** a permit determination.",
      "properties": {
        "receiving_water": {
          "title": "Receiving Water",
          "type": "string"
        },
        "discharger": {
          "title": "Discharger",
          "type": "string"
        },
        "design_low_flow": {
          "$ref": "#/$defs/ProvenancedValue"
        },
        "discharge": {
          "$ref": "#/$defs/ProvenancedValue"
        },
        "upstream_returns": {
          "anyOf": [
            {
              "$ref": "#/$defs/ProvenancedValue"
            },
            {
              "type": "null"
            }
          ],
          "default": null
        },
        "dilution_ratio": {
          "title": "Dilution Ratio",
          "type": "number"
        },
        "flag": {
          "enum": [
            "ok",
            "tight",
            "violation"
          ],
          "title": "Flag",
          "type": "string"
        },
        "detail": {
          "title": "Detail",
          "type": "string"
        }
      },
      "required": [
        "receiving_water",
        "discharger",
        "design_low_flow",
        "discharge",
        "dilution_ratio",
        "flag",
        "detail"
      ],
      "title": "AssimilativeCheck",
      "type": "object"
    },
    "CoolingBasis": {
      "additionalProperties": false,
      "description": "A sourced cooling-water design basis, derived from disclosed campus data.\n\nTwo independent estimates bracket the demand: a top-down power x WUE balance\n(disclosed backup generation -> IT load -> evaporative makeup) and a bottom-up\nblowdown x cycles-of-concentration check (documented FM-2 discharge). The\ninputs are document/assumption-tagged; the demands are ``derived``.",
      "properties": {
        "it_load": {
          "$ref": "#/$defs/ProvenancedValue"
        },
        "wue": {
          "$ref": "#/$defs/ProvenancedValue"
        },
        "cycles_of_concentration": {
          "$ref": "#/$defs/ProvenancedValue"
        },
        "consumptive_fraction": {
          "$ref": "#/$defs/ProvenancedValue"
        },
        "makeup_demand": {
          "$ref": "#/$defs/ProvenancedValue"
        },
        "consumptive_low": {
          "$ref": "#/$defs/ProvenancedValue"
        },
        "consumptive_high": {
          "$ref": "#/$defs/ProvenancedValue"
        },
        "method": {
          "default": "power x WUE (central); blowdown x cycles (upper bound)",
          "title": "Method",
          "type": "string"
        }
      },
      "required": [
        "it_load",
        "wue",
        "cycles_of_concentration",
        "consumptive_fraction",
        "makeup_demand",
        "consumptive_low",
        "consumptive_high"
      ],
      "title": "CoolingBasis",
      "type": "object"
    },
    "Node": {
      "additionalProperties": false,
      "description": "A point in the municipal water loop (a plant, a demand center, a stream).",
      "properties": {
        "id": {
          "title": "Id",
          "type": "string"
        },
        "name": {
          "title": "Name",
          "type": "string"
        },
        "role": {
          "enum": [
            "abstraction",
            "demand",
            "wwtp",
            "receiving"
          ],
          "title": "Role",
          "type": "string"
        },
        "receiving_water": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Receiving Water"
        },
        "lat": {
          "anyOf": [
            {
              "type": "number"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Lat"
        },
        "lon": {
          "anyOf": [
            {
              "type": "number"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Lon"
        }
      },
      "required": [
        "id",
        "name",
        "role"
      ],
      "title": "Node",
      "type": "object"
    },
    "ProvenancedValue": {
      "additionalProperties": false,
      "description": "A single numeric quantity tagged with its provenance.\n\nConstruct via the classmethods (:meth:`from_document`, :meth:`from_connector`,\n:meth:`assume`, :meth:`derived`) so the ``source`` tag is never forgotten.",
      "properties": {
        "value": {
          "title": "Value",
          "type": "number"
        },
        "unit": {
          "title": "Unit",
          "type": "string"
        },
        "source": {
          "enum": [
            "document",
            "connector",
            "reference",
            "assumption",
            "derived"
          ],
          "title": "Source",
          "type": "string"
        },
        "citation": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Citation"
        },
        "confidence": {
          "default": "medium",
          "enum": [
            "high",
            "medium",
            "low"
          ],
          "title": "Confidence",
          "type": "string"
        },
        "asof": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Asof"
        }
      },
      "required": [
        "value",
        "unit",
        "source"
      ],
      "title": "ProvenancedValue",
      "type": "object"
    },
    "Scenario": {
      "additionalProperties": false,
      "description": "A what-if over the municipal loop, parameterized by the cooling knob.\n\nThe data-center campus draws cooling water from the same Ottawa/Auglaize supply\nthe WWTPs discharge to; the evaporated (consumptive) fraction is a net loss to\nthe basin. The knobs default to the sourced :class:`CoolingBasis` but remain\noverridable — this is a sensitivity, not a forecast.",
      "properties": {
        "name": {
          "title": "Name",
          "type": "string"
        },
        "description": {
          "default": "",
          "title": "Description",
          "type": "string"
        },
        "cooling_demand": {
          "$ref": "#/$defs/ProvenancedValue"
        },
        "consumptive_fraction": {
          "$ref": "#/$defs/ProvenancedValue"
        },
        "basis": {
          "anyOf": [
            {
              "$ref": "#/$defs/CoolingBasis"
            },
            {
              "type": "null"
            }
          ],
          "default": null
        }
      },
      "required": [
        "name",
        "cooling_demand",
        "consumptive_fraction"
      ],
      "title": "Scenario",
      "type": "object"
    },
    "WaterBalance": {
      "additionalProperties": false,
      "description": "The assembled source -> use -> WWTP -> receiving loop.",
      "properties": {
        "nodes": {
          "items": {
            "$ref": "#/$defs/WaterBalanceNode"
          },
          "title": "Nodes",
          "type": "array"
        },
        "tier": {
          "const": "tier0",
          "default": "tier0",
          "title": "Tier",
          "type": "string"
        },
        "warnings": {
          "default": [],
          "items": {
            "type": "string"
          },
          "title": "Warnings",
          "type": "array"
        }
      },
      "required": [
        "nodes"
      ],
      "title": "WaterBalance",
      "type": "object"
    },
    "WaterBalanceNode": {
      "additionalProperties": false,
      "description": "One node's flow terms. Conservation: inflow + stormwater = return + consumptive.\n\nTerms are optional — a node carries only what's known/relevant (an abstraction\nnode has ``inflow``; a demand node has ``consumptive_use`` + ``return_flow``).\nAll flows are in **cfs**. ``stormwater`` is the Increment-2 seam: a cited zero\ntoday, filled by the SCS-CN solver later.",
      "properties": {
        "node": {
          "$ref": "#/$defs/Node"
        },
        "inflow": {
          "anyOf": [
            {
              "$ref": "#/$defs/ProvenancedValue"
            },
            {
              "type": "null"
            }
          ],
          "default": null
        },
        "consumptive_use": {
          "anyOf": [
            {
              "$ref": "#/$defs/ProvenancedValue"
            },
            {
              "type": "null"
            }
          ],
          "default": null
        },
        "return_flow": {
          "anyOf": [
            {
              "$ref": "#/$defs/ProvenancedValue"
            },
            {
              "type": "null"
            }
          ],
          "default": null
        },
        "stormwater": {
          "anyOf": [
            {
              "$ref": "#/$defs/ProvenancedValue"
            },
            {
              "type": "null"
            }
          ],
          "default": null
        }
      },
      "required": [
        "node"
      ],
      "title": "WaterBalanceNode",
      "type": "object"
    }
  }
}
