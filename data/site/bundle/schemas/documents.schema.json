{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "documents feed",
  "type": "array",
  "items": {
    "additionalProperties": false,
    "description": "A first-level collection under data/documents and its catalogued entries.",
    "properties": {
      "slug": {
        "title": "Slug",
        "type": "string"
      },
      "title": {
        "title": "Title",
        "type": "string"
      },
      "description": {
        "default": "",
        "title": "Description",
        "type": "string"
      },
      "entries": {
        "items": {
          "$ref": "#/$defs/DocumentItem"
        },
        "title": "Entries",
        "type": "array"
      }
    },
    "required": [
      "slug",
      "title"
    ],
    "title": "DocumentCollectionItem",
    "type": "object"
  },
  "$defs": {
    "DocumentItem": {
      "additionalProperties": false,
      "description": "One source document in the catalog, addressed by its corpus path.",
      "properties": {
        "rel": {
          "title": "Rel",
          "type": "string"
        },
        "name": {
          "title": "Name",
          "type": "string"
        },
        "size_bytes": {
          "title": "Size Bytes",
          "type": "integer"
        },
        "suffix": {
          "title": "Suffix",
          "type": "string"
        },
        "available": {
          "title": "Available",
          "type": "boolean"
        },
        "download_url": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Download Url"
        }
      },
      "required": [
        "rel",
        "name",
        "size_bytes",
        "suffix",
        "available"
      ],
      "title": "DocumentItem",
      "type": "object"
    }
  }
}
