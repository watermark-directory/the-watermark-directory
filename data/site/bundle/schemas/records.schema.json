{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "records feed",
  "type": "array",
  "items": {
    "additionalProperties": false,
    "description": "One committed extraction, contractor-/genre-agnostic (mirrors records.py).\n\n``fields`` is the raw payload block verbatim (so the ``~`` marker survives in any\ntranscribed scalar); ``approximate_paths`` lists the dotted field paths whose value\ncarried that marker, and ``citation`` is the structured provenance footer.",
    "properties": {
      "rel": {
        "title": "Rel",
        "type": "string"
      },
      "group": {
        "enum": [
          "deeds",
          "permits-epa",
          "permits-npdes",
          "permits-sos",
          "plans",
          "opc"
        ],
        "title": "Group",
        "type": "string"
      },
      "title": {
        "title": "Title",
        "type": "string"
      },
      "confidence": {
        "anyOf": [
          {
            "type": "string"
          },
          {
            "type": "null"
          }
        ],
        "default": null,
        "title": "Confidence"
      },
      "warnings": {
        "items": {
          "type": "string"
        },
        "title": "Warnings",
        "type": "array"
      },
      "fields": {
        "additionalProperties": true,
        "title": "Fields",
        "type": "object"
      },
      "approximate_paths": {
        "items": {
          "type": "string"
        },
        "title": "Approximate Paths",
        "type": "array"
      },
      "citation": {
        "$ref": "#/$defs/Citation"
      },
      "source_doc_rel": {
        "anyOf": [
          {
            "type": "string"
          },
          {
            "type": "null"
          }
        ],
        "default": null,
        "title": "Source Doc Rel"
      },
      "source_doc_render_class": {
        "anyOf": [
          {
            "enum": [
              "image",
              "text",
              "html",
              "pdf",
              "office",
              "other"
            ],
            "type": "string"
          },
          {
            "type": "null"
          }
        ],
        "default": null,
        "title": "Source Doc Render Class"
      },
      "source_doc_published": {
        "default": false,
        "title": "Source Doc Published",
        "type": "boolean"
      }
    },
    "required": [
      "rel",
      "group",
      "title",
      "citation"
    ],
    "title": "RecordItem",
    "type": "object"
  },
  "$defs": {
    "Citation": {
      "additionalProperties": false,
      "description": "Structured provenance for a feed item or a single figure.\n\nMirrors :class:`watermark.hydrology.model.ProvenancedValue`'s evidence discipline so the\nwhole bundle speaks one provenance language: ``source_kind`` says where the value\ncame from, ``source`` is the citable artifact (a repo-relative ``data/`` path, an\nexternal dataset label, a permit/instrument number), ``page`` locates it within a\nmulti-page source, and ``verified`` is derived so a consumer never re-computes it.",
      "properties": {
        "source": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Source"
        },
        "source_kind": {
          "default": "document",
          "enum": [
            "document",
            "connector",
            "reference",
            "assumption",
            "derived"
          ],
          "title": "Source Kind",
          "type": "string"
        },
        "page": {
          "anyOf": [
            {
              "type": "integer"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Page"
        },
        "confidence": {
          "default": "medium",
          "enum": [
            "high",
            "medium",
            "low"
          ],
          "title": "Confidence",
          "type": "string"
        },
        "note": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Note"
        },
        "verified": {
          "description": "True when grounded in a record or a live gauge (``[verified]`` in prose).",
          "readOnly": true,
          "title": "Verified",
          "type": "boolean"
        }
      },
      "required": [
        "verified"
      ],
      "title": "Citation",
      "type": "object"
    }
  }
}
