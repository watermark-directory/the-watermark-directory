{
  "$defs": {
    "IndustryEmployment": {
      "additionalProperties": false,
      "description": "A county's employment by NAICS sector for one year (BLS QCEW).",
      "properties": {
        "fips": {
          "title": "Fips",
          "type": "string"
        },
        "area_name": {
          "title": "Area Name",
          "type": "string"
        },
        "year": {
          "title": "Year",
          "type": "integer"
        },
        "total_employment": {
          "$ref": "#/$defs/ProvenancedValue"
        },
        "establishments": {
          "anyOf": [
            {
              "$ref": "#/$defs/ProvenancedValue"
            },
            {
              "type": "null"
            }
          ],
          "default": null
        },
        "sectors": {
          "items": {
            "$ref": "#/$defs/SectorEmployment"
          },
          "title": "Sectors",
          "type": "array"
        },
        "source": {
          "default": "BLS QCEW (annual averages, private ownership by NAICS sector)",
          "title": "Source",
          "type": "string"
        }
      },
      "required": [
        "fips",
        "area_name",
        "year",
        "total_employment",
        "sectors"
      ],
      "title": "IndustryEmployment",
      "type": "object"
    },
    "PopulationPoint": {
      "additionalProperties": false,
      "description": "County population in one year (Census).",
      "properties": {
        "year": {
          "title": "Year",
          "type": "integer"
        },
        "population": {
          "$ref": "#/$defs/ProvenancedValue"
        }
      },
      "required": [
        "year",
        "population"
      ],
      "title": "PopulationPoint",
      "type": "object"
    },
    "PopulationSeries": {
      "additionalProperties": false,
      "description": "County population over time — present only when a Census source is available.",
      "properties": {
        "fips": {
          "title": "Fips",
          "type": "string"
        },
        "area_name": {
          "title": "Area Name",
          "type": "string"
        },
        "points": {
          "items": {
            "$ref": "#/$defs/PopulationPoint"
          },
          "title": "Points",
          "type": "array"
        },
        "source": {
          "default": "US Census ACS 5-year (B01003)",
          "title": "Source",
          "type": "string"
        }
      },
      "required": [
        "fips",
        "area_name",
        "points"
      ],
      "title": "PopulationSeries",
      "type": "object"
    },
    "ProvenancedValue": {
      "additionalProperties": false,
      "description": "A single numeric quantity tagged with its provenance.\n\nConstruct via the classmethods (:meth:`from_document`, :meth:`from_connector`,\n:meth:`assume`, :meth:`derived`) so the ``source`` tag is never forgotten.",
      "properties": {
        "value": {
          "title": "Value",
          "type": "number"
        },
        "unit": {
          "title": "Unit",
          "type": "string"
        },
        "source": {
          "enum": [
            "document",
            "connector",
            "reference",
            "assumption",
            "derived"
          ],
          "title": "Source",
          "type": "string"
        },
        "citation": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Citation"
        },
        "confidence": {
          "default": "medium",
          "enum": [
            "high",
            "medium",
            "low"
          ],
          "title": "Confidence",
          "type": "string"
        },
        "asof": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Asof"
        }
      },
      "required": [
        "value",
        "unit",
        "source"
      ],
      "title": "ProvenancedValue",
      "type": "object"
    },
    "SectorEmployment": {
      "additionalProperties": false,
      "description": "One NAICS sector's county employment, with its export-orientation location quotient.",
      "properties": {
        "naics": {
          "title": "Naics",
          "type": "string"
        },
        "sector_name": {
          "title": "Sector Name",
          "type": "string"
        },
        "annual_avg_employment": {
          "$ref": "#/$defs/ProvenancedValue"
        },
        "establishments": {
          "anyOf": [
            {
              "$ref": "#/$defs/ProvenancedValue"
            },
            {
              "type": "null"
            }
          ],
          "default": null
        },
        "location_quotient": {
          "anyOf": [
            {
              "$ref": "#/$defs/ProvenancedValue"
            },
            {
              "type": "null"
            }
          ],
          "default": null
        }
      },
      "required": [
        "naics",
        "sector_name",
        "annual_avg_employment"
      ],
      "title": "SectorEmployment",
      "type": "object"
    },
    "YearTotal": {
      "additionalProperties": false,
      "description": "Total covered employment in one year — a point on the trend.",
      "properties": {
        "year": {
          "title": "Year",
          "type": "integer"
        },
        "total_employment": {
          "$ref": "#/$defs/ProvenancedValue"
        }
      },
      "required": [
        "year",
        "total_employment"
      ],
      "title": "YearTotal",
      "type": "object"
    }
  },
  "additionalProperties": false,
  "description": "The assembled localized baseline: latest industry mix + employment trend (+ population).",
  "properties": {
    "fips": {
      "title": "Fips",
      "type": "string"
    },
    "area_name": {
      "title": "Area Name",
      "type": "string"
    },
    "latest": {
      "$ref": "#/$defs/IndustryEmployment"
    },
    "trend": {
      "default": [],
      "items": {
        "$ref": "#/$defs/YearTotal"
      },
      "title": "Trend",
      "type": "array"
    },
    "population": {
      "anyOf": [
        {
          "$ref": "#/$defs/PopulationSeries"
        },
        {
          "type": "null"
        }
      ],
      "default": null
    },
    "note": {
      "default": "",
      "title": "Note",
      "type": "string"
    }
  },
  "required": [
    "fips",
    "area_name",
    "latest"
  ],
  "title": "EconomicBaseline",
  "type": "object",
  "$schema": "https://json-schema.org/draft/2020-12/schema"
}
