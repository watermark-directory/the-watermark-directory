{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "hypothesis-assessments feed",
  "type": "array",
  "items": {
    "additionalProperties": false,
    "description": "One ``(site x hypothesis)`` evidence cell — the join object joining the three axes.\n\nA site's standing under one hypothesis: a :attr:`signal` strength, an evidentiary\n:attr:`tag`, the hypothesis's taxonomy :attr:`group`, the per-hypothesis :attr:`fields`,\nand ≥1 :class:`Citation` (required for any non-``open`` cell). ``site`` is a slug — it\nmay name a *tracking* candidate not yet in :data:`watermark.sites.SITES` (the frontend lists\ntracked points too), so site membership is not hard-enforced here.",
    "properties": {
      "site": {
        "title": "Site",
        "type": "string"
      },
      "hypothesis": {
        "title": "Hypothesis",
        "type": "string"
      },
      "signal": {
        "anyOf": [
          {
            "enum": [
              "anchor",
              "strong",
              "moderate",
              "watch"
            ],
            "type": "string"
          },
          {
            "type": "null"
          }
        ],
        "default": null,
        "title": "Signal"
      },
      "tag": {
        "default": "open",
        "enum": [
          "verified",
          "inference",
          "open"
        ],
        "title": "Tag",
        "type": "string"
      },
      "group": {
        "anyOf": [
          {
            "type": "string"
          },
          {
            "type": "null"
          }
        ],
        "default": null,
        "title": "Group"
      },
      "fields": {
        "additionalProperties": {
          "type": "string"
        },
        "title": "Fields",
        "type": "object"
      },
      "citations": {
        "items": {
          "$ref": "#/$defs/Citation"
        },
        "title": "Citations",
        "type": "array"
      }
    },
    "required": [
      "site",
      "hypothesis"
    ],
    "title": "HypothesisAssessment",
    "type": "object"
  },
  "$defs": {
    "Citation": {
      "additionalProperties": false,
      "description": "Where a cell's facts came from — the provenance the old LENS_DATA lacked.\n\nField-compatible with :class:`watermark.site.feeds.Citation` so a cell exports to the\ncontent bundle without translation. ``source_kind`` says what kind of artifact backs\nthe fact; ``verified`` is derived (a record or a live gauge), so a consumer never\nrecomputes it. An inferred connection uses ``source_kind='assumption'``.",
      "properties": {
        "source": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Source"
        },
        "source_kind": {
          "default": "reference",
          "enum": [
            "document",
            "connector",
            "reference",
            "assumption",
            "derived"
          ],
          "title": "Source Kind",
          "type": "string"
        },
        "page": {
          "anyOf": [
            {
              "type": "integer"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Page"
        },
        "confidence": {
          "default": "medium",
          "enum": [
            "high",
            "medium",
            "low"
          ],
          "title": "Confidence",
          "type": "string"
        },
        "note": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Note"
        },
        "verified": {
          "description": "True when grounded in a record or a live gauge ([verified] in prose).",
          "readOnly": true,
          "title": "Verified",
          "type": "boolean"
        }
      },
      "required": [
        "verified"
      ],
      "title": "Citation",
      "type": "object"
    }
  }
}
