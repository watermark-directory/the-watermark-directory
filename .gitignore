# Ephemeral Claude agent worktrees (linked worktrees live under .claude/; each is a
# full repo copy — never track them from the parent worktree). Ignore everything
# under .claude/ EXCEPT the committed investigative-method skill layer, which is a
# tracked repo artifact (see docs/investigative-method/). Negate the directory (not
# a glob) so git descends into it; never negate .claude/worktrees.
.claude/*
!.claude/skills/

# Python
__pycache__/
*.py[cod]
*.egg-info/
.eggs/
build/
dist/
.venv/
venv/

# Tooling caches — centralized under .cache/ (configured in pyproject.toml)
.cache/
.coverage
htmlcov/

# uv
uv.lock.bak

# Node — root-level dev tooling only (Markdown lint, markdownlint-cli2). The Astro
# site under frontend/ has its own node_modules (ignored by frontend/.gitignore).
# package.json + package-lock.json ARE committed; node_modules is not.
node_modules/

# Environment / secrets
.env
.env.*
!.env.example

# Editor / OS
.DS_Store
.idea/
.vscode/

# ---------------------------------------------------------------------------
# Data policy
# ---------------------------------------------------------------------------
# Source documents (scans, OCR PDFs, images) ARE versioned. Large binaries go
# through Git LFS (see .gitattributes); the reviewed structured extractions
# under data/extracted are the durable research artifact.
# Only regenerable working files are ignored:
data/cache/
data/scratch/

# Hearing audio is multi-GB and belongs in an evidence bucket, not git. The WAVs were
# externalized on 2026-06-10 (kept locally, pending upload); integrity + provenance are
# recorded in .../hearings-audio/hearings-audio-externalized.yaml. The derived transcripts
# stay committed.
data/documents/**/*.wav

# Agent run logs / transcripts
runs/
*.log

# Generated GitHub Pages site (`bosc site build` → web/, `mkdocs build` → site/).
# Both are regenerable from data/extracted + docs; the generator is the source.
# Anchored to the repo root so they don't match src/bosc/site/ or data/site/.
/web/
/site/

# Generated content bundle (`bosc export` → data/site/bundle/). The contract is
# committed — README.md, schemas/, manifest.example.json — but the feed data and the
# timestamped manifest are regenerable (and the documents feed is LFS-state-dependent),
# so they stay out of git. Regenerate any time with `bosc export`.
/data/site/bundle/feeds/
/data/site/bundle/manifest.json
